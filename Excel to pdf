<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Excel to PDF - PassionTools</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
    <style>
        :root {
            --red: #ef4444;
            --purple: #a855f7;
            --blue: #3b82f6;
            --blue-dark: #2563eb;
            --green: #22c55e;
            --bg-color: #f9fafb;
            --card-bg: #ffffff;
            --text-primary: #1f2937;
            --text-secondary: #6b7280;
            --border-color: #e5e7eb;
            --hover-gray: #f3f4f6;
            --btn-action-bg: #fef2f2;
            --logo-passion: #000000;
            --header-bg: rgba(255, 255, 255, 0.72);
            --header-border: rgba(229, 231, 235, 0.6);
            --footer-bg: #111827;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 25px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04);
            --shadow-xl: 0 20px 40px -4px rgba(0,0,0,0.1);
        }

        [data-theme="dark"] {
            --bg-color: #020617;
            --card-bg: #111827;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --border-color: #1e293b;
            --hover-gray: #1e293b;
            --btn-action-bg: #450a0a;
            --logo-passion: #ffffff;
            --header-bg: rgba(2, 6, 23, 0.78);
            --header-border: rgba(30, 41, 59, 0.6);
            --footer-bg: #020617;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.3);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.4), 0 2px 4px -2px rgba(0,0,0,0.3);
            --shadow-lg: 0 10px 25px -3px rgba(0,0,0,0.5), 0 4px 6px -4px rgba(0,0,0,0.4);
            --shadow-xl: 0 20px 40px -4px rgba(0,0,0,0.6);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: background-color 0.3s ease, color 0.3s ease;
            line-height: 1.6;
        }

        /* ===== HEADER ===== */
        .header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--header-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--header-border);
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.3s ease;
        }

        .logo-link {
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            font-size: 1.35rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            cursor: pointer;
        }

        .logo-passion {
            color: var(--logo-passion);
            transition: color 0.3s ease;
        }

        .logo-tools {
            background: linear-gradient(135deg, var(--red), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .back-link:hover {
            color: var(--red);
        }

        .theme-toggle {
            background: none;
            border: 1px solid var(--border-color);
            width: 40px;
            height: 40px;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            transition: all 0.3s ease;
        }

        .theme-toggle:hover {
            background: var(--hover-gray);
            border-color: var(--text-secondary);
        }

        /* ===== MAIN CONTENT ===== */
        .main {
            flex: 1;
            max-width: 780px;
            width: 100%;
            margin: 0 auto;
            padding: 48px 20px 60px;
        }

        /* Tool Header */
        .tool-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .tool-title {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin-bottom: 10px;
            color: var(--text-primary);
        }

        .tool-subtitle {
            font-size: 1rem;
            font-weight: 400;
            color: var(--text-secondary);
            max-width: 520px;
            margin: 0 auto;
            line-height: 1.7;
        }

        /* Card Container */
        .tool-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 32px;
            box-shadow: var(--shadow-lg);
            transition: all 0.3s ease;
        }

        /* ===== STATE 1: UPLOAD ===== */
        .upload-zone {
            border: 2px dashed var(--border-color);
            border-radius: 12px;
            padding: 52px 24px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }

        .upload-zone:hover,
        .upload-zone.drag-over {
            border-color: var(--blue);
            background: rgba(59, 130, 246, 0.04);
        }

        [data-theme="dark"] .upload-zone:hover,
        [data-theme="dark"] .upload-zone.drag-over {
            background: rgba(59, 130, 246, 0.08);
        }

        .upload-zone-icon {
            font-size: 2.8rem;
            color: var(--blue);
            margin-bottom: 16px;
            display: block;
        }

        .upload-zone-text {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        .upload-zone-hint {
            font-size: 0.82rem;
            color: var(--text-secondary);
        }

        .upload-zone input[type="file"] {
            display: none;
        }

        /* ===== STATE 2: OPTIONS & PREVIEW ===== */
        .options-panel {
            display: none;
        }

        .file-summary {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 18px;
            background: var(--hover-gray);
            border-radius: 10px;
            margin-bottom: 24px;
            transition: all 0.3s ease;
        }

        .file-summary-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .file-summary-info {
            flex: 1;
            min-width: 0;
        }

        .file-summary-name {
            font-size: 0.92rem;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .file-summary-meta {
            font-size: 0.78rem;
            color: var(--text-secondary);
            margin-top: 2px;
        }

        .file-remove-btn {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 1rem;
            padding: 6px;
            border-radius: 6px;
            transition: all 0.3s ease;
        }

        .file-remove-btn:hover {
            color: var(--red);
            background: var(--btn-action-bg);
        }

        .option-group {
            margin-bottom: 24px;
        }

        .option-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 10px;
            display: block;
        }

        .orientation-toggle {
            display: flex;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .orientation-btn {
            flex: 1;
            padding: 12px 16px;
            border: none;
            background: transparent;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            font-size: 0.88rem;
            font-weight: 500;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .orientation-btn:first-child {
            border-right: 1px solid var(--border-color);
        }

        .orientation-btn.active {
            background: var(--blue);
            color: #ffffff;
        }

        .orientation-btn:not(.active):hover {
            background: var(--hover-gray);
        }

        /* Sheet selector */
        .sheet-selector {
            margin-bottom: 24px;
        }

        .sheet-selector select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            background: var(--card-bg);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            font-size: 0.88rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            appearance: none;
            -webkit-appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236b7280' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 12px center;
            background-size: 16px;
            padding-right: 36px;
        }

        .sheet-selector select:focus {
            outline: none;
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }

        /* Font size option */
        .font-size-toggle {
            display: flex;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .font-size-btn {
            flex: 1;
            padding: 10px 12px;
            border: none;
            background: transparent;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            font-size: 0.82rem;
            font-weight: 500;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.3s ease;
            border-right: 1px solid var(--border-color);
        }

        .font-size-btn:last-child {
            border-right: none;
        }

        .font-size-btn.active {
            background: var(--blue);
            color: #ffffff;
        }

        .font-size-btn:not(.active):hover {
            background: var(--hover-gray);
        }

        /* Checkbox option */
        .option-checkbox {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            padding: 10px 14px;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            transition: all 0.3s ease;
            user-select: none;
        }

        .option-checkbox:hover {
            background: var(--hover-gray);
        }

        .option-checkbox input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--blue);
            cursor: pointer;
            flex-shrink: 0;
        }

        .option-checkbox-label {
            font-size: 0.88rem;
            font-weight: 500;
            color: var(--text-primary);
        }

        .option-checkbox-hint {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 1px;
        }

        .btn-primary {
            width: 100%;
            padding: 14px 24px;
            border: none;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .btn-generate {
            background: var(--blue);
            color: #ffffff;
        }

        .btn-generate:hover {
            background: var(--blue-dark);
            box-shadow: 0 4px 14px rgba(59, 130, 246, 0.35);
        }

        .btn-generate:disabled {
            opacity: 0.65;
            cursor: not-allowed;
            box-shadow: none;
        }

        .btn-download {
            background: var(--green);
            color: #ffffff;
        }

        .btn-download:hover {
            background: #16a34a;
            box-shadow: 0 4px 14px rgba(34, 197, 94, 0.35);
        }

        .btn-ghost {
            width: 100%;
            padding: 13px 24px;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            background: transparent;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-secondary);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-ghost:hover {
            border-color: var(--text-secondary);
            color: var(--text-primary);
            background: var(--hover-gray);
        }

        /* Spinner */
        .spinner {
            width: 18px;
            height: 18px;
            border: 2.5px solid rgba(255,255,255,0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ===== STATE 3: SUCCESS ===== */
        .success-panel {
            display: none;
        }

        .success-banner {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px 18px;
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.25);
            border-radius: 10px;
            margin-bottom: 24px;
            transition: all 0.3s ease;
        }

        [data-theme="dark"] .success-banner {
            background: rgba(34, 197, 94, 0.08);
            border-color: rgba(34, 197, 94, 0.2);
        }

        .success-banner-icon {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--green);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .success-banner-text {
            font-size: 0.92rem;
            font-weight: 600;
            color: var(--green);
        }

        .success-banner-sub {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-top: 2px;
        }

        /* Error */
        .error-msg {
            display: none;
            align-items: center;
            gap: 10px;
            padding: 14px 16px;
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.22);
            border-radius: 10px;
            margin-top: 16px;
            font-size: 0.87rem;
            font-weight: 500;
            color: var(--red);
            transition: all 0.3s ease;
        }

        .error-msg i {
            font-size: 1rem;
            flex-shrink: 0;
        }

        /* Data preview */
        .data-preview {
            margin-bottom: 24px;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .data-preview-header {
            padding: 10px 16px;
            background: var(--hover-gray);
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .data-preview-table-wrap {
            overflow-x: auto;
            max-height: 260px;
            overflow-y: auto;
        }

        .data-preview-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.78rem;
        }

        .data-preview-table th {
            padding: 8px 12px;
            text-align: left;
            font-weight: 600;
            color: var(--text-primary);
            background: var(--hover-gray);
            border-bottom: 1px solid var(--border-color);
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .data-preview-table td {
            padding: 7px 12px;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border-color);
            white-space: nowrap;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .data-preview-table tr:last-child td {
            border-bottom: none;
        }

        /* Progress bar */
        .progress-wrap {
            display: none;
            margin-top: 16px;
        }

        .progress-bar-outer {
            width: 100%;
            height: 6px;
            background: var(--hover-gray);
            border-radius: 3px;
            overflow: hidden;
        }

        .progress-bar-inner {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--blue), var(--purple));
            border-radius: 3px;
            transition: width 0.3s ease;
        }

        .progress-text {
            font-size: 0.78rem;
            color: var(--text-secondary);
            margin-top: 6px;
            text-align: center;
        }

        /* ===== FOOTER ===== */
        .footer {
            text-align: center;
            padding: 30px 20px;
            font-size: 14px;
            color: #94a3b8;
            background: var(--footer-bg);
            transition: background 0.3s ease;
        }

        /* ===== ANIMATIONS ===== */
        .fade-in {
            animation: fadeIn 0.4s ease forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .pulse-icon {
            animation: pulseIcon 2s ease-in-out infinite;
        }

        @keyframes pulseIcon {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.06); }
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 640px) {
            .main {
                padding: 32px 16px 48px;
            }

            .tool-card {
                padding: 24px 18px;
            }

            .tool-title {
                font-size: 1.55rem;
            }

            .tool-subtitle {
                font-size: 0.9rem;
            }

            .upload-zone {
                padding: 40px 16px;
            }

            .upload-zone-icon {
                font-size: 2.2rem;
            }

            .orientation-toggle {
                flex-direction: column;
            }

            .orientation-btn:first-child {
                border-right: none;
                border-bottom: 1px solid var(--border-color);
            }

            .font-size-toggle {
                flex-direction: column;
            }

            .font-size-btn {
                border-right: none !important;
                border-bottom: 1px solid var(--border-color);
            }

            .font-size-btn:last-child {
                border-bottom: none;
            }

            .header {
                padding: 0 16px;
            }

            .back-link span {
                display: none;
            }

            .success-btns {
                display: flex;
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="header">
        <a href="#" onclick="event.preventDefault();" class="logo-link">
            <span class="logo-passion">Passion</span><span class="logo-tools">Tools</span>
        </a>
        <div class="header-actions">
            <a href="index.html" class="back-link">
                <i class="fas fa-arrow-left"></i>
                <span>Back to Tools</span>
            </a>
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">☀️</button>
        </div>
    </header>

    <!-- MAIN -->
    <main class="main">
        <!-- Tool Header -->
        <div class="tool-header fade-in">
            <h1 class="tool-title">Excel to PDF</h1>
            <p class="tool-subtitle">Convert your spreadsheets (.xlsx, .csv) to print-ready PDF documents instantly. 100% private in-browser processing.</p>
        </div>

        <!-- Tool Card -->
        <div class="tool-card fade-in">

            <!-- STATE 1: Upload -->
            <div id="stateUpload">
                <div class="upload-zone" id="uploadZone">
                    <input type="file" id="fileInput" accept=".xlsx,.xls,.csv">
                    <i class="fas fa-file-excel upload-zone-icon pulse-icon"></i>
                    <p class="upload-zone-text">Click or Drag & Drop Excel file here</p>
                    <p class="upload-zone-hint">Supports .xlsx, .xls and .csv files</p>
                </div>
                <div class="error-msg" id="errorMsg">
                    <i class="fas fa-circle-exclamation"></i>
                    <span id="errorText"></span>
                </div>
            </div>

            <!-- STATE 2: Options & Preview -->
            <div class="options-panel" id="stateOptions">
                <div class="file-summary" id="fileSummary">
                    <div class="file-summary-icon"><i class="fas fa-file-excel"></i></div>
                    <div class="file-summary-info">
                        <div class="file-summary-name" id="fileName"></div>
                        <div class="file-summary-meta" id="fileMeta"></div>
                    </div>
                    <button class="file-remove-btn" id="removeFileBtn" aria-label="Remove file"><i class="fas fa-xmark"></i></button>
                </div>

                <!-- Sheet Selector (shown only for multi-sheet workbooks) -->
                <div class="sheet-selector option-group" id="sheetSelectorWrap" style="display:none;">
                    <label class="option-label"><i class="fas fa-layer-group"></i> Select Sheet</label>
                    <select id="sheetSelect"></select>
                </div>

                <!-- Data Preview -->
                <div class="data-preview" id="dataPreview">
                    <div class="data-preview-header">
                        <i class="fas fa-table"></i> Data Preview <span id="previewCount" style="margin-left:auto; font-weight:400;"></span>
                    </div>
                    <div class="data-preview-table-wrap">
                        <table class="data-preview-table" id="previewTable"></table>
                    </div>
                </div>

                <!-- Options Row -->
                <div class="option-group">
                    <label class="option-label">Page Orientation</label>
                    <div class="orientation-toggle">
                        <button class="orientation-btn" data-orient="portrait" id="btnPortrait">
                            <i class="fas fa-file-lines"></i> Portrait
                        </button>
                        <button class="orientation-btn active" data-orient="landscape" id="btnLandscape">
                            <i class="fas fa-file"></i> Landscape
                        </button>
                    </div>
                </div>

                <div class="option-group">
                    <label class="option-label">Font Size</label>
                    <div class="font-size-toggle">
                        <button class="font-size-btn" data-size="small" id="btnFontSmall">
                            <i class="fas fa-font"></i> Small (6pt)
                        </button>
                        <button class="font-size-btn active" data-size="medium" id="btnFontMedium">
                            <i class="fas fa-font"></i> Medium (8pt)
                        </button>
                        <button class="font-size-btn" data-size="large" id="btnFontLarge">
                            <i class="fas fa-font"></i> Large (10pt)
                        </button>
                    </div>
                </div>

                <div class="option-group">
                    <label class="option-checkbox" id="fitPageCheckbox">
                        <input type="checkbox" id="fitPageToggle" checked>
                        <div>
                            <div class="option-checkbox-label">Fit table to page width</div>
                            <div class="option-checkbox-hint">Automatically scales columns to fit within page margins</div>
                        </div>
                    </label>
                </div>

                <button class="btn-primary btn-generate" id="generateBtn">
                    <i class="fas fa-file-pdf"></i> Generate PDF
                </button>

                <div class="progress-wrap" id="progressWrap">
                    <div class="progress-bar-outer">
                        <div class="progress-bar-inner" id="progressBar"></div>
                    </div>
                    <div class="progress-text" id="progressText">Preparing...</div>
                </div>

                <div class="error-msg" id="errorMsgOptions">
                    <i class="fas fa-circle-exclamation"></i>
                    <span id="errorTextOptions"></span>
                </div>
            </div>

            <!-- STATE 3: Success -->
            <div class="success-panel" id="stateSuccess">
                <div class="success-banner">
                    <div class="success-banner-icon"><i class="fas fa-check"></i></div>
                    <div>
                        <div class="success-banner-text">PDF Generated Successfully!</div>
                        <div class="success-banner-sub" id="successMeta">Your file is ready to download.</div>
                    </div>
                </div>
                <div class="success-btns">
                    <button class="btn-primary btn-download" id="downloadBtn">
                        <i class="fas fa-download"></i> Download PDF
                    </button>
                    <button class="btn-ghost" id="convertAnotherBtn">
                        <i class="fas fa-rotate-right"></i> Convert Another File
                    </button>
                </div>
            </div>

        </div>
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        © 2026 Passion Tools. Secure client-side processing.
    </footer>

    <script>
        // ===== Theme Toggle =====
        const themeToggle = document.getElementById('themeToggle');
        const html = document.documentElement;

        function applyTheme(theme) {
            html.setAttribute('data-theme', theme);
            themeToggle.textContent = theme === 'dark' ? '🌙' : '☀️';
            localStorage.setItem('pt-theme', theme);
        }

        const savedTheme = localStorage.getItem('pt-theme') || 'light';
        applyTheme(savedTheme);

        themeToggle.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            applyTheme(current === 'dark' ? 'light' : 'dark');
        });

        // ===== State Management =====
        const stateUpload = document.getElementById('stateUpload');
        const stateOptions = document.getElementById('stateOptions');
        const stateSuccess = document.getElementById('stateSuccess');
        const uploadZone = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');
        const errorMsg = document.getElementById('errorMsg');
        const errorText = document.getElementById('errorText');
        const errorMsgOptions = document.getElementById('errorMsgOptions');
        const errorTextOptions = document.getElementById('errorTextOptions');
        const generateBtn = document.getElementById('generateBtn');
        const downloadBtn = document.getElementById('downloadBtn');
        const convertAnotherBtn = document.getElementById('convertAnotherBtn');
        const removeFileBtn = document.getElementById('removeFileBtn');
        const btnPortrait = document.getElementById('btnPortrait');
        const btnLandscape = document.getElementById('btnLandscape');
        const sheetSelect = document.getElementById('sheetSelect');
        const sheetSelectorWrap = document.getElementById('sheetSelectorWrap');
        const progressWrap = document.getElementById('progressWrap');
        const progressBar = document.getElementById('progressBar');
        const progressText = document.getElementById('progressText');
        const fitPageToggle = document.getElementById('fitPageToggle');

        let workbookRef = null;
        let parsedData = [];
        let uploadedFileName = '';
        let orientation = 'landscape';
        let fontSize = 'medium';
        let generatedPdfBlob = null;
        let pdfFileName = '';
        let currentSheetName = '';

        function showState(state) {
            stateUpload.style.display = 'none';
            stateOptions.style.display = 'none';
            stateSuccess.style.display = 'none';
            hideError();
            hideErrorOptions();
            progressWrap.style.display = 'none';

            if (state === 'upload') stateUpload.style.display = 'block';
            else if (state === 'options') { stateOptions.style.display = 'block'; stateOptions.classList.add('fade-in'); }
            else if (state === 'success') { stateSuccess.style.display = 'block'; stateSuccess.classList.add('fade-in'); }
        }

        function showError(msg) {
            errorMsg.style.display = 'flex';
            errorText.textContent = msg;
        }
        function hideError() { errorMsg.style.display = 'none'; }
        function showErrorOptions(msg) {
            errorMsgOptions.style.display = 'flex';
            errorTextOptions.textContent = msg;
        }
        function hideErrorOptions() { errorMsgOptions.style.display = 'none'; }

        // ===== Upload Zone =====
        uploadZone.addEventListener('click', () => fileInput.click());

        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.classList.add('drag-over');
        });
        uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('drag-over');
            const files = e.dataTransfer.files;
            if (files.length) handleFile(files[0]);
        });
        fileInput.addEventListener('change', () => {
            if (fileInput.files.length) handleFile(fileInput.files[0]);
        });

        // ===== Robust Cell Formatting =====
        function formatCellValue(cell, raw) {
            if (cell === undefined || cell === null) return '';
            // If it's a Date object, format it
            if (cell instanceof Date) {
                if (!isNaN(cell.getTime())) {
                    const y = cell.getFullYear();
                    const m = String(cell.getMonth() + 1).padStart(2, '0');
                    const d = String(cell.getDate()).padStart(2, '0');
                    // Check if it has time component
                    if (cell.getHours() || cell.getMinutes() || cell.getSeconds()) {
                        const hh = String(cell.getHours()).padStart(2, '0');
                        const mm = String(cell.getMinutes()).padStart(2, '0');
                        return `${y}-${m}-${d} ${hh}:${mm}`;
                    }
                    return `${y}-${m}-${d}`;
                }
                return String(cell);
            }
            if (typeof cell === 'boolean') return cell ? 'TRUE' : 'FALSE';
            if (typeof cell === 'number') {
                // Check for potential Excel date serial number (between 1 and 2958465)
                // Only convert if the raw format suggests a date
                return String(cell);
            }
            if (typeof cell === 'object' && cell.t === 'e') return '#ERROR';
            return String(cell);
        }

        // ===== Extract sheet data with full formatting =====
        function extractSheetData(workbook, sheetName) {
            const sheet = workbook.Sheets[sheetName];
            if (!sheet) return [];

            // Use raw: false to get formatted values, and dateNF for date formatting
            const jsonData = XLSX.utils.sheet_to_json(sheet, {
                header: 1,
                defval: '',
                raw: false,
                dateNF: 'yyyy-mm-dd'
            });

            if (!jsonData || jsonData.length === 0) return [];

            // Find the true maximum column count across ALL rows
            let maxCols = 0;
            for (let i = 0; i < jsonData.length; i++) {
                if (jsonData[i] && jsonData[i].length > maxCols) {
                    maxCols = jsonData[i].length;
                }
            }

            if (maxCols === 0) return [];

            // Normalize ALL rows to have exactly maxCols columns
            const normalized = [];
            for (let i = 0; i < jsonData.length; i++) {
                const row = jsonData[i] || [];
                const normalizedRow = [];
                for (let c = 0; c < maxCols; c++) {
                    const val = row[c];
                    normalizedRow.push(formatCellValue(val, row[c]));
                }
                normalized.push(normalizedRow);
            }

            // Filter out completely empty rows
            const filtered = normalized.filter(row =>
                row.some(cell => cell !== '' && cell !== null && cell !== undefined)
            );

            return filtered;
        }

        // ===== File Handling =====
        function handleFile(file) {
            hideError();
            const validExts = ['.xlsx', '.xls', '.csv'];
            const ext = '.' + file.name.split('.').pop().toLowerCase();
            if (!validExts.includes(ext)) {
                showError('Unsupported file format. Please upload an .xlsx, .xls, or .csv file.');
                return;
            }

            // Check file size (warn for very large files)
            if (file.size > 50 * 1024 * 1024) {
                showError('File is very large (>50MB). Please use a smaller file for best results.');
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, {
                        type: 'array',
                        cellDates: true,
                        cellNF: true,
                        cellText: true,
                        raw: false
                    });

                    if (!workbook.SheetNames || workbook.SheetNames.length === 0) {
                        showError('The workbook appears to be empty. No sheets were found.');
                        return;
                    }

                    workbookRef = workbook;
                    uploadedFileName = file.name;

                    // Populate sheet selector
                    sheetSelect.innerHTML = '';
                    workbook.SheetNames.forEach((name, idx) => {
                        const opt = document.createElement('option');
                        opt.value = name;
                        opt.textContent = `${name}`;
                        sheetSelect.appendChild(opt);
                    });

                    // Show/hide sheet selector
                    if (workbook.SheetNames.length > 1) {
                        sheetSelectorWrap.style.display = 'block';
                    } else {
                        sheetSelectorWrap.style.display = 'none';
                    }

                    // Load first sheet
                    loadSheet(workbook.SheetNames[0]);

                } catch (err) {
                    showError('Failed to parse the file. It may be corrupted or in an unsupported format.');
                    console.error(err);
                }
            };
            reader.onerror = function() {
                showError('An error occurred while reading the file. Please try again.');
            };
            reader.readAsArrayBuffer(file);
        }

        function loadSheet(sheetName) {
            const filtered = extractSheetData(workbookRef, sheetName);

            if (filtered.length === 0) {
                showError('The selected sheet is empty. No data rows were found.');
                if (stateOptions.style.display === 'block') {
                    showErrorOptions('The selected sheet is empty. No data rows were found.');
                }
                return;
            }

            parsedData = filtered;
            currentSheetName = sheetName;

            // Get column count from normalized data
            const cols = filtered[0].length;
            const totalDataRows = filtered.length - 1; // subtract header

            // Show options
            document.getElementById('fileName').textContent = uploadedFileName;
            document.getElementById('fileMeta').textContent =
                `${filtered.length} rows · ${cols} columns · Sheet: "${sheetName}"` +
                (workbookRef.SheetNames.length > 1 ? ` · ${workbookRef.SheetNames.length} sheets total` : '');

            // Auto-suggest orientation based on column count
            if (cols > 5) {
                orientation = 'landscape';
                btnLandscape.classList.add('active');
                btnPortrait.classList.remove('active');
            }

            // Auto-suggest font size based on column count
            if (cols > 12) {
                setFontSize('small');
            } else if (cols > 7) {
                setFontSize('medium');
            }

            // Build preview table
            buildPreviewTable(filtered);

            showState('options');
            hideErrorOptions();
        }

        // Sheet selector change
        sheetSelect.addEventListener('change', () => {
            loadSheet(sheetSelect.value);
        });

        function buildPreviewTable(data) {
            const table = document.getElementById('previewTable');
            table.innerHTML = '';
            const maxCols = data[0] ? data[0].length : 0;
            const previewRowCount = Math.min(data.length, 10);
            const previewRows = data.slice(0, previewRowCount);

            document.getElementById('previewCount').textContent =
                `Showing ${previewRowCount} of ${data.length} rows`;

            previewRows.forEach((row, ri) => {
                const tr = document.createElement('tr');
                for (let ci = 0; ci < maxCols; ci++) {
                    const cell = document.createElement(ri === 0 ? 'th' : 'td');
                    const val = row[ci] !== undefined && row[ci] !== null ? row[ci] : '';
                    cell.textContent = String(val);
                    cell.title = String(val); // tooltip for truncated cells
                    tr.appendChild(cell);
                }
                table.appendChild(tr);
            });

            if (data.length > previewRowCount) {
                const tr = document.createElement('tr');
                const td = document.createElement('td');
                td.colSpan = maxCols;
                td.style.textAlign = 'center';
                td.style.fontStyle = 'italic';
                td.style.color = 'var(--text-secondary)';
                td.style.padding = '10px';
                td.textContent = `… and ${data.length - previewRowCount} more rows`;
                tr.appendChild(td);
                table.appendChild(tr);
            }
        }

        // ===== Orientation Toggle =====
        btnPortrait.addEventListener('click', () => {
            orientation = 'portrait';
            btnPortrait.classList.add('active');
            btnLandscape.classList.remove('active');
        });
        btnLandscape.addEventListener('click', () => {
            orientation = 'landscape';
            btnLandscape.classList.add('active');
            btnPortrait.classList.remove('active');
        });

        // ===== Font Size Toggle =====
        function setFontSize(size) {
            fontSize = size;
            document.querySelectorAll('.font-size-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('btnFont' + size.charAt(0).toUpperCase() + size.slice(1)).classList.add('active');
        }

        document.getElementById('btnFontSmall').addEventListener('click', () => setFontSize('small'));
        document.getElementById('btnFontMedium').addEventListener('click', () => setFontSize('medium'));
        document.getElementById('btnFontLarge').addEventListener('click', () => setFontSize('large'));

        // ===== Remove file =====
        removeFileBtn.addEventListener('click', resetTool);

        function resetTool() {
            parsedData = [];
            workbookRef = null;
            uploadedFileName = '';
            currentSheetName = '';
            generatedPdfBlob = null;
            pdfFileName = '';
            fileInput.value = '';
            orientation = 'landscape';
            fontSize = 'medium';
            btnLandscape.classList.add('active');
            btnPortrait.classList.remove('active');
            setFontSize('medium');
            fitPageToggle.checked = true;
            sheetSelectorWrap.style.display = 'none';
            showState('upload');
        }

        // ===== Progress helpers =====
        function showProgress(pct, text) {
            progressWrap.style.display = 'block';
            progressBar.style.width = pct + '%';
            progressText.textContent = text;
        }

        function hideProgress() {
            progressWrap.style.display = 'none';
            progressBar.style.width = '0%';
        }

        // ===== Generate PDF =====
        generateBtn.addEventListener('click', async () => {
            if (!parsedData.length) {
                showErrorOptions('No data available to generate PDF.');
                return;
            }

            // Show spinner
            generateBtn.disabled = true;
            generateBtn.innerHTML = '<div class="spinner"></div> Generating…';
            hideErrorOptions();
            showProgress(10, 'Initializing PDF document...');

            // Slight delay to let UI update
            await new Promise(r => setTimeout(r, 100));

            try {
                const { jsPDF } = window.jspdf;

                // Determine page size - use A3 for very wide tables
                const numCols = parsedData[0].length;
                let pageFormat = 'a4';
                if (numCols > 15 && orientation === 'portrait') {
                    pageFormat = 'a3';
                } else if (numCols > 20) {
                    pageFormat = 'a3';
                }

                const doc = new jsPDF({
                    orientation: orientation,
                    unit: 'mm',
                    format: pageFormat
                });

                showProgress(20, 'Preparing table data...');
                await new Promise(r => setTimeout(r, 50));

                // Use first row as headers
                const headers = parsedData[0].map(h => {
                    const s = String(h !== undefined && h !== null ? h : '');
                    return s.trim() === '' ? ' ' : s;
                });

                // Process ALL body rows - ensure every row has the same number of columns
                const bodyRows = [];
                for (let i = 1; i < parsedData.length; i++) {
                    const row = parsedData[i];
                    const processedRow = [];
                    for (let c = 0; c < headers.length; c++) {
                        const val = row[c];
                        processedRow.push(String(val !== undefined && val !== null ? val : ''));
                    }
                    bodyRows.push(processedRow);
                }

                showProgress(40, `Processing ${bodyRows.length} rows...`);
                await new Promise(r => setTimeout(r, 50));

                // Calculate font sizes based on user selection and column count
                const fontSizeMap = { small: 6, medium: 8, large: 10 };
                const headFontSizeMap = { small: 6.5, medium: 8.5, large: 10.5 };
                let baseFontSize = fontSizeMap[fontSize];
                let headFontSize = headFontSizeMap[fontSize];

                // Auto-reduce font if too many columns and fit-to-page is on
                const fitToPage = fitPageToggle.checked;
                const pageWidth = doc.internal.pageSize.getWidth();
                const usableWidth = pageWidth - 20; // 10mm margins each side

                if (fitToPage && numCols > 0) {
                    // Estimate: each column needs roughly (fontSize * 3) mm minimum
                    const estimatedMinWidth = numCols * baseFontSize * 3;
                    if (estimatedMinWidth > usableWidth) {
                        // Scale down font to fit
                        const scaleFactor = usableWidth / estimatedMinWidth;
                        const autoFontSize = Math.max(4, Math.floor(baseFontSize * scaleFactor * 10) / 10);
                        if (autoFontSize < baseFontSize) {
                            baseFontSize = autoFontSize;
                            headFontSize = autoFontSize + 0.5;
                        }
                    }
                }

                // Calculate cell padding based on font size
                const cellPadding = Math.max(1.5, baseFontSize * 0.35);
                const margins = { top: 18, left: 8, right: 8, bottom: 14 };

                showProgress(60, 'Generating PDF table...');
                await new Promise(r => setTimeout(r, 50));

                // Column styles - calculate optimal widths
                const columnStyles = {};
                if (fitToPage) {
                    // Calculate column widths based on content
                    const colMaxLengths = [];
                    for (let c = 0; c < headers.length; c++) {
                        let maxLen = String(headers[c]).length;
                        // Sample rows to find max content length (check all rows for accuracy)
                        const sampleSize = Math.min(bodyRows.length, 200);
                        for (let r = 0; r < sampleSize; r++) {
                            const idx = Math.floor(r * bodyRows.length / sampleSize);
                            const cellLen = String(bodyRows[idx][c] || '').length;
                            if (cellLen > maxLen) maxLen = cellLen;
                        }
                        colMaxLengths.push(maxLen);
                    }

                    // Set column widths proportionally
                    const totalLen = colMaxLengths.reduce((a, b) => a + Math.max(b, 3), 0);
                    for (let c = 0; c < headers.length; c++) {
                        const proportion = Math.max(colMaxLengths[c], 3) / totalLen;
                        const colWidth = Math.max(proportion * usableWidth, baseFontSize * 2);
                        columnStyles[c] = { cellWidth: colWidth };
                    }
                }

                const docTitle = uploadedFileName.replace(/\.[^.]+$/, '');

                doc.autoTable({
                    head: [headers],
                    body: bodyRows,
                    startY: 18,
                    styles: {
                        font: 'helvetica',
                        fontSize: baseFontSize,
                        cellPadding: cellPadding,
                        overflow: 'linebreak',
                        lineColor: [200, 200, 200],
                        lineWidth: 0.15,
                        valign: 'middle',
                        halign: 'left',
                        minCellWidth: baseFontSize * 2,
                    },
                    headStyles: {
                        fillColor: [37, 99, 235],
                        textColor: [255, 255, 255],
                        fontStyle: 'bold',
                        fontSize: headFontSize,
                        halign: 'left',
                        valign: 'middle',
                    },
                    alternateRowStyles: {
                        fillColor: [245, 247, 250],
                    },
                    columnStyles: fitToPage ? columnStyles : {},
                    margin: margins,
                    tableWidth: fitToPage ? 'wrap' : 'auto',
                    showHead: 'everyPage',
                    rowPageBreak: 'auto',
                    didDrawPage: function(data) {
                        // Header - document title
                        doc.setFontSize(10);
                        doc.setFont('helvetica', 'bold');
                        doc.setTextColor(31, 41, 55);
                        const title = docTitle.length > 60 ? docTitle.substring(0, 57) + '...' : docTitle;
                        doc.text(title, margins.left, 11);

                        // Sheet name indicator (if multi-sheet)
                        if (workbookRef && workbookRef.SheetNames.length > 1) {
                            doc.setFontSize(7);
                            doc.setFont('helvetica', 'normal');
                            doc.setTextColor(107, 114, 128);
                            doc.text(`Sheet: ${currentSheetName}`, margins.left, 15);
                        }

                        // Footer
                        const pw = doc.internal.pageSize.getWidth();
                        const ph = doc.internal.pageSize.getHeight();
                        const pageNum = doc.getCurrentPageInfo().pageNumber;
                        doc.setFontSize(7);
                        doc.setFont('helvetica', 'normal');
                        doc.setTextColor(148, 163, 184);
                        doc.text(
                            `Generated by PassionTools  ·  Page ${pageNum}`,
                            pw / 2, ph - 7,
                            { align: 'center' }
                        );

                        // Row count on first page
                        if (pageNum === 1) {
                            doc.setFontSize(7);
                            doc.setTextColor(148, 163, 184);
                            doc.text(
                                `${bodyRows.length} data rows · ${headers.length} columns`,
                                pw - margins.right, 11,
                                { align: 'right' }
                            );
                        }
                    },
                });

                showProgress(90, 'Finalizing PDF...');
                await new Promise(r => setTimeout(r, 50));

                const pdfOutput = doc.output('blob');
                generatedPdfBlob = pdfOutput;
                pdfFileName = docTitle + '.pdf';

                const totalPages = doc.internal.getNumberOfPages();
                const fileSizeKB = Math.round(pdfOutput.size / 1024);
                const fileSizeStr = fileSizeKB > 1024
                    ? (fileSizeKB / 1024).toFixed(1) + ' MB'
                    : fileSizeKB + ' KB';

                document.getElementById('successMeta').textContent =
                    `${pdfFileName} · ${totalPages} page${totalPages > 1 ? 's' : ''} · ${fileSizeStr} · ${orientation.charAt(0).toUpperCase() + orientation.slice(1)} · ${bodyRows.length} rows`;

                showProgress(100, 'Done!');
                await new Promise(r => setTimeout(r, 200));

                showState('success');
            } catch (err) {
                hideProgress();
                showErrorOptions('An error occurred while generating the PDF: ' + err.message);
                console.error(err);
            } finally {
                generateBtn.disabled = false;
                generateBtn.innerHTML = '<i class="fas fa-file-pdf"></i> Generate PDF';
                hideProgress();
            }
        });

        // ===== Download PDF =====
        downloadBtn.addEventListener('click', () => {
            if (!generatedPdfBlob) return;
            const url = URL.createObjectURL(generatedPdfBlob);
            const a = document.createElement('a');
            a.href = url;
            a.download = pdfFileName;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            setTimeout(() => URL.revokeObjectURL(url), 1000);
        });

        // ===== Convert Another =====
        convertAnotherBtn.addEventListener('click', resetTool);

        // Initial state
        showState('upload');
    </script>
</body>

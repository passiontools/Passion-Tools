    <!-- OFFSCREEN CANVAS -->
    <canvas id="offscreenCanvas" style="display:none"></canvas>

    <script>
    (() => {
    'use strict';

    // ===== MATRICES =====
    const IDENTITY = [1,0,0, 0,1,0, 0,0,1];
    const MATRICES = {
        normal:        [1,0,0, 0,1,0, 0,0,1],
        protanopia:    [0.56667,0.43333,0, 0.55833,0.44167,0, 0,0.24167,0.75833],
        deuteranopia:  [0.625,0.375,0, 0.7,0.3,0, 0,0.3,0.7],
        tritanopia:    [0.95,0.05,0, 0,0.43333,0.56667, 0,0.475,0.525],
        achromatopsia: [0.299,0.587,0.114, 0.299,0.587,0.114, 0.299,0.587,0.114],
        protanomaly:   [0.81667,0.18333,0, 0.33333,0.66667,0, 0,0.125,0.875],
        deuteranomaly: [0.8,0.2,0, 0.25833,0.74167,0, 0,0.14167,0.85833],
        tritanomaly:   [0.96667,0.03333,0, 0,0.73333,0.26667, 0,0.18333,0.81667]
    };
    const FILTER_LABELS = {
        normal:'Normal Vision', protanopia:'Protanopia (Red-Blind)',
        deuteranopia:'Deuteranopia (Green-Blind)', tritanopia:'Tritanopia (Blue-Blind)',
        achromatopsia:'Achromatopsia (Monochromacy)', protanomaly:'Protanomaly (Red-Weak)',
        deuteranomaly:'Deuteranomaly (Green-Weak)', tritanomaly:'Tritanomaly (Blue-Weak)'
    };
    const FILTER_KEYS = Object.keys(MATRICES);
    const MAX_DIM = 4096;

    // ===== STATE =====
    const state = {
        activeFilter:'normal', viewMode:'single', severity:100,
        zoom:1, panX:0, panY:0, isPanning:false, panStart:{x:0,y:0},
        eyedropper:false, fileName:'image', fileSize:0,
        dominantColors:[], imageLoaded:false
    };

    // ===== DOM =====
    const $ = id => document.getElementById(id);
    const html = document.documentElement;
    const themeToggle = $('themeToggle');
    const uploadArea = $('uploadArea');
    const simulatorArea = $('simulatorArea');
    const dropZone = $('dropZone');
    const fileInput = $('fileInput');
    const previewCanvas = $('previewCanvas');
    const offscreenCanvas = $('offscreenCanvas');
    const canvasWrapper = $('canvasWrapper');
    const filterButtonsEl = $('filterButtons');
    const downloadBtn = $('downloadBtn');
    const downloadAllBtn = $('downloadAllBtn');
    const copyBtn = $('copyBtn');
    const startOverBtn = $('startOverBtn');
    const severitySlider = $('severitySlider');
    const severityValue = $('severityValue');
    const severityPanel = $('severityPanel');
    const zoomIndicator = $('zoomIndicator');
    const eyedropperBtn = $('eyedropperBtn');
    const eyedropperTooltip = $('eyedropperTooltip');
    const singleView = $('singleView');
    const compareView = $('compareView');
    const gridView = $('gridView');
    const compareContainer = $('compareContainer');
    const compareOriginalCanvas = $('compareOriginalCanvas');
    const compareFilteredCanvas = $('compareFilteredCanvas');
    const compareOverlay = $('compareOverlay');
    const compareHandle = $('compareHandle');
    const compareLabelLeft = $('compareLabelLeft');
    const compareLabelRight = $('compareLabelRight');
    const gridContainer = $('gridContainer');
    const viewModesEl = $('viewModes');
    const toastContainer = $('toastContainer');
    const shortcutsModal = $('shortcutsModal');

    const previewCtx = previewCanvas.getContext('2d', {willReadFrequently:true});
    const offscreenCtx = offscreenCanvas.getContext('2d', {willReadFrequently:true});

    // ===== THEME =====
    function setTheme(t) {
        html.setAttribute('data-theme', t);
        themeToggle.textContent = t==='dark' ? '🌙' : '☀️';
        localStorage.setItem('passion-tools-theme', t);
    }
    (() => {
        const s = localStorage.getItem('passion-tools-theme');
        if(s) setTheme(s);
        else if(matchMedia('(prefers-color-scheme:dark)').matches) setTheme('dark');
    })();
    themeToggle.addEventListener('click', () => setTheme(html.getAttribute('data-theme')==='dark'?'light':'dark'));

    // ===== TOAST =====
    function showToast(msg, type='info') {
        const t = document.createElement('div');
        t.className = `toast toast-${type}`;
        const icons = {info:'fa-circle-info', success:'fa-circle-check', error:'fa-circle-exclamation'};
        t.innerHTML = `<i class="fa-solid ${icons[type]||icons.info}"></i> ${msg}`;
        toastContainer.appendChild(t);
        setTimeout(() => { t.classList.add('toast-exit'); setTimeout(()=>t.remove(),300); }, 3000);
    }

    // ===== FILE HANDLING =====
    const validTypes = ['image/jpeg','image/png','image/webp'];

    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('drag-over'); if(e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', e => { if(e.target.files.length) handleFile(e.target.files[0]); });

    // Clipboard paste
    document.addEventListener('paste', e => {
        const items = e.clipboardData?.items;
        if(!items) return;
        for(const item of items) {
            if(item.type.startsWith('image/')) {
                e.preventDefault();
                handleFile(item.getAsFile());
                break;
            }
        }
    });

    function handleFile(file) {
        if(!validTypes.includes(file.type)) { showToast('Unsupported format. Use JPG, PNG, or WEBP.','error'); return; }
        state.fileName = file.name.replace(/\.[^/.]+$/,'') || 'image';
        state.fileSize = file.size;
        const reader = new FileReader();
        reader.onload = e => {
            const img = new Image();
            img.onload = () => {
                let w = img.width, h = img.height;
                if(w > MAX_DIM || h > MAX_DIM) {
                    const scale = MAX_DIM / Math.max(w,h);
                    w = Math.round(w*scale); h = Math.round(h*scale);
                }
                offscreenCanvas.width = w; offscreenCanvas.height = h;
                offscreenCtx.drawImage(img, 0, 0, w, h);
                previewCanvas.width = w; previewCanvas.height = h;
                previewCtx.drawImage(img, 0, 0, w, h);
                $('infoName').textContent = state.fileName + '.' + (file.name.split('.').pop()||'png');
                $('infoDims').textContent = `${w} × ${h}`;
                $('infoSize').textContent = formatBytes(state.fileSize);
                state.imageLoaded = true;
                state.dominantColors = extractPalette();
                showSimulator();
                showToast('Image loaded successfully!','success');
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    }

    function formatBytes(b) {
        if(b<1024) return b+' B';
        if(b<1048576) return (b/1024).toFixed(1)+' KB';
        return (b/1048576).toFixed(1)+' MB';
    }

    // ===== VIEW MANAGEMENT =====
    function showSimulator() {
        uploadArea.classList.add('hidden');
        simulatorArea.classList.add('active');
        simulatorArea.classList.add('fade-in');
        state.activeFilter = 'normal';
        state.severity = 100;
        severitySlider.value = 100;
        severityValue.textContent = '100%';
        resetZoom();
        updateFilterButtons();
        updateSeverityVisibility();
        setViewMode('single');
        renderPalette();
        renderAccessibility();
    }

    function showUpload() {
        simulatorArea.classList.remove('active','fade-in');
        uploadArea.classList.remove('hidden');
        uploadArea.classList.add('fade-in');
        state.imageLoaded = false;
        state.eyedropper = false;
        eyedropperBtn.classList.remove('active');
        eyedropperTooltip.classList.remove('visible');
    }

    function setViewMode(mode) {
        state.viewMode = mode;
        singleView.style.display = mode==='single' ? 'flex' : 'none';
        compareView.classList.toggle('active', mode==='compare');
        gridView.classList.toggle('active', mode==='grid');
        document.querySelectorAll('.view-mode-btn').forEach(b => b.classList.toggle('active', b.dataset.view===mode));
        updateSeverityVisibility();
        if(mode==='single') renderSingle();
        else if(mode==='compare') renderCompare();
        else if(mode==='grid') renderGrid();
    }

    viewModesEl.addEventListener('click', e => {
        const btn = e.target.closest('.view-mode-btn');
        if(btn && state.imageLoaded) setViewMode(btn.dataset.view);
    });

    function updateSeverityVisibility() {
        severityPanel.classList.toggle('hidden', state.activeFilter==='normal');
    }

    // ===== FILTER BUTTONS =====
    filterButtonsEl.addEventListener('click', e => {
        const btn = e.target.closest('.filter-btn');
        if(!btn) return;
        state.activeFilter = btn.dataset.filter;
        updateFilterButtons();
        updateSeverityVisibility();
        if(state.viewMode==='single') renderSingle();
        else if(state.viewMode==='compare') renderCompare();
        else if(state.viewMode==='grid') renderGrid();
        renderPalette();
    });

    function updateFilterButtons() {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.filter===state.activeFilter));
    }

    // ===== SEVERITY SLIDER =====
    let rafSeverity = null;
    severitySlider.addEventListener('input', () => {
        state.severity = parseInt(severitySlider.value);
        severityValue.textContent = state.severity + '%';
        if(rafSeverity) cancelAnimationFrame(rafSeverity);
        rafSeverity = requestAnimationFrame(() => {
            if(state.viewMode==='single') renderSingle();
            else if(state.viewMode==='compare') renderCompare();
            else if(state.viewMode==='grid') renderGrid();
            renderPalette();
            rafSeverity = null;
        });
    });

    // ===== PIXEL PROCESSING ENGINE =====
    function getInterpolatedMatrix(filterName, severity) {
        const t = severity / 100;
        const target = MATRICES[filterName];
        return IDENTITY.map((v,i) => v + (target[i] - v) * t);
    }

    function applyMatrixToImageData(srcData, filterName, severity) {
        const w = srcData.width, h = srcData.height;
        const src = srcData.data;
        const out = new ImageData(w, h);
        const dst = out.data;
        if(filterName==='normal' || severity===0) { dst.set(src); return out; }
        const m = getInterpolatedMatrix(filterName, severity);
        for(let i=0; i<src.length; i+=4) {
            const r=src[i], g=src[i+1], b=src[i+2];
            dst[i]   = Math.min(255, Math.max(0, m[0]*r + m[1]*g + m[2]*b));
            dst[i+1] = Math.min(255, Math.max(0, m[3]*r + m[4]*g + m[5]*b));
            dst[i+2] = Math.min(255, Math.max(0, m[6]*r + m[7]*g + m[8]*b));
            dst[i+3] = src[i+3];
        }
        return out;
    }

    function applyColorMatrix(r, g, b, filterName, severity) {
        if(filterName==='normal' || severity===0) return {r,g,b};
        const m = getInterpolatedMatrix(filterName, severity);
        return {
            r: Math.min(255, Math.max(0, Math.round(m[0]*r + m[1]*g + m[2]*b))),
            g: Math.min(255, Math.max(0, Math.round(m[3]*r + m[4]*g + m[5]*b))),
            b: Math.min(255, Math.max(0, Math.round(m[6]*r + m[7]*g + m[8]*b)))
        };
    }

    // ===== RENDER FUNCTIONS =====
    function renderSingle() {
        const w = offscreenCanvas.width, h = offscreenCanvas.height;
        const orig = offscreenCtx.getImageData(0,0,w,h);
        const filtered = applyMatrixToImageData(orig, state.activeFilter, state.severity);
        previewCtx.putImageData(filtered, 0, 0);
    }

    function renderCompare() {
        const w = offscreenCanvas.width, h = offscreenCanvas.height;
        compareOriginalCanvas.width = w; compareOriginalCanvas.height = h;
        compareFilteredCanvas.width = w; compareFilteredCanvas.height = h;
        const origData = offscreenCtx.getImageData(0,0,w,h);
        const origCtx = compareOriginalCanvas.getContext('2d');
        origCtx.putImageData(origData, 0, 0);
        const filteredData = applyMatrixToImageData(origData, state.activeFilter, state.severity);
        const filtCtx = compareFilteredCanvas.getContext('2d');
        filtCtx.putImageData(filteredData, 0, 0);
        compareLabelRight.textContent = FILTER_LABELS[state.activeFilter] || 'Filtered';
    }

    async function renderGrid() {
        gridContainer.innerHTML = '';
        const origData = offscreenCtx.getImageData(0, 0, offscreenCanvas.width, offscreenCanvas.height);
        for(let i=0; i<FILTER_KEYS.length; i++) {
            const filter = FILTER_KEYS[i];
            const item = document.createElement('div');
            item.className = 'grid-item';
            item.style.animation = `gridItemIn .35s ease ${i*0.05}s both`;
            item.dataset.filter = filter;

            const canvas = document.createElement('canvas');
            canvas.width = offscreenCanvas.width;
            canvas.height = offscreenCanvas.height;
            const ctx = canvas.getContext('2d');

            const label = document.createElement('div');
            label.className = 'grid-item-label';
            const dot = document.createElement('span');
            dot.className = 'filter-dot';
            const dotColors = {normal:'#22c55e',protanopia:'#ef4444',deuteranopia:'#f97316',tritanopia:'#3b82f6',achromatopsia:'#6b7280',protanomaly:'#fb923c',deuteranomaly:'#fbbf24',tritanomaly:'#818cf8'};
            dot.style.background = dotColors[filter]||'#6b7280';
            label.appendChild(dot);
            label.appendChild(document.createTextNode(' ' + FILTER_LABELS[filter]));

            item.appendChild(canvas);
            item.appendChild(label);
            gridContainer.appendChild(item);

            // Render asynchronously to keep UI responsive
            await new Promise(resolve => {
                requestAnimationFrame(() => {
                    const filtered = applyMatrixToImageData(origData, filter, state.severity);
                    ctx.putImageData(filtered, 0, 0);
                    resolve();
                });
            });
        }

        // Click grid item to switch to single view with that filter
        gridContainer.querySelectorAll('.grid-item').forEach(item => {
            item.addEventListener('click', () => {
                state.activeFilter = item.dataset.filter;
                updateFilterButtons();
                updateSeverityVisibility();
                setViewMode('single');
                renderPalette();
            });
        });
    }

    // ===== COMPARE SLIDER =====
    let compareActive = false;
    function updateCompareSlider(clientX) {
        const rect = compareContainer.getBoundingClientRect();
        let x = (clientX - rect.left) / rect.width;
        x = Math.max(0.03, Math.min(0.97, x));
        const pct = x * 100;
        compareOverlay.style.clipPath = `inset(0 ${100-pct}% 0 0)`;
        compareHandle.style.left = pct + '%';
        compareLabelLeft.style.opacity = pct > 12 ? '1' : '0';
        compareLabelRight.style.opacity = pct < 88 ? '1' : '0';
    }
    compareHandle.addEventListener('mousedown', e => { e.preventDefault(); compareActive = true; });
    compareContainer.addEventListener('mousedown', e => { compareActive = true; updateCompareSlider(e.clientX); });
    document.addEventListener('mousemove', e => { if(compareActive) updateCompareSlider(e.clientX); });
    document.addEventListener('mouseup', () => compareActive = false);
    // Touch
    compareHandle.addEventListener('touchstart', e => { e.preventDefault(); compareActive = true; }, {passive:false});
    compareContainer.addEventListener('touchstart', e => { compareActive = true; updateCompareSlider(e.touches[0].clientX); });
    document.addEventListener('touchmove', e => { if(compareActive) updateCompareSlider(e.touches[0].clientX); });
    document.addEventListener('touchend', () => compareActive = false);

    // ===== ZOOM & PAN =====
    function setZoom(z) {
        state.zoom = Math.max(0.25, Math.min(5, z));
        canvasWrapper.style.transform = `scale(${state.zoom}) translate(${state.panX}px, ${state.panY}px)`;
        canvasWrapper.classList.toggle('zoomed', state.zoom > 1.01);
        zoomIndicator.textContent = Math.round(state.zoom*100) + '%';
        zoomIndicator.classList.add('visible');
        clearTimeout(zoomIndicator._hide);
        zoomIndicator._hide = setTimeout(() => zoomIndicator.classList.remove('visible'), 1500);
    }
    function resetZoom() {
        state.zoom = 1; state.panX = 0; state.panY = 0;
        canvasWrapper.style.transform = '';
        canvasWrapper.classList.remove('zoomed','panning');
    }
    singleView.addEventListener('wheel', e => {
        if(!state.imageLoaded || state.viewMode!=='single') return;
        e.preventDefault();
        const delta = e.deltaY > 0 ? 0.9 : 1.1;
        setZoom(state.zoom * delta);
    }, {passive:false});

    // Pan
    canvasWrapper.addEventListener('mousedown', e => {
        if(state.zoom <= 1.01 || state.eyedropper) return;
        state.isPanning = true;
        state.panStart = {x:e.clientX - state.panX*state.zoom, y:e.clientY - state.panY*state.zoom};
        canvasWrapper.classList.add('panning');
    });
    document.addEventListener('mousemove', e => {
        if(!state.isPanning) return;
        state.panX = (e.clientX - state.panStart.x) / state.zoom;
        state.panY = (e.clientY - state.panStart.y) / state.zoom;
        canvasWrapper.style.transform = `scale(${state.zoom}) translate(${state.panX}px, ${state.panY}px)`;
    });
    document.addEventListener('mouseup', () => { state.isPanning = false; canvasWrapper.classList.remove('panning'); });

    $('zoomInBtn').addEventListener('click', () => setZoom(state.zoom * 1.25));
    $('zoomOutBtn').addEventListener('click', () => setZoom(state.zoom * 0.8));
    $('zoomResetBtn').addEventListener('click', () => { resetZoom(); setZoom(1); });

    // ===== FULLSCREEN =====
    $('fullscreenBtn').addEventListener('click', () => {
        const el = state.viewMode==='compare' ? compareContainer : singleView;
        if(!document.fullscreenElement) {
            el.requestFullscreen?.() || el.webkitRequestFullscreen?.();
        } else {
            document.exitFullscreen?.() || document.webkitExitFullscreen?.();
        }
    });

    // ===== EYEDROPPER =====
    eyedropperBtn.addEventListener('click', () => {
        state.eyedropper = !state.eyedropper;
        eyedropperBtn.classList.toggle('active', state.eyedropper);
        singleView.classList.toggle('eyedropper-active', state.eyedropper);
        if(!state.eyedropper) eyedropperTooltip.classList.remove('visible');
    });

    previewCanvas.addEventListener('mousemove', e => {
        if(!state.eyedropper || !state.imageLoaded) return;
        const rect = previewCanvas.getBoundingClientRect();
        const px = Math.floor((e.clientX - rect.left) / rect.width * previewCanvas.width);
        const py = Math.floor((e.clientY - rect.top) / rect.height * previewCanvas.height);
        if(px<0||py<0||px>=previewCanvas.width||py>=previewCanvas.height) { eyedropperTooltip.classList.remove('visible'); return; }

        const origData = offscreenCtx.getImageData(px, py, 1, 1).data;
        const simColor = applyColorMatrix(origData[0], origData[1], origData[2], state.activeFilter, state.severity);
        const origHex = rgbToHex(origData[0], origData[1], origData[2]);
        const simHex = rgbToHex(simColor.r, simColor.g, simColor.b);

        $('edSwatchOrig').style.background = origHex;
        $('edSwatchSim').style.background = simHex;
        $('edInfo').innerHTML = `<strong>Position:</strong> ${px}, ${py}<br><strong>Original:</strong> ${origHex} · rgb(${origData[0]},${origData[1]},${origData[2]})<br><strong>Simulated:</strong> ${simHex} · rgb(${simColor.r},${simColor.g},${simColor.b})`;

        let tx = e.clientX + 18, ty = e.clientY + 18;
        if(tx + 220 > window.innerWidth) tx = e.clientX - 220;
        if(ty + 150 > window.innerHeight) ty = e.clientY - 150;
        eyedropperTooltip.style.left = tx + 'px';
        eyedropperTooltip.style.top = ty + 'px';
        eyedropperTooltip.classList.add('visible');
    });

    previewCanvas.addEventListener('mouseleave', () => eyedropperTooltip.classList.remove('visible'));

    previewCanvas.addEventListener('click', e => {
        if(!state.eyedropper || !state.imageLoaded) return;
        const rect = previewCanvas.getBoundingClientRect();
        const px = Math.floor((e.clientX - rect.left) / rect.width * previewCanvas.width);
        const py = Math.floor((e.clientY - rect.top) / rect.height * previewCanvas.height);
        if(px<0||py<0||px>=previewCanvas.width||py>=previewCanvas.height) return;
        const origData = offscreenCtx.getImageData(px, py, 1, 1).data;
        const hex = rgbToHex(origData[0], origData[1], origData[2]);
        navigator.clipboard?.writeText(hex).then(() => showToast(`Copied ${hex}`,'success')).catch(()=>{});
    });

    function rgbToHex(r,g,b) { return '#'+[r,g,b].map(c=>c.toString(16).padStart(2,'0')).join(''); }

    // ===== COLOR PALETTE EXTRACTION =====
    function extractPalette(count=8) {
        const w = offscreenCanvas.width, h = offscreenCanvas.height;
        const data = offscreenCtx.getImageData(0,0,w,h).data;
        const step = Math.max(1, Math.floor(data.length / 4 / 12000)) * 4;
        const buckets = {};
        for(let i=0; i<data.length; i+=step) {
            const r = Math.round(data[i]/32)*32;
            const g = Math.round(data[i+1]/32)*32;
            const b = Math.round(data[i+2]/32)*32;
            const key = `${r},${g},${b}`;
            if(!buckets[key]) buckets[key] = {r:0,g:0,b:0,n:0};
            buckets[key].r += data[i]; buckets[key].g += data[i+1]; buckets[key].b += data[i+2]; buckets[key].n++;
        }
        const sorted = Object.values(buckets).sort((a,b)=>b.n-a.n);
        const result = [];
        for(const c of sorted) {
            const avg = {r:Math.round(c.r/c.n), g:Math.round(c.g/c.n), b:Math.round(c.b/c.n)};
            const tooClose = result.some(e => colorDist(e,avg)<55);
            if(!tooClose) { result.push(avg); if(result.length>=count) break; }
        }
        return result;
    }

    function colorDist(a,b) { return Math.sqrt((a.r-b.r)**2+(a.g-b.g)**2+(a.b-b.b)**2); }

    function renderPalette() {
        const origRow = $('paletteOriginal');
        const simRow = $('paletteSimulated');
        origRow.innerHTML = ''; simRow.innerHTML = '';
        $('paletteSimLabel').textContent = FILTER_LABELS[state.activeFilter] || 'Simulated';
        state.dominantColors.forEach(c => {
            const hex = rgbToHex(c.r,c.g,c.b);
            const sw = document.createElement('div');
            sw.className = 'palette-swatch';
            sw.style.background = hex;
            sw.setAttribute('data-tooltip', hex);
            sw.addEventListener('click', () => { navigator.clipboard?.writeText(hex); showToast(`Copied ${hex}`,'success'); });
            origRow.appendChild(sw);

            const sim = applyColorMatrix(c.r,c.g,c.b, state.activeFilter, state.severity);
            const simHex = rgbToHex(sim.r,sim.g,sim.b);
            const sw2 = document.createElement('div');
            sw2.className = 'palette-swatch';
            sw2.style.background = simHex;
            sw2.setAttribute('data-tooltip', simHex);
            sw2.addEventListener('click', () => { navigator.clipboard?.writeText(simHex); showToast(`Copied ${simHex}`,'success'); });
            simRow.appendChild(sw2);
        });
    }

    // ===== ACCESSIBILITY REPORT =====
    function renderAccessibility() {
        const inner = $('accessibilityInner');
        const colors = state.dominantColors;
        if(colors.length < 2) { inner.innerHTML = '<p style="font-size:.82rem;color:var(--text-secondary)">Need more color variety to analyze.</p>'; return; }

        const cvdTypes = ['protanopia','deuteranopia','tritanopia','protanomaly','deuteranomaly','tritanomaly','achromatopsia'];
        let totalConfusable = 0;
        const details = [];

        for(const cvd of cvdTypes) {
            const simColors = colors.map(c => applyColorMatrix(c.r,c.g,c.b, cvd, 100));
            let confusable = 0;
            for(let i=0;i<colors.length;i++) {
                for(let j=i+1;j<colors.length;j++) {
                    const origDist = colorDist(colors[i], colors[j]);
                    const simDist = colorDist(simColors[i], simColors[j]);
                    if(origDist > 50 && simDist < 25) confusable++;
                }
            }
            totalConfusable += confusable;
            details.push({cvd, confusable, label:FILTER_LABELS[cvd]});
        }

        const maxPairs = cvdTypes.length * (colors.length*(colors.length-1)/2);
        const ratio = maxPairs > 0 ? totalConfusable / maxPairs : 0;
        const score = Math.max(1, Math.min(10, Math.round(10 - ratio * 30)));
        let rating, ratingClass;
        if(score >= 8) { rating='Excellent'; ratingClass='score-excellent'; }
        else if(score >= 6) { rating='Good'; ratingClass='score-good'; }
        else if(score >= 4) { rating='Fair'; ratingClass='score-fair'; }
        else { rating='Poor'; ratingClass='score-poor'; }

        const barColor = score>=8?'var(--green)':score>=6?'#eab308':score>=4?'#f97316':'var(--red)';

        let detailsHtml = '';
        details.forEach(d => {
            const icon = d.confusable===0 ? 'fa-circle-check' : 'fa-triangle-exclamation';
            const iconColor = d.confusable===0 ? 'var(--green)' : (d.confusable<=1?'#eab308':'var(--red)');
            const badgeColor = d.confusable===0 ? 'var(--green)' : (d.confusable<=1?'#eab308':'var(--red)');
            detailsHtml += `<div class="score-detail-item">
                <i class="fa-solid ${icon} score-detail-icon" style="color:${iconColor}"></i>
                <span>${d.label}</span>
                <span class="confusable-badge" style="background:${badgeColor}20;color:${badgeColor}">${d.confusable} issue${d.confusable!==1?'s':''}</span>
            </div>`;
        });

        inner.innerHTML = `
            <div class="score-header">
                <div class="score-big">${score}<span class="out-of">/10</span></div>
                <span class="score-rating ${ratingClass}">${rating}</span>
            </div>
            <div class="score-bar-wrap">
                <div class="score-bar"><div class="score-fill" style="width:${score*10}%;background:${barColor}"></div></div>
            </div>
            <div style="font-size:.75rem;color:var(--text-secondary);margin-bottom:12px;">
                ${totalConfusable===0 ? 'No confusable color pairs detected. Great color accessibility!' :
                `${totalConfusable} potentially confusable color pair${totalConfusable!==1?'s':''} detected across all CVD types.`}
            </div>
            <div class="score-details">${detailsHtml}</div>`;
    }

    // ===== PANEL TOGGLES =====
    $('paletteToggle').addEventListener('click', function() {
        this.classList.toggle('open');
        $('paletteContent').classList.toggle('open');
    });
    $('accessibilityToggle').addEventListener('click', function() {
        this.classList.toggle('open');
        $('accessibilityContent').classList.toggle('open');
    });

    // ===== DOWNLOAD =====
    downloadBtn.addEventListener('click', () => {
        if(!state.imageLoaded) return;
        const canvas = state.viewMode==='compare' ? compareFilteredCanvas : previewCanvas;
        const link = document.createElement('a');
        link.download = `${state.fileName}-${state.activeFilter}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
        showToast('Image downloaded!','success');
    });

    downloadAllBtn.addEventListener('click', async () => {
        if(!state.imageLoaded) return;
        showToast('Preparing downloads…','info');
        const origData = offscreenCtx.getImageData(0,0,offscreenCanvas.width,offscreenCanvas.height);
        for(let i=0; i<FILTER_KEYS.length; i++) {
            const f = FILTER_KEYS[i];
            await new Promise(r => setTimeout(r, 400));
            const tc = document.createElement('canvas');
            tc.width = offscreenCanvas.width; tc.height = offscreenCanvas.height;
            const tctx = tc.getContext('2d');
            tctx.putImageData(applyMatrixToImageData(origData, f, state.severity), 0, 0);
            const link = document.createElement('a');
            link.download = `${state.fileName}-${f}.png`;
            link.href = tc.toDataURL('image/png');
            link.click();
        }
        showToast(`All ${FILTER_KEYS.length} images downloaded!`,'success');
    });

    // ===== COPY =====
    copyBtn.addEventListener('click', async () => {
        if(!state.imageLoaded) return;
        try {
            const canvas = state.viewMode==='compare' ? compareFilteredCanvas : previewCanvas;
            const blob = await new Promise(r => canvas.toBlob(r));
            await navigator.clipboard.write([new ClipboardItem({'image/png':blob})]);
            showToast('Copied to clipboard!','success');
        } catch(err) {
            showToast('Copy failed. Try downloading instead.','error');
        }
    });

    // ===== START OVER =====
    startOverBtn.addEventListener('click', () => {
        fileInput.value = '';
        previewCtx.clearRect(0,0,previewCanvas.width,previewCanvas.height);
        offscreenCtx.clearRect(0,0,offscreenCanvas.width,offscreenCanvas.height);
        previewCanvas.width = 0; previewCanvas.height = 0;
        offscreenCanvas.width = 0; offscreenCanvas.height = 0;
        state.activeFilter = 'normal';
        state.dominantColors = [];
        resetZoom();
        showUpload();
    });

    // ===== SHORTCUTS MODAL =====
    $('shortcutsBtn').addEventListener('click', () => shortcutsModal.classList.add('active'));
    $('modalClose').addEventListener('click', () => shortcutsModal.classList.remove('active'));
    shortcutsModal.addEventListener('click', e => { if(e.target===shortcutsModal) shortcutsModal.classList.remove('active'); });

    // ===== KEYBOARD SHORTCUTS =====
    document.addEventListener('keydown', e => {
        // Don't trigger if typing in input
        if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA') return;
        if(shortcutsModal.classList.contains('active')) { if(e.key==='Escape') shortcutsModal.classList.remove('active'); return; }

        if(!state.imageLoaded) return;

        const key = e.key.toLowerCase();

        // Filter selection 1-8
        if(key>='1'&&key<='8'&&!e.ctrlKey&&!e.metaKey&&!e.altKey) {
            const idx = parseInt(key)-1;
            if(idx < FILTER_KEYS.length) {
                state.activeFilter = FILTER_KEYS[idx];
                updateFilterButtons();
                updateSeverityVisibility();
                if(state.viewMode==='single') renderSingle();
                else if(state.viewMode==='compare') renderCompare();
                renderPalette();
            }
            return;
        }

        // View modes
        if(key==='s'&&!e.ctrlKey) { setViewMode('single'); return; }
        if(key==='c'&&!e.ctrlKey&&!e.metaKey) { setViewMode('compare'); return; }
        if(key==='g'&&!e.ctrlKey) { setViewMode('grid'); return; }

        // Tools
        if(key==='e'&&!e.ctrlKey) { eyedropperBtn.click(); return; }
        if(key==='='||key==='+') { e.preventDefault(); setZoom(state.zoom*1.25); return; }
        if(key==='-') { e.preventDefault(); setZoom(state.zoom*0.8); return; }
        if(key==='0'&&!e.ctrlKey) { resetZoom(); setZoom(1); return; }
        if(key==='f'&&!e.ctrlKey) { $('fullscreenBtn').click(); return; }

        // Actions
        if(key==='d'&&!e.ctrlKey&&!e.metaKey&&!e.shiftKey) { downloadBtn.click(); return; }
        if(key==='d'&&e.shiftKey&&!e.ctrlKey) { downloadAllBtn.click(); return; }
        if(key==='?'||key==='/') { shortcutsModal.classList.add('active'); return; }
        if(key==='escape') { startOverBtn.click(); return; }
    });

    })();
    </script>
</body>
</html>

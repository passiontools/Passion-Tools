<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Color Blindness Simulator — PassionTools</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --red: #ef4444;
            --purple: #a855f7;
            --blue: #3b82f6;
            --blue-dark: #2563eb;
            --green: #22c55e;
            --bg-color: #f9fafb;
            --card-bg: #ffffff;
            --text-primary: #000000;
            --text-secondary: #6b7280;
            --border-color: #e5e7eb;
            --hover-gray: #f3f4f6;
            --btn-action-bg: #fef2f2;
            --error-bg: #fee2e2;
            --error-text: #991b1b;
            --footer-bg: #111827;
        }
        [data-theme="dark"] {
            --bg-color: #020617;
            --card-bg: #111827;
            --text-primary: #ffffff;
            --text-secondary: #94a3b8;
            --border-color: #1e293b;
            --hover-gray: #1e293b;
            --btn-action-bg: #450a0a;
            --error-bg: #7f1d1d;
            --error-text: #f87171;
            --footer-bg: #020617;
        }
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family:'Inter',sans-serif;
            background:var(--bg-color);
            color:var(--text-primary);
            min-height:100vh;
            display:flex;
            flex-direction:column;
            transition:background-color .3s ease,color .3s ease;
            -webkit-font-smoothing:antialiased;
        }
        /* HEADER */
        .header {
            position:sticky;top:0;z-index:1000;
            backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
            background:rgba(255,255,255,.75);
            border-bottom:1px solid var(--border-color);
            transition:all .3s ease;
        }
        [data-theme="dark"] .header { background:rgba(2,6,23,.75); }
        .header-inner { max-width:1200px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between; }
        .logo { text-decoration:none;font-size:1.35rem;font-weight:700;display:inline-flex;align-items:center;line-height:1;cursor:pointer; }
        .logo-passion { color:var(--text-primary);transition:color .3s ease; }
        .logo-tools { background:linear-gradient(135deg,var(--red),var(--purple));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent; }
        .header-actions { display:flex;align-items:center;gap:16px; }
        .back-link { text-decoration:none;color:var(--text-primary);font-size:.9rem;font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:color .3s ease; }
        .back-link:hover { color:var(--red); }
        .theme-toggle { background:none;border:none;cursor:pointer;font-size:1.25rem;line-height:1;padding:4px;display:flex;align-items:center;justify-content:center;transition:transform .3s ease; }
        .theme-toggle:hover { transform:scale(1.15); }

        /* MAIN */
        .main-content { flex:1;max-width:960px;width:100%;margin:0 auto;padding:48px 24px 64px; }
        .tool-header { text-align:center;margin-bottom:40px; }
        .tool-title { font-size:2rem;font-weight:800;color:var(--text-primary);margin-bottom:12px;letter-spacing:-.025em;transition:color .3s ease; }
        .tool-subtitle { font-size:1rem;color:var(--text-secondary);max-width:620px;margin:0 auto;line-height:1.65;font-weight:400;transition:color .3s ease; }

        /* CARD */
        .workspace-card { background:var(--card-bg);border:1px solid var(--border-color);border-radius:16px;overflow:hidden;transition:all .3s ease; }

        /* UPLOAD */
        .upload-area { padding:48px 32px;display:flex;flex-direction:column;align-items:center;justify-content:center; }
        .upload-area.hidden { display:none; }
        .drop-zone { width:100%;max-width:560px;border:2.5px dashed var(--border-color);border-radius:14px;padding:56px 32px;text-align:center;cursor:pointer;transition:all .3s ease;position:relative; }
        .drop-zone:hover,.drop-zone.drag-over { border-color:var(--blue);background:rgba(59,130,246,.04); }
        [data-theme="dark"] .drop-zone:hover,[data-theme="dark"] .drop-zone.drag-over { background:rgba(59,130,246,.08); }
        .drop-zone-icon { font-size:2.5rem;color:var(--blue);margin-bottom:16px; }
        .drop-zone-title { font-size:1.1rem;font-weight:600;color:var(--text-primary);margin-bottom:6px;transition:color .3s ease; }
        .drop-zone-subtitle { font-size:.875rem;color:var(--text-secondary);transition:color .3s ease; }
        .drop-zone-formats { margin-top:16px;font-size:.8rem;color:var(--text-secondary);font-weight:500;letter-spacing:.02em; }
        .drop-zone-paste { margin-top:10px;font-size:.75rem;color:var(--text-secondary);opacity:.7; }
        .file-input-hidden { display:none; }

        /* SIMULATOR */
        .simulator-area { display:none;flex-direction:column; }
        .simulator-area.active { display:flex; }

        /* TOOLBAR */
        .toolbar { padding:12px 20px;border-bottom:1px solid var(--border-color);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;transition:border-color .3s ease; }
        .view-modes { display:flex;background:var(--hover-gray);border-radius:10px;padding:3px;transition:background .3s ease; }
        .view-mode-btn {
            padding:7px 14px;border-radius:8px;border:none;background:none;cursor:pointer;
            font-family:'Inter',sans-serif;font-size:.78rem;font-weight:600;
            color:var(--text-secondary);transition:all .3s ease;white-space:nowrap;
            display:inline-flex;align-items:center;gap:5px;
        }
        .view-mode-btn.active { background:var(--card-bg);color:var(--text-primary);box-shadow:0 1px 4px rgba(0,0,0,.08); }
        [data-theme="dark"] .view-mode-btn.active { box-shadow:0 1px 4px rgba(0,0,0,.3); }
        .view-mode-btn:hover:not(.active) { color:var(--text-primary); }
        .tool-actions { display:flex;gap:4px;align-items:center; }
        .tool-btn {
            width:36px;height:36px;border-radius:9px;border:1.5px solid var(--border-color);
            background:var(--card-bg);color:var(--text-secondary);cursor:pointer;
            display:flex;align-items:center;justify-content:center;font-size:.85rem;
            transition:all .3s ease;position:relative;
        }
        .tool-btn:hover { border-color:var(--blue);color:var(--blue);background:rgba(59,130,246,.05); }
        .tool-btn.active { background:var(--blue);border-color:var(--blue);color:#fff; }
        .tool-btn[data-tooltip]:hover::after {
            content:attr(data-tooltip);position:absolute;bottom:-32px;left:50%;transform:translateX(-50%);
            background:rgba(0,0,0,.8);color:#fff;padding:4px 10px;border-radius:6px;
            font-size:.7rem;white-space:nowrap;z-index:99;pointer-events:none;
        }

        /* CONTROLS */
        .controls-panel { padding:14px 20px;border-bottom:1px solid var(--border-color);overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:thin;scrollbar-color:var(--border-color) transparent; }
        .controls-panel::-webkit-scrollbar { height:4px; }
        .controls-panel::-webkit-scrollbar-track { background:transparent; }
        .controls-panel::-webkit-scrollbar-thumb { background:var(--border-color);border-radius:4px; }
        .filter-buttons { display:flex;gap:7px;min-width:max-content; }
        .filter-btn {
            padding:8px 15px;border-radius:9px;border:1.5px solid var(--border-color);
            background:var(--card-bg);color:var(--text-secondary);
            font-family:'Inter',sans-serif;font-size:.78rem;font-weight:550;
            cursor:pointer;white-space:nowrap;transition:all .3s ease;
            display:inline-flex;align-items:center;gap:6px;
        }
        .filter-btn:hover { border-color:var(--blue);color:var(--blue);background:rgba(59,130,246,.05); }
        .filter-btn.active { background:var(--blue);border-color:var(--blue);color:#fff;box-shadow:0 2px 8px rgba(59,130,246,.3); }
        .filter-dot { width:8px;height:8px;border-radius:50%;flex-shrink:0; }

        /* SEVERITY */
        .severity-panel { padding:12px 20px;border-bottom:1px solid var(--border-color);display:flex;align-items:center;gap:14px;transition:all .3s ease; }
        .severity-panel.hidden { display:none; }
        .severity-label { font-size:.78rem;font-weight:600;color:var(--text-secondary);white-space:nowrap;min-width:60px; }
        .severity-slider-wrap { flex:1;display:flex;align-items:center;gap:12px; }
        .severity-slider {
            -webkit-appearance:none;appearance:none;flex:1;height:6px;border-radius:3px;
            background:var(--border-color);outline:none;cursor:pointer;transition:background .3s ease;
        }
        .severity-slider::-webkit-slider-thumb {
            -webkit-appearance:none;width:20px;height:20px;border-radius:50%;
            background:#fff;border:2.5px solid var(--blue);cursor:pointer;
            box-shadow:0 2px 6px rgba(0,0,0,.15);transition:transform .2s ease;
        }
        .severity-slider::-webkit-slider-thumb:hover { transform:scale(1.15); }
        .severity-slider::-moz-range-thumb {
            width:20px;height:20px;border-radius:50%;background:#fff;
            border:2.5px solid var(--blue);cursor:pointer;box-shadow:0 2px 6px rgba(0,0,0,.15);
        }
        .severity-value { font-size:.8rem;font-weight:700;color:var(--blue);min-width:38px;text-align:right; }

        /* IMAGE INFO */
        .image-info-bar { padding:8px 20px;border-bottom:1px solid var(--border-color);display:flex;align-items:center;gap:16px;font-size:.75rem;color:var(--text-secondary);flex-wrap:wrap;transition:all .3s ease; }
        .image-info-bar i { color:var(--blue); }
        .image-info-item { display:inline-flex;align-items:center;gap:5px; }
        .image-info-sep { width:1px;height:14px;background:var(--border-color); }

        /* PREVIEW */
        .preview-container { position:relative;background:var(--bg-color);transition:background .3s ease; }
        .preview-area { padding:24px;display:flex;align-items:center;justify-content:center;min-height:200px;overflow:hidden;position:relative; }
        .canvas-wrapper { position:relative;transition:transform .15s ease;transform-origin:center center;cursor:default; }
        .canvas-wrapper.zoomed { cursor:grab; }
        .canvas-wrapper.panning { cursor:grabbing; }
        .preview-canvas { max-width:100%;height:auto;max-height:600px;border-radius:10px;border:1px solid var(--border-color);display:block;transition:border-color .3s ease; }
        .preview-area.eyedropper-active { cursor:crosshair !important; }
        .preview-area.eyedropper-active .canvas-wrapper { cursor:crosshair !important; }

        /* ZOOM INDICATOR */
        .zoom-indicator {
            position:absolute;bottom:16px;right:16px;
            background:rgba(0,0,0,.65);color:#fff;padding:5px 12px;border-radius:8px;
            font-size:.72rem;font-weight:700;pointer-events:none;
            opacity:0;transition:opacity .3s ease;z-index:5;
            backdrop-filter:blur(4px);
        }
        .zoom-indicator.visible { opacity:1; }

        /* COMPARE VIEW */
        .compare-view { display:none;padding:24px;justify-content:center; }
        .compare-view.active { display:flex; }
        .compare-container {
            position:relative;max-width:100%;max-height:600px;overflow:hidden;
            border-radius:10px;border:1px solid var(--border-color);user-select:none;
        }
        .compare-canvas-base { max-width:100%;height:auto;max-height:600px;display:block; }
        .compare-overlay-wrap {
            position:absolute;top:0;left:0;right:0;bottom:0;
            clip-path:inset(0 0 0 50%);transition:none;
        }
        .compare-canvas-overlay { width:100%;height:100%;display:block;object-fit:contain; }
        .compare-handle {
            position:absolute;top:0;bottom:0;left:50%;z-index:10;
            transform:translateX(-50%);cursor:col-resize;width:36px;
            display:flex;align-items:center;justify-content:center;
        }
        .compare-handle-line { position:absolute;top:0;bottom:0;left:50%;width:3px;background:#fff;transform:translateX(-50%);box-shadow:0 0 8px rgba(0,0,0,.4); }
        .compare-handle-grip {
            width:36px;height:36px;border-radius:50%;background:#fff;
            box-shadow:0 2px 10px rgba(0,0,0,.25);display:flex;align-items:center;
            justify-content:center;z-index:11;font-size:.8rem;color:#333;
        }
        .compare-label {
            position:absolute;top:12px;padding:5px 14px;border-radius:8px;
            background:rgba(0,0,0,.55);color:#fff;font-size:.7rem;font-weight:700;
            z-index:5;backdrop-filter:blur(4px);pointer-events:none;
            transition:opacity .3s ease;letter-spacing:.02em;
        }
        .compare-label-left { left:12px; }
        .compare-label-right { right:12px; }

        /* GRID VIEW */
        .grid-view { display:none;padding:20px; }
        .grid-view.active { display:block; }
        .grid-container { display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px; }
        .grid-item {
            border-radius:10px;overflow:hidden;border:1px solid var(--border-color);
            background:var(--card-bg);cursor:pointer;transition:all .3s ease;
        }
        .grid-item:hover { border-color:var(--blue);transform:translateY(-2px);box-shadow:0 4px 16px rgba(59,130,246,.12); }
        .grid-item canvas { width:100%;height:auto;display:block; }
        .grid-item-label {
            padding:8px 12px;font-size:.72rem;font-weight:600;
            color:var(--text-secondary);border-top:1px solid var(--border-color);
            display:flex;align-items:center;gap:6px;transition:color .3s ease;
        }
        .grid-item-loading {
            aspect-ratio:16/10;display:flex;align-items:center;justify-content:center;
            color:var(--text-secondary);font-size:1.2rem;
        }

        /* EYEDROPPER TOOLTIP */
        .eyedropper-tooltip {
            position:fixed;z-index:9999;background:var(--card-bg);border:1px solid var(--border-color);
            border-radius:12px;padding:14px;box-shadow:0 8px 28px rgba(0,0,0,.18);
            pointer-events:none;display:none;min-width:200px;
            transition:background .3s ease,border-color .3s ease;
        }
        .eyedropper-tooltip.visible { display:block; }
        .eyedropper-colors { display:flex;gap:10px;margin-bottom:10px; }
        .eyedropper-swatch-group { text-align:center; }
        .eyedropper-swatch { width:44px;height:44px;border-radius:8px;border:2px solid var(--border-color);margin-bottom:4px; }
        .eyedropper-swatch-label { font-size:.6rem;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.04em; }
        .eyedropper-info { font-size:.72rem;color:var(--text-secondary);line-height:1.6; }
        .eyedropper-info strong { color:var(--text-primary);font-weight:600; }

        /* PALETTE PANEL */
        .panel-section { border-top:1px solid var(--border-color); }
        .panel-toggle {
            width:100%;padding:14px 20px;background:none;border:none;cursor:pointer;
            display:flex;align-items:center;justify-content:space-between;
            font-family:'Inter',sans-serif;font-size:.82rem;font-weight:600;
            color:var(--text-primary);transition:all .3s ease;
        }
        .panel-toggle:hover { background:var(--hover-gray); }
        .panel-toggle i { font-size:.7rem;color:var(--text-secondary);transition:transform .3s ease; }
        .panel-toggle.open i { transform:rotate(180deg); }
        .panel-content { max-height:0;overflow:hidden;transition:max-height .4s ease; }
        .panel-content.open { max-height:500px; }
        .panel-inner { padding:0 20px 18px; }

        .palette-section { margin-bottom:14px; }
        .palette-section:last-child { margin-bottom:0; }
        .palette-section-label { font-size:.7rem;font-weight:600;color:var(--text-secondary);margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em; }
        .palette-row { display:flex;gap:8px;flex-wrap:wrap; }
        .palette-swatch {
            width:42px;height:42px;border-radius:10px;border:2px solid var(--border-color);
            cursor:pointer;transition:all .2s ease;position:relative;
        }
        .palette-swatch:hover { transform:scale(1.12);box-shadow:0 4px 12px rgba(0,0,0,.15); }
        .palette-swatch[data-tooltip]:hover::after {
            content:attr(data-tooltip);position:absolute;bottom:-26px;left:50%;transform:translateX(-50%);
            background:rgba(0,0,0,.8);color:#fff;padding:3px 8px;border-radius:5px;
            font-size:.65rem;white-space:nowrap;z-index:99;
        }
        .palette-arrow { display:flex;align-items:center;justify-content:center;color:var(--text-secondary);font-size:.7rem;padding:0 4px; }

        /* ACCESSIBILITY PANEL */
        .accessibility-inner { padding:0 20px 18px; }
        .score-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:12px; }
        .score-big { font-size:2rem;font-weight:800;line-height:1; }
        .score-big .out-of { font-size:.9rem;font-weight:500;color:var(--text-secondary); }
        .score-rating {
            padding:5px 14px;border-radius:20px;font-size:.72rem;font-weight:700;
            text-transform:uppercase;letter-spacing:.04em;
        }
        .score-excellent { background:#dcfce7;color:#166534; }
        .score-good { background:#fef9c3;color:#854d0e; }
        .score-fair { background:#ffedd5;color:#9a3412; }
        .score-poor { background:#fee2e2;color:#991b1b; }
        [data-theme="dark"] .score-excellent { background:#14532d;color:#86efac; }
        [data-theme="dark"] .score-good { background:#713f12;color:#fde047; }
        [data-theme="dark"] .score-fair { background:#7c2d12;color:#fdba74; }
        [data-theme="dark"] .score-poor { background:#7f1d1d;color:#fca5a5; }
        .score-bar-wrap { margin-bottom:14px; }
        .score-bar { height:8px;border-radius:4px;background:var(--hover-gray);overflow:hidden; }
        .score-fill { height:100%;border-radius:4px;transition:width .8s ease,background .3s ease; }
        .score-details { display:flex;flex-direction:column;gap:6px; }
        .score-detail-item {
            display:flex;align-items:center;gap:8px;font-size:.75rem;color:var(--text-secondary);
            padding:6px 10px;border-radius:8px;background:var(--hover-gray);transition:background .3s ease;
        }
        .score-detail-icon { font-size:.7rem; }
        .confusable-badge { display:inline-block;padding:2px 8px;border-radius:10px;font-size:.65rem;font-weight:700;margin-left:auto; }

        /* ACTION BAR */
        .action-bar {
            padding:14px 20px;border-top:1px solid var(--border-color);
            display:flex;align-items:center;justify-content:center;gap:10px;
            flex-wrap:wrap;transition:border-color .3s ease;
        }
        .btn {
            font-family:'Inter',sans-serif;font-size:.82rem;font-weight:600;
            padding:10px 20px;border-radius:10px;cursor:pointer;
            display:inline-flex;align-items:center;gap:7px;
            transition:all .3s ease;border:none;text-decoration:none;
        }
        .btn-primary { background:var(--blue);color:#fff;box-shadow:0 2px 8px rgba(59,130,246,.25); }
        .btn-primary:hover { background:var(--blue-dark);box-shadow:0 4px 14px rgba(59,130,246,.35);transform:translateY(-1px); }
        .btn-secondary { background:var(--hover-gray);color:var(--text-primary);border:1.5px solid var(--border-color); }
        .btn-secondary:hover { border-color:var(--blue);color:var(--blue);transform:translateY(-1px); }
        .btn-ghost-red { background:var(--btn-action-bg);color:var(--red);border:1.5px solid transparent; }
        .btn-ghost-red:hover { border-color:var(--red);transform:translateY(-1px); }

        /* FOOTER */
        .footer { background:var(--footer-bg);text-align:center;padding:30px 20px;margin-top:auto; }
        .footer-text { font-size:14px;color:#94a3b8;font-weight:400; }

        /* TOAST */
        .toast-container { position:fixed;bottom:24px;right:24px;z-index:10001;display:flex;flex-direction:column-reverse;gap:8px; }
        .toast {
            padding:12px 20px;border-radius:10px;font-size:.82rem;font-weight:500;color:#fff;
            box-shadow:0 4px 16px rgba(0,0,0,.18);animation:toastIn .35s ease;
            display:flex;align-items:center;gap:8px;backdrop-filter:blur(8px);
        }
        .toast-info { background:rgba(59,130,246,.92); }
        .toast-success { background:rgba(34,197,94,.92); }
        .toast-error { background:rgba(239,68,68,.92); }
        .toast-exit { animation:toastOut .3s ease forwards; }

        /* SHORTCUTS MODAL */
        .modal-overlay {
            position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:10000;
            display:none;align-items:center;justify-content:center;
            backdrop-filter:blur(4px);animation:fadeIn .25s ease;
        }
        .modal-overlay.active { display:flex; }
        .modal-content {
            background:var(--card-bg);border:1px solid var(--border-color);
            border-radius:16px;padding:28px 32px;max-width:480px;width:92%;
            max-height:80vh;overflow-y:auto;animation:scaleIn .25s ease;
        }
        .modal-title { font-size:1.1rem;font-weight:700;margin-bottom:4px;color:var(--text-primary); }
        .modal-desc { font-size:.82rem;color:var(--text-secondary);margin-bottom:20px; }
        .modal-close {
            position:absolute;top:16px;right:16px;background:none;border:none;
            font-size:1.1rem;color:var(--text-secondary);cursor:pointer;transition:color .3s ease;
        }
        .modal-close:hover { color:var(--text-primary); }
        .shortcut-group-title { font-size:.72rem;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:.06em;margin:16px 0 8px; }
        .shortcut-row { display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border-color); }
        .shortcut-row:last-child { border-bottom:none; }
        .shortcut-desc { font-size:.8rem;color:var(--text-secondary); }
        .shortcut-key {
            display:inline-block;padding:3px 9px;background:var(--hover-gray);border:1px solid var(--border-color);
            border-radius:6px;font-family:'Inter',monospace;font-size:.72rem;font-weight:700;
            color:var(--text-primary);min-width:28px;text-align:center;
        }

        /* ANIMATIONS */
        .fade-in { animation:fadeIn .35s ease; }
        @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Password Manager Tools | PassionTools</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --red: #ef4444;
            --purple: #a855f7;
            --blue: #3b82f6;
            --blue-dark: #2563eb;
            --green: #22c55e;
            --yellow: #f59e0b;
            
            /* Light Mode */
            --bg-color: #f9fafb;
            --card-bg: #ffffff;
            --text-primary: #1f2937;
            --text-secondary: #6b7280;
            --border-color: #e5e7eb;
            --hover-gray: #f3f4f6;
            --btn-action-bg: #fef2f2;
            --header-bg: rgba(255, 255, 255, 0.8);
            --footer-bg: #111827;
            --footer-text: #94a3b8;
        }

        .dark-mode {
            --bg-color: #020617;
            --card-bg: #111827;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --border-color: #1e293b;
            --hover-gray: #1e293b;
            --btn-action-bg: #450a0a;
            --header-bg: rgba(2, 6, 23, 0.8);
            --footer-bg: #020617;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            transition: background-color 0.3s ease, color 0.3s ease;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .mono { font-family: 'Roboto Mono', monospace; }

        .glass-header {
            position: sticky;
            top: 0;
            z-index: 50;
            background: var(--header-bg);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
        }

        .logo-passion {
            color: #000000;
            font-weight: 800;
            transition: none;
        }
        
        .dark-mode .logo-passion {
            color: #ffffff;
        }
        
        .logo-tools {
            background: linear-gradient(to right, var(--red), var(--purple));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
        }

        .btn-red-hover:hover {
            color: var(--red) !important;
        }

        .nav-tab {
            transition: all 0.3s ease;
            border-bottom: 2px solid transparent;
        }
        .nav-tab.active {
            border-bottom-color: var(--red);
            color: var(--red);
        }

        .strength-bar {
            height: 8px;
            border-radius: 4px;
            background: var(--border-color);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .strength-fill {
            height: 100%;
            width: 0;
            transition: width 0.3s ease, background-color 0.3s ease;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        input[type="range"] {
            -webkit-appearance: none;
            appearance: none;
            background: transparent;
            cursor: pointer;
        }

        input[type="range"]::-webkit-slider-runnable-track {
            background: linear-gradient(to right, var(--red), var(--purple));
            height: 8px;
            border-radius: 4px;
        }

        input[type="range"]::-moz-range-track {
            background: linear-gradient(to right, var(--red), var(--purple));
            height: 8px;
            border-radius: 4px;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--card-bg);
            border: 3px solid var(--red);
            margin-top: -7px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
            transition: transform 0.2s ease;
        }

        input[type="range"]::-moz-range-thumb {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--card-bg);
            border: 3px solid var(--red);
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }

        input[type="range"]::-webkit-slider-thumb:hover {
            transform: scale(1.1);
        }

        input[type="range"]:focus {
            outline: none;
        }

        .copy-toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--text-primary);
            color: var(--bg-color);
            padding: 0.75rem 1.5rem;
            border-radius: 0.5rem;
            transform: translateY(150%);
            transition: transform 0.3s ease;
        }
        .copy-toast.show { transform: translateY(0); }

        footer {
            background: var(--footer-bg);
            color: var(--footer-text);
            padding: 30px 20px;
            text-align: center;
            font-size: 14px;
            margin-top: auto;
        }

        /* Checkbox Styling */
        .custom-checkbox {
            -webkit-appearance: none;
            appearance: none;
            width: 1.25rem;
            height: 1.25rem;
            min-width: 1.25rem;
            border: 2px solid var(--border-color);
            border-radius: 0.25rem;
            cursor: pointer;
            position: relative;
            background: var(--card-bg);
            transition: all 0.2s ease;
        }
        .custom-checkbox:hover {
            border-color: var(--red);
        }
        .custom-checkbox:checked {
            background: var(--red);
            border-color: var(--red);
        }
        .custom-checkbox:checked::after {
            content: "\f00c";
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            color: white;
            font-size: 0.75rem;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        .custom-checkbox:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2);
        }
    </style>
</head>
<body class="light-mode">

    <!-- Header -->
    <header class="glass-header">
        <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="#" onclick="event.preventDefault();" class="text-2xl tracking-tight flex items-center">
                <span class="logo-passion">Passion</span><span class="logo-tools">Tools</span>
            </a>
            <div class="flex items-center gap-6">
                <a href="index.html" class="text-sm font-medium btn-red-hover transition-colors flex items-center gap-2" style="color: var(--text-secondary);">
                    <i class="fa-solid fa-arrow-left"></i> Back to Tools
                </a>
                <button id="themeToggle" class="text-xl cursor-pointer hover:scale-110 transition-transform">
                    ☀️
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-4 py-12 flex-grow w-full">
        <!-- Tool Header -->
        <div class="text-center mb-10">
            <h1 class="text-3xl font-extrabold mb-3">Password Manager Tools</h1>
            <p style="color: var(--text-secondary);">Generate unbreakable passwords or test the strength of your current ones. 100% private client-side processing.</p>
        </div>

        <!-- Tabs -->
        <div class="flex border-b border-[var(--border-color)] mb-8">
            <button onclick="switchTab('generator')" id="tab-generator" class="nav-tab active flex-1 py-4 font-semibold text-center cursor-pointer">
                <i class="fa-solid fa-wand-magic-sparkles mr-2"></i> Generator
            </button>
            <button onclick="switchTab('checker')" id="tab-checker" class="nav-tab flex-1 py-4 font-semibold text-center cursor-pointer" style="color: var(--text-secondary);">
                <i class="fa-solid fa-shield-halved mr-2"></i> Strength Checker
            </button>
        </div>

        <!-- Generator View -->
        <div id="view-generator" class="space-y-6">
            <div class="card p-6 md:p-8">
                <div class="relative group">
                    <div id="passwordDisplay" class="mono text-xl md:text-3xl p-6 bg-[var(--hover-gray)] rounded-xl break-all text-center min-h-[5rem] flex items-center justify-center border border-[var(--border-color)]">
                        ••••••••••••••••
                    </div>
                    <button onclick="copyToClipboard('passwordDisplay')" class="absolute right-4 top-1/2 -translate-y-1/2 p-3 text-[var(--text-secondary)] hover:text-[var(--red)] transition-colors" title="Copy to clipboard">
                        <i class="fa-regular fa-copy text-xl"></i>
                    </button>
                </div>

                <div class="mt-8 grid md:grid-cols-2 gap-8">
                    <div class="space-y-6">
                        <div>
                            <div class="flex justify-between mb-4">
                                <label class="font-semibold">Password Length</label>
                                <span id="lengthVal" class="mono font-bold text-[var(--red)]">16</span>
                            </div>
                            <input type="range" id="lengthSlider" min="8" max="128" value="16" class="w-full h-2 bg-[var(--border-color)] rounded-lg appearance-none cursor-pointer">
                        </div>
                        
                        <button onclick="generatePassword()" class="w-full py-4 bg-[var(--blue)] hover:bg-[var(--blue-dark)] text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-500/20 active:scale-95">
                            <i class="fa-solid fa-rotate mr-2"></i> Generate New Password
                        </button>
                    </div>

                    <div class="grid grid-cols-1 gap-4">
                        <label class="flex items-center gap-3 cursor-pointer p-3 rounded-lg hover:bg-[var(--hover-gray)] transition-colors">
                            <input type="checkbox" id="includeUpper" checked class="custom-checkbox">
                            <span class="text-sm font-medium">Uppercase (A-Z)</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer p-3 rounded-lg hover:bg-[var(--hover-gray)] transition-colors">
                            <input type="checkbox" id="includeLower" checked class="custom-checkbox">
                            <span class="text-sm font-medium">Lowercase (a-z)</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer p-3 rounded-lg hover:bg-[var(--hover-gray)] transition-colors">
                            <input type="checkbox" id="includeNumbers" checked class="custom-checkbox">
                            <span class="text-sm font-medium">Numbers (0-9)</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer p-3 rounded-lg hover:bg-[var(--hover-gray)] transition-colors">
                            <input type="checkbox" id="includeSymbols" checked class="custom-checkbox">
                            <span class="text-sm font-medium">Symbols (!@#$...)</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Checker View -->
        <div id="view-checker" class="hidden space-y-6">
            <div class="card p-6 md:p-8">
                <div class="relative">
                    <input type="password" id="checkInput" placeholder="Type a password to test..." class="w-full p-5 pr-14 rounded-xl border border-[var(--border-color)] bg-[var(--hover-gray)] focus:ring-2 focus:ring-[var(--red)] outline-none mono text-lg transition-all">
                    <button onclick="toggleVisibility('checkInput', this)" class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--text-secondary)] hover:text-[var(--red)] p-2">
                        <i class="fa-regular fa-eye text-xl"></i>
                    </button>
                </div>

                <div class="mt-8 space-y-4">
                    <div class="flex justify-between items-end">
                        <span class="text-sm font-bold uppercase tracking-wider text-[var(--text-secondary)]">Strength Score</span>
                        <span id="strengthText" class="font-bold text-lg">Empty</span>
                    </div>
                    <div class="strength-bar">
                        <div id="strengthFill" class="strength-fill"></div>
                    </div>
                </div>

                <div class="mt-10 grid md:grid-cols-2 gap-4" id="checklist">
                    <div data-check="length" class="flex items-center gap-3 transition-colors" style="color: var(--text-secondary);">
                        <i class="fa-solid fa-circle-check"></i>
                        <span class="text-sm">At least 12 characters</span>
                    </div>
                    <div data-check="upper" class="flex items-center gap-3 transition-colors" style="color: var(--text-secondary);">
                        <i class="fa-solid fa-circle-check"></i>
                        <span class="text-sm">Uppercase letters</span>
                    </div>
                    <div data-check="lower" class="flex items-center gap-3 transition-colors" style="color: var(--text-secondary);">
                        <i class="fa-solid fa-circle-check"></i>
                        <span class="text-sm">Lowercase letters</span>
                    </div>
                    <div data-check="number" class="flex items-center gap-3 transition-colors" style="color: var(--text-secondary);">
                        <i class="fa-solid fa-circle-check"></i>
                        <span class="text-sm">Contains numbers</span>
                    </div>
                    <div data-check="symbol" class="flex items-center gap-3 transition-colors" style="color: var(--text-secondary);">
                        <i class="fa-solid fa-circle-check"></i>
                        <span class="text-sm">Contains symbols</span>
                    </div>
                    <div data-check="noCommon" class="flex items-center gap-3 transition-colors" style="color: var(--text-secondary);">
                        <i class="fa-solid fa-circle-check"></i>
                        <span class="text-sm">No common patterns</span>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div id="toast" class="copy-toast">Password copied to clipboard!</div>

    <footer>
        © 2026 Passion Tools. Secure client-side processing.
    </footer>

    <script>
        // State Management
        let currentTab = 'generator';
        const body = document.body;
        const themeToggle = document.getElementById('themeToggle');

        // Theme Toggle Logic
        function initTheme() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                body.classList.add('dark-mode');
                themeToggle.innerText = '🌙';
            }
        }

        themeToggle.addEventListener('click', () => {
            body.classList.toggle('dark-mode');
            const isDark = body.classList.contains('dark-mode');
            themeToggle.innerText = isDark ? '🌙' : '☀️';
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });

        // Tab Switching
        function switchTab(tab) {
            currentTab = tab;
            document.querySelectorAll('.nav-tab').forEach(el => {
                el.classList.remove('active');
                el.style.color = 'var(--text-secondary)';
            });
            document.getElementById(`tab-${tab}`).classList.add('active');
            document.getElementById(`tab-${tab}`).style.color = 'var(--red)';

            document.getElementById('view-generator').classList.toggle('hidden', tab !== 'generator');
            document.getElementById('view-checker').classList.toggle('hidden', tab !== 'checker');
        }

        // Secure Generator Logic
        const charSets = {
            upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
            lower: 'abcdefghijklmnopqrstuvwxyz',
            numbers: '0123456789',
            symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?'
        };

        function generatePassword() {
            const length = parseInt(document.getElementById('lengthSlider').value);
            const useUpper = document.getElementById('includeUpper').checked;
            const useLower = document.getElementById('includeLower').checked;
            const useNumbers = document.getElementById('includeNumbers').checked;
            const useSymbols = document.getElementById('includeSymbols').checked;

            let pool = '';
            if (useUpper) pool += charSets.upper;
            if (useLower) pool += charSets.lower;
            if (useNumbers) pool += charSets.numbers;
            if (useSymbols) pool += charSets.symbols;

            if (pool === '') {
                document.getElementById('passwordDisplay').innerText = 'Select at least one option';
                return;
            }

            let password = '';
            const randomValues = new Uint32Array(length);
            window.crypto.getRandomValues(randomValues);

            for (let i = 0; i < length; i++) {
                password += pool[randomValues[i] % pool.length];
            }

            document.getElementById('passwordDisplay').innerText = password;
        }

        // Strength Checker Logic
        function analyzePassword(pwd) {
            let score = 0;
            
            // Common patterns to check against
            const commonPatterns = [
                /^123456/, /password/i, /qwerty/i, /abc123/i,
                /letmein/i, /welcome/i, /admin/i, /login/i,
                /(.)\1{3,}/, // 4+ repeated characters
                /^[a-z]+$/i, // only letters
                /^[0-9]+$/ // only numbers
            ];
            
            const hasCommonPattern = pwd.length > 0 && commonPatterns.some(pattern => pattern.test(pwd));
            
            const checks = {
                length: pwd.length >= 12,
                upper: /[A-Z]/.test(pwd),
                lower: /[a-z]/.test(pwd),
                number: /[0-9]/.test(pwd),
                symbol: /[^A-Za-z0-9]/.test(pwd),
                noCommon: pwd.length > 0 && !hasCommonPattern
            };

            // Calculate base score from checks
            if (checks.length) score += 15;
            if (checks.upper) score += 12;
            if (checks.lower) score += 12;
            if (checks.number) score += 12;
            if (checks.symbol) score += 15;
            if (checks.noCommon) score += 14;

            // Bonus points for length
            if (pwd.length >= 8) score += 5;
            if (pwd.length >= 16) score += 10;
            if (pwd.length >= 24) score += 5;

            // Cap at 100
            score = Math.min(score, 100);

            // Update UI Checklist
            Object.keys(checks).forEach(key => {
                const el = document.querySelector(`[data-check="${key}"]`);
                if (el) {
                    if (pwd.length === 0) {
                        el.style.color = 'var(--text-secondary)';
                    } else if (checks[key]) {
                        el.style.color = 'var(--green)';
                    } else {
                        el.style.color = 'var(--text-secondary)';
                    }
                }
            });

            // Update Bar and Text
            const fill = document.getElementById('strengthFill');
            const text = document.getElementById('strengthText');
            
            fill.style.width = score + '%';
            
            if (pwd.length === 0) {
                text.innerText = 'Empty';
                text.style.color = 'var(--text-secondary)';
                fill.style.background = 'var(--border-color)';
            } else if (score <= 20) {
                text.innerText = 'Very Weak';
                text.style.color = 'var(--red)';
                fill.style.background = 'var(--red)';
            } else if (score <= 40) {
                text.innerText = 'Weak';
                text.style.color = 'var(--red)';
                fill.style.background = 'var(--red)';
            } else if (score <= 60) {
                text.innerText = 'Fair';
                text.style.color = 'var(--yellow)';
                fill.style.background = 'var(--yellow)';
            } else if (score <= 80) {
                text.innerText = 'Good';
                text.style.color = 'var(--yellow)';
                fill.style.background = 'var(--yellow)';
            } else {
                text.innerText = 'Strong';
                text.style.color = 'var(--green)';
                fill.style.background = 'var(--green)';
            }
        }

        // Helpers
        function copyToClipboard(elementId) {
            const text = document.getElementById(elementId).innerText;
            if (text === '••••••••••••••••' || text === 'Select at least one option') return;
            
            navigator.clipboard.writeText(text).then(() => {
                const toast = document.getElementById('toast');
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 2000);
            });
        }

        function toggleVisibility(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        // Event Listeners
        document.getElementById('lengthSlider').addEventListener('input', (e) => {
            document.getElementById('lengthVal').innerText = e.target.value;
            generatePassword();
        });

        document.querySelectorAll('#view-generator input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', generatePassword);
        });

        document.getElementById('checkInput').addEventListener('input', (e) => {
            analyzePassword(e.target.value);
        });

        // Initial Load
        initTheme();
        generatePassword();
    </script>
</body>
</html>

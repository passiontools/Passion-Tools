                    <!-- Radial Shape -->
                    <div class="control-group radial-control" id="radialControl">
                        <label class="control-label">Shape</label>
                        <div class="type-toggle">
                            <button class="type-btn active" data-shape="circle" id="btnCircle">Circle</button>
                            <button class="type-btn" data-shape="ellipse" id="btnEllipse">Ellipse</button>
                        </div>
                        <label class="control-label" style="margin-top:14px;">Position</label>
                        <div class="radial-position-grid" id="radialPositionGrid"></div>
                    </div>

                    <!-- Color Stops -->
                    <div class="control-group">
                        <label class="control-label">Color Stops <span class="badge">ALPHA</span></label>
                        <div class="gradient-bar-container">
                            <div class="gradient-bar" id="gradientBar"></div>
                        </div>
                        <div class="color-stops-list" id="colorStopsList"></div>
                        <button class="add-color-btn" id="addColorBtn">
                            <i class="fas fa-plus"></i> Add Color Stop
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right Column: Preview & Export -->
            <div>
                <div class="card">
                    <h2 class="card-title"><i class="fas fa-eye"></i> Live Preview</h2>

                    <div class="preview-box-wrapper">
                        <div class="preview-box" id="previewBox"></div>
                        <div class="preview-overlay-btns">
                            <button class="preview-mini-btn" id="previewAnimBtn" title="Toggle Animation"><i class="fas fa-play"></i></button>
                            <button class="preview-mini-btn" id="previewFullBtn" title="Fullscreen"><i class="fas fa-expand"></i></button>
                        </div>
                        <div class="preview-size-label" id="previewSizeLabel">100% × 260px</div>
                    </div>

                    <!-- Output Format -->
                    <div class="output-header">
                        <span class="control-label" style="margin:0;">CSS Output</span>
                        <div class="output-format-toggle">
                            <button class="format-btn active" data-format="hex" id="fmtHex">HEX</button>
                            <button class="format-btn" data-format="rgb" id="fmtRgb">RGB</button>
                            <button class="format-btn" data-format="hsl" id="fmtHsl">HSL</button>

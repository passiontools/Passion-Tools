        <div class="fullscreen-info" id="fullscreenInfo"></div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast"><i class="fas fa-check-circle"></i> <span id="toastText">Copied!</span></div>

    <!-- Footer -->
    <footer class="footer">
        <p class="footer-text">&copy; 2026 Passion Tools. Secure client-side processing.</p>
    </footer>

    <script>
        // ===== THEME =====
        const themeToggle = document.getElementById('themeToggle');
        const htmlEl = document.documentElement;

        function setTheme(theme) {
            htmlEl.setAttribute('data-theme', theme);
            themeToggle.textContent = theme === 'dark' ? '🌙' : '☀️';
            localStorage.setItem('pt-theme', theme);
        }

        (function initTheme() {
            const saved = localStorage.getItem('pt-theme');
            if (saved) setTheme(saved);
            else if (window.matchMedia('(prefers-color-scheme: dark)').matches) setTheme('dark');
        })();

        themeToggle.addEventListener('click', () => {
            setTheme(htmlEl.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
        });

        // ===== PRESETS =====
        const PRESETS = [
            { name: 'Sunset', stops: [{ color: '#f97316', position: 0, opacity: 1 },{ color: '#ef4444', position: 50, opacity: 1 },{ color: '#ec4899', position: 100, opacity: 1 }], type: 'linear', angle: 135 },
            { name: 'Ocean', stops: [{ color: '#06b6d4', position: 0, opacity: 1 },{ color: '#3b82f6', position: 50, opacity: 1 },{ color: '#6366f1', position: 100, opacity: 1 }], type: 'linear', angle: 135 },
            { name: 'Forest', stops: [{ color: '#22c55e', position: 0, opacity: 1 },{ color: '#16a34a', position: 50, opacity: 1 },{ color: '#15803d', position: 100, opacity: 1 }], type: 'linear', angle: 180 },
            { name: 'Lavender', stops: [{ color: '#c084fc', position: 0, opacity: 1 },{ color: '#a855f7', position: 50, opacity: 1 },{ color: '#7c3aed', position: 100, opacity: 1 }], type: 'linear', angle: 135 },
            { name: 'Fire', stops: [{ color: '#fbbf24', position: 0, opacity: 1 },{ color: '#f97316', position: 40, opacity: 1 },{ color: '#ef4444', position: 100, opacity: 1 }], type: 'linear', angle: 45 },
            { name: 'Midnight', stops: [{ color: '#1e293b', position: 0, opacity: 1 },{ color: '#312e81', position: 50, opacity: 1 },{ color: '#0f172a', position: 100, opacity: 1 }], type: 'linear', angle: 135 },
            { name: 'Cotton Candy', stops: [{ color: '#f9a8d4', position: 0, opacity: 1 },{ color: '#c4b5fd', position: 50, opacity: 1 },{ color: '#93c5fd', position: 100, opacity: 1 }], type: 'linear', angle: 120 },
            { name: 'Aurora', stops: [{ color: '#06b6d4', position: 0, opacity: 1 },{ color: '#22c55e', position: 33, opacity: 1 },{ color: '#a855f7', position: 66, opacity: 1 },{ color: '#ec4899', position: 100, opacity: 1 }], type: 'linear', angle: 135 },
            { name: 'Peach', stops: [{ color: '#fecaca', position: 0, opacity: 1 },{ color: '#fdba74', position: 100, opacity: 1 }], type: 'linear', angle: 135 },
            { name: 'Neon', stops: [{ color: '#00ff87', position: 0, opacity: 1 },{ color: '#60efff', position: 100, opacity: 1 }], type: 'linear', angle: 90 },
            { name: 'Cosmic', stops: [{ color: '#667eea', position: 0, opacity: 1 },{ color: '#764ba2', position: 100, opacity: 1 }], type: 'linear', angle: 135 },
            { name: 'Solar', stops: [{ color: '#f093fb', position: 0, opacity: 1 },{ color: '#f5576c', position: 50, opacity: 1 },{ color: '#ffd200', position: 100, opacity: 1 }], type: 'linear', angle: 45 },
            { name: 'Ice', stops: [{ color: '#e0f2fe', position: 0, opacity: 1 },{ color: '#bae6fd', position: 40, opacity: 1 },{ color: '#38bdf8', position: 100, opacity: 1 }], type: 'radial', angle: 0, shape: 'circle' },
            { name: 'Gold', stops: [{ color: '#fef3c7', position: 0, opacity: 1 },{ color: '#fbbf24', position: 50, opacity: 1 },{ color: '#d97706', position: 100, opacity: 1 }], type: 'linear', angle: 135 },
            { name: 'Emerald Ring', stops: [{ color: '#6ee7b7', position: 0, opacity: 1 },{ color: '#059669', position: 50, opacity: 1 },{ color: '#064e3b', position: 100, opacity: 1 }], type: 'conic', angle: 0 },
            { name: 'Rainbow', stops: [{ color: '#ef4444', position: 0, opacity: 1 },{ color: '#f97316', position: 17, opacity: 1 },{ color: '#eab308', position: 33, opacity: 1 },{ color: '#22c55e', position: 50, opacity: 1 },{ color: '#3b82f6', position: 67, opacity: 1 },{ color: '#a855f7', position: 83, opacity: 1 },{ color: '#ec4899', position: 100, opacity: 1 }], type: 'conic', angle: 0 },
        ];

        const DIRECTIONS = [
            { label: '→', angle: 90 },
            { label: '↗', angle: 45 },
            { label: '↑', angle: 0 },
            { label: '↖', angle: 315 },
            { label: '←', angle: 270 },
            { label: '↙', angle: 225 },
            { label: '↓', angle: 180 },
            { label: '↘', angle: 135 },
        ];

        const RADIAL_POSITIONS = [
            { label: 'Top Left', value: 'at top left' },
            { label: 'Top', value: 'at top' },
            { label: 'Top Right', value: 'at top right' },
            { label: 'Left', value: 'at left' },
            { label: 'Center', value: 'at center' },
            { label: 'Right', value: 'at right' },
            { label: 'Bottom Left', value: 'at bottom left' },
            { label: 'Bottom', value: 'at bottom' },
            { label: 'Bottom Right', value: 'at bottom right' },
        ];

        // ===== STATE =====
        const DEFAULT_STOPS = [
            { color: '#ef4444', position: 0, opacity: 1 },
            { color: '#a855f7', position: 100, opacity: 1 }
        ];

        let state = {
            type: 'linear',
            angle: 90,
            shape: 'circle',
            radialPosition: 'at center',
            repeating: false,
            animated: false,
            colorFormat: 'hex',
            stops: JSON.parse(JSON.stringify(DEFAULT_STOPS)),
            activeStopIndex: 0
        };

        let history = JSON.parse(localStorage.getItem('pt-gradient-history') || '[]');

        const RANDOM_COLORS = ['#f59e0b','#22c55e','#3b82f6','#ec4899','#06b6d4','#8b5cf6','#f97316','#14b8a6','#e11d48','#84cc16'];

        // ===== DOM =====
        const btnLinear = document.getElementById('btnLinear');
        const btnRadial = document.getElementById('btnRadial');
        const btnConic = document.getElementById('btnConic');
        const angleControl = document.getElementById('angleControl');
        const radialControl = document.getElementById('radialControl');
        const angleSlider = document.getElementById('angleSlider');
        const angleValueEl = document.getElementById('angleValue');
        const angleWheel = document.getElementById('angleWheel');
        const angleWheelPointer = document.getElementById('angleWheelPointer');
        const angleWheelDot = document.getElementById('angleWheelDot');
        const colorStopsList = document.getElementById('colorStopsList');
        const addColorBtn = document.getElementById('addColorBtn');
        const previewBox = document.getElementById('previewBox');
        const cssOutput = document.getElementById('cssOutput');
        const copyBtn = document.getElementById('copyBtn');
        const resetBtn = document.getElementById('resetBtn');
        const btnCircle = document.getElementById('btnCircle');
        const btnEllipse = document.getElementById('btnEllipse');
        const gradientBar = document.getElementById('gradientBar');
        const presetsGrid = document.getElementById('presetsGrid');
        const historyGrid = document.getElementById('historyGrid');
        const fullscreenOverlay = document.getElementById('fullscreenOverlay');
        const fullscreenGradient = document.getElementById('fullscreenGradient');
        const fullscreenClose = document.getElementById('fullscreenClose');
        const fullscreenInfo = document.getElementById('fullscreenInfo');
        const toast = document.getElementById('toast');
        const toastText = document.getElementById('toastText');
        const directionPresets = document.getElementById('directionPresets');
        const radialPositionGrid = document.getElementById('radialPositionGrid');

        // ===== TOAST =====
        let toastTimer;
        function showToast(msg) {
            toastText.textContent = msg;
            toast.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => toast.classList.remove('show'), 2200);
        }

        // ===== RENDER PRESETS =====
        function renderPresets() {
            presetsGrid.innerHTML = '';
            PRESETS.forEach((p, i) => {
                const div = document.createElement('div');
                div.className = 'preset-swatch';
                div.title = p.name;
                const colorStr = p.stops.map(s => `${s.color} ${s.position}%`).join(', ');
                if (p.type === 'linear') {
                    div.style.background = `linear-gradient(${p.angle || 135}deg, ${colorStr})`;
                } else if (p.type === 'radial') {
                    div.style.background = `radial-gradient(${p.shape || 'circle'}, ${colorStr})`;
                } else {
                    div.style.background = `conic-gradient(from ${p.angle || 0}deg, ${colorStr})`;
                }
                div.addEventListener('click', () => applyPreset(p));
                presetsGrid.appendChild(div);
            });
        }

        function applyPreset(p) {
            state.type = p.type || 'linear';
            state.angle = p.angle || 90;
            state.shape = p.shape || 'circle';
            state.radialPosition = 'at center';
            state.stops = JSON.parse(JSON.stringify(p.stops));
            state.stops.forEach(s => { if (s.opacity === undefined) s.opacity = 1; });
            state.activeStopIndex = 0;
            syncTypeButtons();
            syncAngleUI();
            renderColorStops();
            updateGradient();
        }

        // ===== RENDER DIRECTION PRESETS =====
        function renderDirectionPresets() {
            directionPresets.innerHTML = '';
            DIRECTIONS.forEach(d => {
                const btn = document.createElement('button');
                btn.className = 'dir-btn' + (state.angle === d.angle ? ' active' : '');
                btn.textContent = d.label;
                btn.title = d.angle + '°';
                btn.addEventListener('click', () => {
                    state.angle = d.angle;
                    syncAngleUI();
                    updateGradient();
                });
                directionPresets.appendChild(btn);
            });
        }

        // ===== RENDER RADIAL POSITIONS =====
        function renderRadialPositions() {
            radialPositionGrid.innerHTML = '';
            RADIAL_POSITIONS.forEach(p => {
                const btn = document.createElement('button');
                btn.className = 'radial-pos-btn' + (state.radialPosition === p.value ? ' active' : '');
                btn.textContent = p.label;
                btn.addEventListener('click', () => {
                    state.radialPosition = p.value;
                    renderRadialPositions();
                    updateGradient();
                });
                radialPositionGrid.appendChild(btn);
            });

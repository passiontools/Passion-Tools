        // ===== ADD COLOR =====
        addColorBtn.addEventListener('click', () => {
            if (state.stops.length >= 8) return;
            const ci = (state.stops.length - 2) % RANDOM_COLORS.length;
            state.stops.push({ color: RANDOM_COLORS[ci], position: 100, opacity: 1 });
            const total = state.stops.length;
            state.stops.forEach((s, i) => { s.position = Math.round((i / (total - 1)) * 100); });
            state.activeStopIndex = state.stops.length - 1;
            renderColorStops();
            renderGradientBar();
            updateGradient();
        });

        // ===== COLOR UTILS =====
        function hexToRgb(hex) {
            const r = parseInt(hex.slice(1, 3), 16);
            const g = parseInt(hex.slice(3, 5), 16);
            const b = parseInt(hex.slice(5, 7), 16);
            return { r, g, b };
        }

        function rgbToHsl(r, g, b) {
            r /= 255; g /= 255; b /= 255;
            const max = Math.max(r, g, b), min = Math.min(r, g, b);
            let h, s, l = (max + min) / 2;
            if (max === min) { h = s = 0; }
            else {
                const d = max - min;
                s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
                switch (max) {
                    case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
                    case g: h = ((b - r) / d + 2) / 6; break;
                    case b: h = ((r - g) / d + 4) / 6; break;
                }
            }
            return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
        }

        function formatColor(hex, format, opacity) {
            const { r, g, b } = hexToRgb(hex);
            const alpha = opacity !== undefined ? opacity : 1;
            if (format === 'rgb') {
                return alpha < 1 ? `rgba(${r}, ${g}, ${b}, ${alpha.toFixed(2)})` : `rgb(${r}, ${g}, ${b})`;
            } else if (format === 'hsl') {
                const { h, s, l } = rgbToHsl(r, g, b);
                return alpha < 1 ? `hsla(${h}, ${s}%, ${l}%, ${alpha.toFixed(2)})` : `hsl(${h}, ${s}%, ${l}%)`;
            } else {
                if (alpha < 1) {
                    const a = Math.round(alpha * 255).toString(16).padStart(2, '0');
                    return hex + a;
                }
                return hex;
            }
        }

        function formatColorWithOpacity(stop) {
            return formatColor(stop.color, 'rgb', stop.opacity);
        }

        function formatColorForCSS(stop, fmt) {
            return formatColor(stop.color, fmt, stop.opacity);
        }

        // ===== GRADIENT ENGINE =====
        function buildGradientString(forCSS) {
            const fmt = forCSS ? state.colorFormat : 'rgb';
            const sortedStops = [...state.stops].sort((a, b) => a.position - b.position);
            const colorStr = sortedStops.map(s => `${formatColorForCSS(s, fmt)} ${s.position}%`).join(', ');
            const prefix = state.repeating ? 'repeating-' : '';

            if (state.type === 'linear') {
                return `${prefix}linear-gradient(${state.angle}deg, ${colorStr})`;
            } else if (state.type === 'radial') {
                return `${prefix}radial-gradient(${state.shape} ${state.radialPosition}, ${colorStr})`;
            } else {
                return `${prefix}conic-gradient(from ${state.angle}deg ${state.radialPosition}, ${colorStr})`;
            }
        }

        function buildCSSOutput() {
            const grad = buildGradientString(true);
            const lines = [];
            lines.push(`background: -webkit-${grad};`);
            lines.push(`background: -moz-${grad};`);
            lines.push(`background: ${grad};`);
            return lines.join('\n');
        }

        function updateGradient() {
            const gradient = buildGradientString(false);
            previewBox.style.backgroundImage = gradient;
            cssOutput.value = buildCSSOutput();
            renderGradientBar();

            // Fullscreen sync
            if (fullscreenOverlay.classList.contains('show')) {
                fullscreenGradient.style.background = gradient;
                fullscreenInfo.textContent = buildGradientString(true);
            }
        }

        // ===== COPY =====
        copyBtn.addEventListener('click', () => {

                                <i class="fas fa-arrow-right-long"></i>&nbsp; Linear
                            </button>
                            <button class="type-btn" data-type="radial" id="btnRadial">
                                <i class="fas fa-circle-dot"></i>&nbsp; Radial
                            </button>
                            <button class="type-btn" data-type="conic" id="btnConic">
                                <i class="fas fa-compact-disc"></i>&nbsp; Conic
                            </button>
                        </div>
                    </div>

                    <!-- Angle -->
                    <div class="control-group angle-control" id="angleControl">
                        <label class="control-label">Direction / Angle</label>
                        <div class="angle-top-row">
                            <div class="angle-wheel-container">
                                <div class="angle-wheel" id="angleWheel">
                                    <div class="angle-wheel-center"></div>
                                    <div class="angle-wheel-pointer" id="angleWheelPointer"></div>
                                    <div class="angle-wheel-dot" id="angleWheelDot"></div>
                                </div>
                            </div>
                            <div class="angle-right-col">
                                <div class="angle-display">
                                    <span style="font-size:12px;color:var(--text-secondary);">Angle</span>
                                    <span class="angle-value" id="angleValue">90°</span>
                                </div>
                                <input type="range" min="0" max="360" value="90" class="angle-slider" id="angleSlider">
                                <div class="direction-presets" id="directionPresets"></div>

        // ===== HISTORY =====
        function saveToHistory() {
            const entry = {
                type: state.type,
                angle: state.angle,
                shape: state.shape,
                radialPosition: state.radialPosition,
                repeating: state.repeating,
                stops: JSON.parse(JSON.stringify(state.stops)),
                timestamp: Date.now()
            };
            // Avoid duplicates (simple check)
            history = history.filter(h => JSON.stringify(h.stops) !== JSON.stringify(entry.stops) || h.type !== entry.type || h.angle !== entry.angle);
            history.unshift(entry);
            if (history.length > 12) history = history.slice(0, 12);
            localStorage.setItem('pt-gradient-history', JSON.stringify(history));
            renderHistory();
        }

        function renderHistory() {
            historyGrid.innerHTML = '';
            if (history.length === 0) {
                historyGrid.innerHTML = '<div class="history-empty"><i class="fas fa-clock-rotate-left" style="margin-right:6px;"></i>Your gradient history will appear here</div>';
                return;
            }
            history.forEach((h, i) => {
                const div = document.createElement('div');
                div.className = 'history-swatch';
                const sortedStops = [...h.stops].sort((a, b) => a.position - b.position);
                const colorStr = sortedStops.map(s => `${s.color} ${s.position}%`).join(', ');
                if (h.type === 'linear') div.style.background = `linear-gradient(${h.angle}deg, ${colorStr})`;
                else if (h.type === 'radial') div.style.background = `radial-gradient(${h.shape || 'circle'}, ${colorStr})`;
                else div.style.background = `conic-gradient(from ${h.angle}deg, ${colorStr})`;

                const delBtn = document.createElement('button');
                delBtn.className = 'history-delete';
                delBtn.innerHTML = '<i class="fas fa-xmark"></i>';
                delBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    history.splice(i, 1);
                    localStorage.setItem('pt-gradient-history', JSON.stringify(history));
                    renderHistory();
                });
                div.appendChild(delBtn);

                div.addEventListener('click', () => {
                    state.type = h.type;
                    state.angle = h.angle;
                    state.shape = h.shape || 'circle';
                    state.radialPosition = h.radialPosition || 'at center';
                    state.repeating = h.repeating || false;
                    state.stops = JSON.parse(JSON.stringify(h.stops));
                    state.stops.forEach(s => { if (s.opacity === undefined) s.opacity = 1; });
                    state.activeStopIndex = 0;
                    syncTypeButtons();
                    syncAngleUI();
                    renderColorStops();
                    renderRadialPositions();
                    updateGradient();
                    showToast('Gradient restored from history');
                });

                historyGrid.appendChild(div);
            });
        }

        // ===== KEYBOARD SHORTCUTS =====
        document.addEventListener('keydown', (e) => {
            // Ctrl+C → copy when not in input
            if ((e.ctrlKey || e.metaKey) && e.key === 'c' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                // Don't override normal copy
            }
            // R for random (when not focused on input)
            if (e.key === 'r' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                generateRandom();
            }
            // F for fullscreen
            if (e.key === 'f' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                if (fullscreenOverlay.classList.contains('show')) closeFullscreen();
                else openFullscreen();

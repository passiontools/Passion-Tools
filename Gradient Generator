        // ===== EXPORT PNG =====
        function exportPNG() {
            const canvas = document.createElement('canvas');
            canvas.width = 1920;
            canvas.height = 1080;
            const ctx = canvas.getContext('2d');

            const sortedStops = [...state.stops].sort((a, b) => a.position - b.position);
            let grad;

            if (state.type === 'linear') {
                const rad = (state.angle - 90) * Math.PI / 180;
                const cx = 960, cy = 540, len = 1200;
                grad = ctx.createLinearGradient(
                    cx - len * Math.cos(rad), cy - len * Math.sin(rad),
                    cx + len * Math.cos(rad), cy + len * Math.sin(rad)
                );
            } else if (state.type === 'radial') {
                grad = ctx.createRadialGradient(960, 540, 0, 960, 540, 700);
            } else {
                // Conic → fallback to linear for canvas
                const rad = (state.angle - 90) * Math.PI / 180;
                const cx = 960, cy = 540, len = 1200;
                grad = ctx.createLinearGradient(
                    cx - len * Math.cos(rad), cy - len * Math.sin(rad),
                    cx + len * Math.cos(rad), cy + len * Math.sin(rad)
                );
            }

            sortedStops.forEach(s => {
                const { r, g, b } = hexToRgb(s.color);
                const alpha = s.opacity !== undefined ? s.opacity : 1;
                grad.addColorStop(s.position / 100, `rgba(${r},${g},${b},${alpha})`);
            });

            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, 1920, 1080);

            canvas.toBlob((blob) => {
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'gradient-passiontools.png';
                a.click();
                URL.revokeObjectURL(url);
                showToast('PNG exported (1920×1080)');
            });
        }

        document.getElementById('qaExportPNG').addEventListener('click', exportPNG);
        document.getElementById('exportPngBtn2').addEventListener('click', exportPNG);


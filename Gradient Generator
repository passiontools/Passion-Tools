                    <div class="css-output-wrapper">
                        <textarea class="css-output" id="cssOutput" readonly></textarea>
                    </div>

                    <div class="action-bar">
                        <button class="btn-copy" id="copyBtn">
                            <i class="fas fa-copy"></i> Copy CSS
                        </button>
                        <button class="btn-export" id="exportPngBtn2">
                            <i class="fas fa-image"></i> PNG
                        </button>
                        <button class="btn-reset" id="resetBtn">
                            <i class="fas fa-rotate-left"></i> Reset
                        </button>
                    </div>
                </div>

                <!-- History -->
                <div class="card history-section" style="margin-top:28px;">
                    <h2 class="card-title"><i class="fas fa-clock-rotate-left"></i> History</h2>

        // ===== GRADIENT BAR (Draggable stops) =====
        let barDragging = null;

        function renderGradientBar() {
            // Set bar background
            const sortedStops = [...state.stops].sort((a, b) => a.position - b.position);
            const colorStr = sortedStops.map(s => `${formatColorWithOpacity(s)} ${s.position}%`).join(', ');
            gradientBar.style.background = `linear-gradient(90deg, ${colorStr})`;

            // Remove old handles
            gradientBar.querySelectorAll('.gradient-bar-handle').forEach(h => h.remove());

            // Create handles
            state.stops.forEach((stop, i) => {
                const handle = document.createElement('div');
                handle.className = 'gradient-bar-handle' + (i === state.activeStopIndex ? ' active-handle' : '');
                handle.style.left = stop.position + '%';
                handle.style.background = stop.color;
                handle.dataset.index = i;

                handle.addEventListener('mousedown', (e) => {
                    e.preventDefault();
                    barDragging = i;
                    state.activeStopIndex = i;
                    document.body.classList.add('dragging');
                    renderColorStops();

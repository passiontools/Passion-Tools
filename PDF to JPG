<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDF to JPG Converter - PassionTools</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <style>
        :root {
            --red: #ef4444;
            --purple: #a855f7;
            --blue: #3b82f6;
            --blue-dark: #2563eb;
            --green: #22c55e;
            --bg-color: #f9fafb;
            --card-bg: #ffffff;
            --text-primary: #000000;
            --text-secondary: #6b7280;
            --border-color: #e5e7eb;
            --hover-gray: #f3f4f6;
            --btn-action-bg: #fef2f2;
            --error-bg: #fee2e2;
            --error-text: #991b1b;
            --footer-bg: #111827;
        }

        [data-theme="dark"] {
            --bg-color: #020617;
            --card-bg: #111827;
            --text-primary: #ffffff;
            --text-secondary: #94a3b8;
            --border-color: #1e293b;
            --hover-gray: #1e293b;
            --btn-action-bg: #450a0a;
            --error-bg: #7f1d1d;
            --error-text: #f87171;
            --footer-bg: #020617;
        }

        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
            -webkit-font-smoothing: antialiased;
        }

        /* ========== HEADER ========== */
        .header {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.72);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-color);
            transition: all 0.3s ease;
        }

        [data-theme="dark"] .header {
            background: rgba(2, 6, 23, 0.72);
        }

        .header-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            text-decoration: none;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -0.5px;
            display: inline-flex;
            align-items: center;
            cursor: pointer;
        }

        .logo-passion {
            color: var(--text-primary);
            transition: none;
        }

        .logo-tools {
            background: linear-gradient(135deg, var(--red), var(--purple));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .back-link {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.3s ease;
            background: none;
            border: none;
            padding: 0;
        }

        .back-link:hover {
            color: var(--red);
        }

        .theme-toggle {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 20px;
            padding: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            border-radius: 8px;
            width: 36px;
            height: 36px;
        }

        .theme-toggle:hover {
            background: var(--hover-gray);
        }

        /* ========== MAIN CONTENT ========== */
        .main-content {
            flex: 1;
            max-width: 820px;
            width: 100%;
            margin: 0 auto;
            padding: 48px 24px 64px;
        }

        .tool-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .tool-title {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.5px;
            margin-bottom: 12px;
            line-height: 1.2;
        }

        .tool-subtitle {
            font-size: 16px;
            color: var(--text-secondary);
            line-height: 1.6;
            max-width: 560px;
            margin: 0 auto;
            font-weight: 400;
        }

        /* ========== WORKSPACE CARD ========== */
        .workspace-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        /* ========== STATE 1: UPLOAD AREA ========== */
        .upload-area {
            padding: 48px 32px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .upload-dropzone {
            width: 100%;
            border: 2.5px dashed var(--border-color);
            border-radius: 14px;
            padding: 56px 32px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
        }

        .upload-dropzone:hover,
        .upload-dropzone.drag-over {
            border-color: var(--blue);
            background: rgba(59, 130, 246, 0.04);
        }

        [data-theme="dark"] .upload-dropzone:hover,
        [data-theme="dark"] .upload-dropzone.drag-over {
            background: rgba(59, 130, 246, 0.08);
        }

        .upload-icon {
            width: 88px;
            height: 88px;
            border-radius: 22px;
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.08), rgba(168, 85, 247, 0.08));
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 22px;
            position: relative;
            transition: all 0.3s ease;
        }

        .upload-icon svg {
            width: 52px;
            height: 52px;
            filter: drop-shadow(0 2px 8px rgba(239, 68, 68, 0.15));
            transition: all 0.3s ease;
        }

        .upload-dropzone:hover .upload-icon {
            transform: scale(1.06);
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.12), rgba(168, 85, 247, 0.12));
        }

        .upload-dropzone:hover .upload-icon svg {
            filter: drop-shadow(0 4px 12px rgba(239, 68, 68, 0.25));
        }

        .upload-title {
            font-size: 17px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .upload-title span {
            color: var(--blue);
        }

        .upload-hint {
            font-size: 13px;
            color: var(--text-secondary);
            font-weight: 400;
        }

        .file-input-hidden {
            display: none;
        }

        /* ========== STATE 2: PREVIEW & SETTINGS ========== */
        .settings-panel {
            display: none;
            padding: 32px;
        }

        .settings-panel.active {
            display: block;
        }

        /* File Info */
        .file-info-bar {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 20px;
            background: var(--hover-gray);
            border-radius: 12px;
            margin-bottom: 28px;
            transition: all 0.3s ease;
        }

        .file-info-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--red), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 18px;
            flex-shrink: 0;
        }

        .file-info-details {
            flex: 1;
            min-width: 0;
        }

        .file-info-name {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .file-info-meta {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 2px;
        }

        /* Quality Slider */
        .setting-group {
            margin-bottom: 28px;
        }

        .setting-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .setting-label-text {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .setting-label-text i {
            color: var(--blue);
            font-size: 14px;
        }

        .setting-label-value {
            font-size: 14px;
            font-weight: 700;
            color: var(--blue);
            background: rgba(59, 130, 246, 0.1);
            padding: 3px 10px;
            border-radius: 6px;
        }

        .quality-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 8px;
            border-radius: 4px;
            background: var(--border-color);
            outline: none;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .quality-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--blue);
            cursor: pointer;
            border: 3px solid var(--card-bg);
            box-shadow: 0 2px 8px rgba(59, 130, 246, 0.35);
            transition: all 0.3s ease;
        }

        .quality-slider::-webkit-slider-thumb:hover {
            transform: scale(1.15);
            box-shadow: 0 2px 12px rgba(59, 130, 246, 0.5);
        }

        .quality-slider::-moz-range-thumb {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--blue);
            cursor: pointer;
            border: 3px solid var(--card-bg);
            box-shadow: 0 2px 8px rgba(59, 130, 246, 0.35);
            transition: all 0.3s ease;
        }

        .quality-labels {
            display: flex;
            justify-content: space-between;
            margin-top: 8px;
        }

        .quality-labels span {
            font-size: 11px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        /* Progress */
        .progress-container {
            display: none;
            margin-bottom: 28px;
        }

        .progress-container.active {
            display: block;
        }

        .progress-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .progress-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .progress-percent {
            font-size: 13px;
            font-weight: 700;
            color: var(--blue);
        }

        .progress-track {
            width: 100%;
            height: 10px;
            background: var(--border-color);
            border-radius: 5px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--blue), var(--purple));
            border-radius: 5px;
            transition: width 0.3s ease;
        }

        .progress-status {
            font-size: 12px;
            color: var(--text-secondary);
            margin-top: 8px;
            text-align: center;
        }

        /* Action Bar */
        .action-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-top: 4px;
        }

        .btn-convert {
            flex: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 14px 24px;
            background: var(--blue);
            color: #ffffff;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-convert:hover:not(:disabled) {
            background: var(--blue-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(59, 130, 246, 0.35);
        }

        .btn-convert:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-convert:active:not(:disabled) {
            transform: translateY(0);
        }

        .btn-start-over {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 14px 24px;
            background: transparent;
            color: var(--red);
            border: 1.5px solid var(--red);
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-start-over:hover {
            background: var(--btn-action-bg);
        }

        /* Success State */
        .success-message {
            display: none;
            align-items: center;
            gap: 10px;
            padding: 14px 18px;
            background: rgba(34, 197, 94, 0.08);
            border: 1px solid rgba(34, 197, 94, 0.25);
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 500;
            color: var(--green);
        }

        .success-message.active {
            display: flex;
        }

        .success-message i {
            font-size: 18px;
        }

        /* Error State */
        .error-message {
            display: none;
            align-items: center;
            gap: 10px;
            padding: 14px 18px;
            background: var(--error-bg);
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 500;
            color: var(--error-text);
        }

        .error-message.active {
            display: flex;
        }

        .error-message i {
            font-size: 18px;
        }

        /* ========== FOOTER ========== */
        .footer {
            text-align: center;
            padding: 30px 20px;
            font-size: 14px;
            color: #94a3b8;
            background: var(--footer-bg);
            margin-top: auto;
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 640px) {
            .header-inner {
                padding: 0 16px;
            }

            .main-content {
                padding: 32px 16px 48px;
            }

            .tool-title {
                font-size: 26px;
            }

            .tool-subtitle {
                font-size: 14px;
            }

            .upload-dropzone {
                padding: 40px 20px;
            }

            .upload-icon {
                width: 56px;
                height: 56px;
                font-size: 22px;
            }

            .upload-title {
                font-size: 15px;
            }

            .settings-panel {
                padding: 24px 20px;
            }

            .file-info-bar {
                padding: 14px 16px;
                gap: 12px;
            }

            .quality-slider {
                height: 10px;
            }

            .quality-slider::-webkit-slider-thumb {
                width: 28px;
                height: 28px;
            }

            .quality-slider::-moz-range-thumb {
                width: 28px;
                height: 28px;
            }

            .action-bar {
                flex-direction: column;
            }

            .btn-convert,
            .btn-start-over {
                width: 100%;
            }

            .back-link-text {
                display: none;
            }
        }

        /* Hidden Canvas */
        #renderCanvas {
            display: none;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="header-inner">
            <a href="#" class="logo" onclick="event.preventDefault();">
                <span class="logo-passion">Passion</span><span class="logo-tools">Tools</span>
            </a>
            <div class="header-actions">
                <a href="index.html" class="back-link">
                    <i class="fas fa-arrow-left"></i>
                    <span class="back-link-text">Back to Tools</span>
                </a>
                <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">☀️</button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main-content">
        <div class="tool-header">
            <h1 class="tool-title">PDF to JPG Converter</h1>
            <p class="tool-subtitle">Extract high-quality JPG images from any PDF document instantly. 100% private in-browser processing.</p>
        </div>

        <div class="workspace-card">
            <!-- State 1: Upload Area -->
            <div class="upload-area" id="uploadArea">
                <div class="upload-dropzone" id="dropzone">
                    <div class="upload-icon">
                        <svg viewBox="0 0 56 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M35 0H7C3.13 0 0 3.13 0 7v50c0 3.87 3.13 7 7 7h42c3.87 0 7-3.13 7-7V21L35 0z" fill="#ef4444" opacity="0.12"/>
                            <path d="M35 0H7C3.13 0 0 3.13 0 7v50c0 3.87 3.13 7 7 7h42c3.87 0 7-3.13 7-7V21L35 0z" stroke="#ef4444" stroke-width="2" fill="none"/>
                            <path d="M35 0v14c0 3.87 3.13 7 7 7h14" stroke="#ef4444" stroke-width="2" fill="none"/>
                            <path d="M35 0L56 21H42c-3.87 0-7-3.13-7-7V0z" fill="#ef4444" opacity="0.2"/>
                            <text x="28" y="44" text-anchor="middle" font-family="Inter, sans-serif" font-weight="800" font-size="13" fill="#ef4444">PDF</text>
                        </svg>
                    </div>
                    <p class="upload-title">Drag & drop your PDF here or <span>browse files</span></p>
                    <p class="upload-hint">Supports any PDF document</p>
                    <input type="file" id="fileInput" class="file-input-hidden" accept=".pdf,application/pdf">
                </div>
            </div>

            <!-- State 2: Settings & Convert -->
            <div class="settings-panel" id="settingsPanel">
                <!-- Error Message -->
                <div class="error-message" id="errorMessage">
                    <i class="fas fa-circle-exclamation"></i>
                    <span id="errorText">Something went wrong.</span>
                </div>

                <!-- Success Message -->
                <div class="success-message" id="successMessage">
                    <i class="fas fa-circle-check"></i>
                    <span id="successText">Conversion complete! Your download should start automatically.</span>
                </div>

                <!-- File Info -->
                <div class="file-info-bar">
                    <div class="file-info-icon">
                        <i class="fas fa-file-pdf"></i>
                    </div>
                    <div class="file-info-details">
                        <div class="file-info-name" id="fileName">document.pdf</div>
                        <div class="file-info-meta" id="fileMeta">0 pages</div>
                    </div>
                </div>

                <!-- Quality Slider -->
                <div class="setting-group">
                    <div class="setting-label">
                        <span class="setting-label-text">
                            <i class="fas fa-sliders"></i>
                            JPG Quality
                        </span>
                        <span class="setting-label-value" id="qualityValue">90%</span>
                    </div>
                    <input type="range" class="quality-slider" id="qualitySlider" min="10" max="100" value="90" step="5">
                    <div class="quality-labels">
                        <span>Low (10%)</span>
                        <span>High (100%)</span>
                    </div>
                </div>

                <!-- Progress -->
                <div class="progress-container" id="progressContainer">
                    <div class="progress-header">
                        <span class="progress-label">Converting pages...</span>
                        <span class="progress-percent" id="progressPercent">0%</span>
                    </div>
                    <div class="progress-track">
                        <div class="progress-fill" id="progressFill"></div>
                    </div>
                    <div class="progress-status" id="progressStatus">Preparing...</div>
                </div>

                <!-- Action Bar -->
                <div class="action-bar">
                    <button class="btn-convert" id="btnConvert">
                        <i class="fas fa-download"></i>
                        Convert & Download ZIP
                    </button>
                    <button class="btn-start-over" id="btnStartOver">
                        <i class="fas fa-rotate-left"></i>
                        Start Over
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Hidden Canvas for Rendering -->
    <canvas id="renderCanvas"></canvas>

    <!-- Footer -->
    <footer class="footer">
        © 2026 Passion Tools. Secure client-side processing.
    </footer>

    <script>
        // ==================== PDF.js Worker Setup ====================
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        // ==================== Theme Toggle ====================
        const themeToggle = document.getElementById('themeToggle');
        const savedTheme = localStorage.getItem('passion-tools-theme');

        function applyTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            themeToggle.textContent = theme === 'dark' ? '🌙' : '☀️';
            localStorage.setItem('passion-tools-theme', theme);
        }

        if (savedTheme) {
            applyTheme(savedTheme);
        } else {
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            applyTheme(prefersDark ? 'dark' : 'light');
        }

        themeToggle.addEventListener('click', () => {
            const current = document.documentElement.getAttribute('data-theme');
            applyTheme(current === 'dark' ? 'light' : 'dark');
        });

        // ==================== DOM Elements ====================
        const uploadArea = document.getElementById('uploadArea');
        const settingsPanel = document.getElementById('settingsPanel');
        const dropzone = document.getElementById('dropzone');
        const fileInput = document.getElementById('fileInput');
        const fileNameEl = document.getElementById('fileName');
        const fileMetaEl = document.getElementById('fileMeta');
        const qualitySlider = document.getElementById('qualitySlider');
        const qualityValueEl = document.getElementById('qualityValue');
        const progressContainer = document.getElementById('progressContainer');
        const progressFill = document.getElementById('progressFill');
        const progressPercent = document.getElementById('progressPercent');
        const progressStatus = document.getElementById('progressStatus');
        const btnConvert = document.getElementById('btnConvert');
        const btnStartOver = document.getElementById('btnStartOver');
        const errorMessage = document.getElementById('errorMessage');
        const errorText = document.getElementById('errorText');
        const successMessage = document.getElementById('successMessage');
        const renderCanvas = document.getElementById('renderCanvas');

        let pdfDoc = null;
        let isConverting = false;

        // ==================== Quality Slider ====================
        qualitySlider.addEventListener('input', () => {
            qualityValueEl.textContent = qualitySlider.value + '%';
        });

        // ==================== Drag & Drop ====================
        dropzone.addEventListener('click', () => fileInput.click());

        dropzone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropzone.classList.add('drag-over');
        });

        dropzone.addEventListener('dragleave', (e) => {
            e.preventDefault();
            dropzone.classList.remove('drag-over');
        });

        dropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropzone.classList.remove('drag-over');
            const files = e.dataTransfer.files;
            if (files.length > 0 && files[0].type === 'application/pdf') {
                handleFile(files[0]);
            } else {
                showError('Please upload a valid PDF file.');
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFile(e.target.files[0]);
            }
        });

        // ==================== File Handling ====================
        function handleFile(file) {
            if (file.type !== 'application/pdf') {
                showError('Please upload a valid PDF file.');
                return;
            }

            hideError();
            hideSuccess();

            const reader = new FileReader();
            reader.onload = async function(e) {
                try {
                    const typedArray = new Uint8Array(e.target.result);
                    pdfDoc = await pdfjsLib.getDocument({ data: typedArray }).promise;

                    const pageCount = pdfDoc.numPages;
                    const fileSize = formatFileSize(file.size);

                    fileNameEl.textContent = file.name;
                    fileMetaEl.textContent = pageCount + (pageCount === 1 ? ' page' : ' pages') + ' • ' + fileSize;

                    showSettings();
                } catch (err) {
                    showError('Failed to parse the PDF file. It may be corrupted or password-protected.');
                    console.error(err);
                }
            };
            reader.onerror = function() {
                showError('Failed to read the file. Please try again.');
            };
            reader.readAsArrayBuffer(file);
        }

        // ==================== UI State Transitions ====================
        function showSettings() {
            uploadArea.style.display = 'none';
            settingsPanel.classList.add('active');
            resetProgress();
        }

        function showUpload() {
            settingsPanel.classList.remove('active');
            uploadArea.style.display = 'flex';
            pdfDoc = null;
            fileInput.value = '';
            resetProgress();
            hideError();
            hideSuccess();
            btnConvert.disabled = false;
            btnConvert.innerHTML = '<i class="fas fa-download"></i> Convert & Download ZIP';
        }

        function resetProgress() {
            progressContainer.classList.remove('active');
            progressFill.style.width = '0%';
            progressPercent.textContent = '0%';
            progressStatus.textContent = 'Preparing...';
        }

        function showError(msg) {
            errorText.textContent = msg;
            errorMessage.classList.add('active');
        }

        function hideError() {
            errorMessage.classList.remove('active');
        }

        function showSuccess(msg) {
            document.getElementById('successText').textContent = msg || 'Conversion complete! Your download should start automatically.';
            successMessage.classList.add('active');
        }

        function hideSuccess() {
            successMessage.classList.remove('active');
        }

        function formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / 1048576).toFixed(1) + ' MB';
        }

        // ==================== Conversion ====================
        btnConvert.addEventListener('click', async () => {
            if (!pdfDoc || isConverting) return;

            isConverting = true;
            hideError();
            hideSuccess();
            btnConvert.disabled = true;
            btnConvert.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Converting...';

            progressContainer.classList.add('active');
            progressFill.style.width = '0%';
            progressPercent.textContent = '0%';

            const quality = parseInt(qualitySlider.value) / 100;
            const totalPages = pdfDoc.numPages;
            const zip = new JSZip();
            const canvas = renderCanvas;
            const ctx = canvas.getContext('2d');

            try {
                for (let i = 1; i <= totalPages; i++) {
                    progressStatus.textContent = `Rendering page ${i} of ${totalPages}...`;

                    const page = await pdfDoc.getPage(i);
                    const viewport = page.getViewport({ scale: 2.0 });

                    canvas.width = viewport.width;
                    canvas.height = viewport.height;

                    const renderContext = {
                        canvasContext: ctx,
                        viewport: viewport
                    };

                    await page.render(renderContext).promise;

                    const jpgDataUrl = canvas.toDataURL('image/jpeg', quality);
                    const base64Data = jpgDataUrl.replace(/^data:image\/jpeg;base64,/, '');

                    const pageNum = String(i).padStart(String(totalPages).length, '0');
                    zip.file(`page-${pageNum}.jpg`, base64Data, { base64: true });

                    const pct = Math.round((i / totalPages) * 100);
                    progressFill.style.width = pct + '%';
                    progressPercent.textContent = pct + '%';

                    // Yield to browser to update UI
                    await new Promise(r => setTimeout(r, 10));
                }

                progressStatus.textContent = 'Generating ZIP file...';

                const zipBlob = await zip.generateAsync({
                    type: 'blob',
                    compression: 'DEFLATE',
                    compressionOptions: { level: 6 }
                }, (metadata) => {
                    const zipPct = Math.round(metadata.percent);
                    progressStatus.textContent = `Compressing ZIP: ${zipPct}%`;
                });

                // Trigger download
                const link = document.createElement('a');
                link.href = URL.createObjectURL(zipBlob);
                link.download = 'passion-tools-images.zip';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(link.href);

                progressFill.style.width = '100%';
                progressPercent.textContent = '100%';
                progressStatus.textContent = 'Done!';

                showSuccess(`Successfully converted ${totalPages} ${totalPages === 1 ? 'page' : 'pages'} to JPG!`);

                btnConvert.innerHTML = '<i class="fas fa-check"></i> Done!';

                // Allow reconvert
                setTimeout(() => {
                    btnConvert.disabled = false;
                    btnConvert.innerHTML = '<i class="fas fa-download"></i> Convert & Download ZIP';
                    isConverting = false;
                }, 2000);

            } catch (err) {
                showError('An error occurred during conversion. Please try again.');
                console.error(err);
                btnConvert.disabled = false;
                btnConvert.innerHTML = '<i class="fas fa-download"></i> Convert & Download ZIP';
                isConverting = false;
            }
        });

        // ==================== Start Over ====================
        btnStartOver.addEventListener('click', () => {
            if (isConverting) return;
            showUpload();
        });
    </script>
</body>
</html>

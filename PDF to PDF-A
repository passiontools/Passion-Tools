<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDF to PDF/A Converter — PassionTools</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <style>
        :root {
            --red: #ef4444;
            --purple: #a855f7;
            --blue: #3b82f6;
            --blue-dark: #2563eb;
            --green: #22c55e;
            --bg-color: #f9fafb;
            --card-bg: #ffffff;
            --text-primary: #000000;
            --text-secondary: #6b7280;
            --border-color: #e5e7eb;
            --hover-gray: #f3f4f6;
            --btn-action-bg: #fef2f2;
            --error-bg: #fee2e2;
            --error-text: #991b1b;
            --header-bg: rgba(255,255,255,0.72);
            --footer-bg: #111827;
        }

        [data-theme="dark"] {
            --bg-color: #020617;
            --card-bg: #111827;
            --text-primary: #ffffff;
            --text-secondary: #94a3b8;
            --border-color: #1e293b;
            --hover-gray: #1e293b;
            --btn-action-bg: #450a0a;
            --error-bg: #7f1d1d;
            --error-text: #f87171;
            --header-bg: rgba(2,6,23,0.72);
            --footer-bg: #020617;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-color);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: background 0.3s ease, color 0.3s ease;
        }

        /* ── Header ── */
        .header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--header-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border-color);
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.3s ease;
        }

        .logo {
            text-decoration: none;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -0.5px;
            display: inline-flex;
            line-height: 1;
        }
        .logo-passion { color: var(--text-primary); transition: color 0.3s ease; }
        .logo-tools {
            background: linear-gradient(135deg, var(--red), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header-actions { display: flex; align-items: center; gap: 20px; }

        .back-link {
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            color: var(--text-secondary);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: color 0.3s ease;
        }
        .back-link:hover { color: var(--red); }

        .theme-toggle {
            background: none;
            border: 1px solid var(--border-color);
            width: 40px;
            height: 40px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        .theme-toggle:hover { background: var(--hover-gray); }

        /* ── Main Content ── */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 48px 20px 60px;
        }

        .tool-header { text-align: center; margin-bottom: 36px; max-width: 600px; }
        .tool-header h1 {
            font-size: 28px;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 10px;
            letter-spacing: -0.5px;
        }
        .tool-header p {
            font-size: 15px;
            color: var(--text-secondary);
            line-height: 1.65;
            font-weight: 400;
        }

        .workspace {
            width: 100%;
            max-width: 600px;
        }

        /* ── Upload Zone (State 1) ── */
        .upload-zone {
            border: 2.5px dashed var(--border-color);
            border-radius: 16px;
            background: var(--card-bg);
            padding: 56px 32px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }
        .upload-zone:hover,
        .upload-zone.drag-over {
            border-color: var(--blue);
            background: color-mix(in srgb, var(--blue) 4%, var(--card-bg));
        }
        .upload-zone.drag-over .upload-icon { transform: scale(1.12); }

        .upload-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 20px;
            border-radius: 16px;
            background: color-mix(in srgb, var(--blue) 10%, transparent);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.3s ease;
        }
        .upload-icon i { font-size: 26px; color: var(--blue); }

        .upload-zone h3 {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 6px;
        }
        .upload-zone p {
            font-size: 13px;
            color: var(--text-secondary);
        }
        .upload-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }

        /* ── Processing UI (State 2) ── */
        .processing-ui { display: none; }
        .processing-ui.active { display: block; }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            padding: 20px 24px;
            margin-bottom: 16px;
            transition: all 0.3s ease;
        }

        /* File Details */
        .file-details { display: flex; align-items: center; gap: 16px; }

        .file-icon-box {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: var(--btn-action-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .file-icon-box i { font-size: 22px; color: var(--red); }

        .file-meta { min-width: 0; flex: 1; }
        .file-meta .file-name {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .file-meta .file-size {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 2px;
        }

        /* Pipeline progress */
        .pipeline-card { padding: 0; overflow: hidden; }
        .pipeline-header {
            padding: 16px 24px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .pipeline-header i { color: var(--blue); }

        .pipeline-steps { padding: 8px 24px 16px; }

        .p-step {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            font-size: 13px;
            color: var(--text-secondary);
            transition: color 0.3s ease;
        }
        .p-step.active { color: var(--blue); font-weight: 600; }
        .p-step.done { color: var(--green); }
        .p-step.error-step { color: var(--red); }

        .step-indicator {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            border: 2px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 11px;
            transition: all 0.3s ease;
        }
        .p-step.active .step-indicator {
            border-color: var(--blue);
            background: color-mix(in srgb, var(--blue) 12%, transparent);
            color: var(--blue);
        }
        .p-step.done .step-indicator {
            border-color: var(--green);
            background: var(--green);
            color: #fff;
        }
        .p-step.error-step .step-indicator {
            border-color: var(--red);
            background: var(--red);
            color: #fff;
        }

        @keyframes spin { to { transform: rotate(360deg); } }
        .spinner-icon { animation: spin 0.8s linear infinite; }

        /* Compliance Info */
        .compliance-banner {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            background: color-mix(in srgb, var(--blue) 6%, var(--card-bg));
            border: 1px solid color-mix(in srgb, var(--blue) 18%, transparent);
            border-radius: 12px;
            padding: 16px 20px;
            margin-bottom: 16px;
        }
        .compliance-banner i { color: var(--blue); font-size: 16px; margin-top: 2px; flex-shrink: 0; }
        .compliance-banner p { font-size: 12.5px; color: var(--text-secondary); line-height: 1.6; }

        /* Action bar */
        .action-bar { display: flex; gap: 12px; margin-top: 4px; }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 600;
            padding: 13px 28px;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            flex: 1;
            white-space: nowrap;
        }

        .btn-primary {
            background: var(--blue);
            color: #ffffff;
        }
        .btn-primary:hover { background: var(--blue-dark); transform: translateY(-1px); box-shadow: 0 4px 16px color-mix(in srgb, var(--blue) 35%, transparent); }
        .btn-primary:disabled { opacity: 0.55; cursor: not-allowed; transform: none; box-shadow: none; }

        .btn-ghost-red {
            background: var(--btn-action-bg);
            color: var(--red);
            border: 1px solid color-mix(in srgb, var(--red) 18%, transparent);
        }
        .btn-ghost-red:hover { background: color-mix(in srgb, var(--red) 12%, transparent); }

        .btn-success {
            background: var(--green);
            color: #fff;
        }
        .btn-success:hover { background: color-mix(in srgb, var(--green) 85%, #000); transform: translateY(-1px); }

        /* Result */
        .result-banner {
            display: none;
            align-items: center;
            gap: 12px;
            border-radius: 12px;
            padding: 16px 20px;
            margin-bottom: 16px;
        }
        .result-banner.success {
            display: flex;
            background: color-mix(in srgb, var(--green) 8%, var(--card-bg));
            border: 1px solid color-mix(in srgb, var(--green) 22%, transparent);
        }
        .result-banner.success i { color: var(--green); font-size: 20px; }
        .result-banner.success .result-text { font-size: 13.5px; color: var(--text-primary); font-weight: 500; }
        .result-banner.success .result-sub { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }

        .result-banner.error-banner {
            display: flex;
            background: var(--error-bg);
            border: 1px solid color-mix(in srgb, var(--red) 22%, transparent);
        }
        .result-banner.error-banner i { color: var(--error-text); font-size: 20px; }
        .result-banner.error-banner .result-text { font-size: 13.5px; color: var(--error-text); font-weight: 500; }
        .result-banner.error-banner .result-sub { font-size: 12px; color: var(--error-text); opacity: 0.75; margin-top: 2px; }

        /* ── Footer ── */
        .footer {
            text-align: center;
            padding: 30px 20px;
            font-size: 14px;
            color: #94a3b8;
            background: var(--footer-bg);
            margin-top: auto;
        }

        /* ── Responsive ── */
        @media (max-width: 640px) {
            .header { padding: 0 16px; height: 56px; }
            .logo { font-size: 19px; }
            .back-link span { display: none; }
            .main-content { padding: 32px 14px 48px; }
            .tool-header h1 { font-size: 22px; }
            .tool-header p { font-size: 14px; }
            .upload-zone { padding: 40px 20px; }
            .action-bar { flex-direction: column; }
            .btn { width: 100%; }
            .card { padding: 16px 18px; }
            .pipeline-header { padding: 14px 18px; }
            .pipeline-steps { padding: 8px 18px 14px; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <a href="#" onclick="event.preventDefault();" class="logo">
            <span class="logo-passion">Passion</span><span class="logo-tools">Tools</span>
        </a>
        <div class="header-actions">
            <a href="index.html" class="back-link">
                <i class="fa-solid fa-arrow-left"></i>
                <span>Back to Tools</span>
            </a>
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">☀️</button>
        </div>
    </header>

    <!-- Main -->
    <main class="main-content">
        <div class="tool-header">
            <h1>PDF to PDF/A Converter</h1>
            <p>Convert standard PDFs into PDF/A-ready, archive-optimized PDFs for long-term storage. All processing happens 100% privately in your browser</p>
        </div>

        <div class="workspace">
            <!-- State 1: Upload -->
            <div class="upload-zone" id="uploadZone">
                <input type="file" accept=".pdf,application/pdf" id="fileInput">
                <div class="upload-icon">
                    <i class="fa-solid fa-cloud-arrow-up"></i>
                </div>
                <h3>Click or Drag & Drop PDF file here</h3>
                <p>Supports standard PDF documents</p>
            </div>

            <!-- State 2: Processing -->
            <div class="processing-ui" id="processingUI">

                <!-- File Info -->
                <div class="card">
                    <div class="file-details">
                        <div class="file-icon-box">
                            <i class="fa-solid fa-file-pdf"></i>
                        </div>
                        <div class="file-meta">
                            <div class="file-name" id="fileName">—</div>
                            <div class="file-size" id="fileSize">—</div>
                        </div>
                    </div>
                </div>

                <!-- Pipeline Progress (hidden) -->
                <div class="card pipeline-card" id="pipelineCard" style="display:none;">
                    <div class="pipeline-header">
                        <i class="fa-solid fa-microchip"></i> Conversion Pipeline
                    </div>
                    <div class="pipeline-steps">
                        <div class="p-step" id="step1">
                            <span class="step-indicator">1</span>
                            <span>Parsing PDF pages with PDF.js</span>
                        </div>
                        <div class="p-step" id="step2">
                            <span class="step-indicator">2</span>
                            <span>Recreating pages with pdf-lib</span>
                        </div>
                        <div class="p-step" id="step3">
                            <span class="step-indicator">3</span>
                            <span>Removing JavaScript & cleaning metadata</span>
                        </div>
                        <div class="p-step" id="step4">
                            <span class="step-indicator">4</span>
                            <span>Flattening content & forms</span>
                        </div>
                        <div class="p-step" id="step5">
                            <span class="step-indicator">5</span>
                            <span>Injecting PDF/A metadata & OutputIntent</span>
                        </div>
                        <div class="p-step" id="step6">
                            <span class="step-indicator">6</span>
                            <span>Exporting archive-ready PDF</span>
                        </div>
                    </div>
                </div>

                <!-- Compliance (hidden) -->
                <div class="compliance-banner" id="complianceBanner" style="display:none;">
                    <i class="fa-solid fa-circle-info"></i>
                    <p>To comply with PDF/A archiving standards, encryption, embedded JavaScript, and interactive form fields will be removed or flattened during conversion. Page content is re-rendered at high resolution to ensure visual fidelity.</p>
                </div>

                <!-- Result Banner -->
                <div class="result-banner" id="resultBanner">
                    <i class="fa-solid fa-circle-check"></i>
                    <div>
                        <div class="result-text" id="resultText">Conversion complete!</div>
                        <div class="result-sub" id="resultSub"></div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="action-bar" id="actionBar">
                    <button class="btn btn-primary" id="convertBtn" onclick="startConversion()">
                        <i class="fa-solid fa-arrows-rotate"></i> Convert & Download PDF/A
                    </button>
                    <button class="btn btn-ghost-red" id="resetBtn" onclick="resetTool()">
                        <i class="fa-solid fa-rotate-left"></i> Start Over
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">© 2026 Passion Tools. Secure client-side processing.</footer>

    <script>
        /* ── Theme Toggle ── */
        const html = document.documentElement;
        const themeBtn = document.getElementById('themeToggle');

        function applyTheme(t) {
            html.setAttribute('data-theme', t);
            themeBtn.textContent = t === 'dark' ? '🌙' : '☀️';
            localStorage.setItem('pt-theme', t);
        }
        applyTheme(localStorage.getItem('pt-theme') || 'light');

        themeBtn.addEventListener('click', () => {
            applyTheme(html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
        });

        /* ── PDF.js worker ── */
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        /* ── State ── */
        let uploadedFile = null;
        let uploadedArrayBuffer = null;

        const uploadZone  = document.getElementById('uploadZone');
        const fileInput   = document.getElementById('fileInput');
        const processingUI = document.getElementById('processingUI');
        const convertBtn  = document.getElementById('convertBtn');

        /* ── Drag & Drop ── */
        uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
        uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
        uploadZone.addEventListener('drop', e => {
            e.preventDefault();
            uploadZone.classList.remove('drag-over');
            const f = e.dataTransfer.files[0];
            if (f && f.type === 'application/pdf') handleFile(f);
        });

        fileInput.addEventListener('change', e => {
            const f = e.target.files[0];
            if (f) handleFile(f);
        });

        /* ── Handle File ── */
        function formatBytes(b) {
            if (b < 1024) return b + ' B';
            if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
            return (b/1048576).toFixed(2) + ' MB';
        }

        function handleFile(file) {
            uploadedFile = file;
            document.getElementById('fileName').textContent = file.name;
            document.getElementById('fileSize').textContent = formatBytes(file.size);

            const reader = new FileReader();
            reader.onload = e => {
                uploadedArrayBuffer = e.target.result;
                showProcessingUI();
            };
            reader.readAsArrayBuffer(file);
        }

        function showProcessingUI() {
            uploadZone.style.display = 'none';
            processingUI.classList.add('active');
            resetPipeline();
        }

        /* ── Pipeline UI ── */
        function resetPipeline() {
            for (let i = 1; i <= 6; i++) {
                const s = document.getElementById('step' + i);
                s.className = 'p-step';
                s.querySelector('.step-indicator').innerHTML = i;
            }
            document.getElementById('resultBanner').className = 'result-banner';
            document.getElementById('resultBanner').style.display = 'none';
            convertBtn.disabled = false;
            convertBtn.className = 'btn btn-primary';
            convertBtn.innerHTML = '<i class="fa-solid fa-arrows-rotate"></i> Convert & Download PDF/A';
        }

        function setStep(n, state) {
            const s = document.getElementById('step' + n);
            s.className = 'p-step ' + state;
            const ind = s.querySelector('.step-indicator');
            if (state === 'active')     ind.innerHTML = '<i class="fa-solid fa-spinner spinner-icon" style="font-size:11px"></i>';
            else if (state === 'done')  ind.innerHTML = '<i class="fa-solid fa-check" style="font-size:10px"></i>';
            else if (state === 'error-step') ind.innerHTML = '<i class="fa-solid fa-xmark" style="font-size:10px"></i>';
        }

        function showResult(success, text, sub) {
            const b = document.getElementById('resultBanner');
            b.style.display = 'flex';
            if (success) {
                b.className = 'result-banner success';
                b.querySelector('i').className = 'fa-solid fa-circle-check';
            } else {
                b.className = 'result-banner error-banner';
                b.querySelector('i').className = 'fa-solid fa-circle-xmark';
            }
            document.getElementById('resultText').textContent = text;
            document.getElementById('resultSub').textContent = sub || '';
        }

        /* ── Conversion ── */
        async function startConversion() {
            if (!uploadedArrayBuffer) return;

            convertBtn.disabled = true;
            convertBtn.innerHTML = '<i class="fa-solid fa-spinner spinner-icon"></i> Converting…';
            resetPipeline();

            const RENDER_SCALE = 2.5;
            let pagesData = [];

            try {
                /* Step 1 — Parse with PDF.js */
                setStep(1, 'active');
                const pdfDoc = await pdfjsLib.getDocument({ data: uploadedArrayBuffer.slice(0) }).promise;
                const totalPages = pdfDoc.numPages;

                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');

                for (let i = 1; i <= totalPages; i++) {
                    const page = await pdfDoc.getPage(i);
                    const vp = page.getViewport({ scale: RENDER_SCALE });
                    canvas.width = vp.width;
                    canvas.height = vp.height;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    await page.render({ canvasContext: ctx, viewport: vp }).promise;

                    const blob = await new Promise(r => canvas.toBlob(r, 'image/png'));
                    const arrBuf = await blob.arrayBuffer();
                    pagesData.push({
                        png: new Uint8Array(arrBuf),
                        widthPt: vp.width / RENDER_SCALE,
                        heightPt: vp.height / RENDER_SCALE
                    });
                }
                setStep(1, 'done');

                /* Step 2 — Recreate with pdf-lib */
                setStep(2, 'active');
                const { PDFDocument, rgb } = PDFLib;
                const newPdf = await PDFDocument.create();

                for (const pd of pagesData) {
                    const img = await newPdf.embedPng(pd.png);
                    const page = newPdf.addPage([pd.widthPt, pd.heightPt]);
                    page.drawImage(img, {
                        x: 0, y: 0,
                        width: pd.widthPt,
                        height: pd.heightPt
                    });
                }
                setStep(2, 'done');

                /* Step 3 — Remove JS & clean metadata */
                setStep(3, 'active');
                await sleep(180);
                /* New document has no JS or annotations — clean slate */
                setStep(3, 'done');

                /* Step 4 — Flatten */
                setStep(4, 'active');
                try { newPdf.getForm().flatten(); } catch(_) {}
                await sleep(120);
                setStep(4, 'done');

                /* Step 5 — PDF/A metadata & OutputIntent */
                setStep(5, 'active');
                const baseName = uploadedFile.name.replace(/\.pdf$/i, '');
                const now = new Date();
                newPdf.setTitle(baseName);
                newPdf.setAuthor('PassionTools');
                newPdf.setCreator('PassionTools PDF/A Converter');
                newPdf.setProducer('PassionTools (pdf-lib)');
                newPdf.setCreationDate(now);
                newPdf.setModificationDate(now);

                /* XMP packet */
                const isoDate = now.toISOString();
                const xmpXML = `<?xpacket begin="\uFEFF" id="W5M0MpCehiHzreSzNTczkc9d"?>
<x:xmpmeta xmlns:x="adobe:ns:meta/">
  <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
    <rdf:Description rdf:about=""
      xmlns:dc="http://purl.org/dc/elements/1.1/"
      xmlns:xmp="http://ns.adobe.com/xap/1.0/"
      xmlns:pdfaid="http://www.aiim.org/pdfa/ns/id/"
      xmlns:pdfaExtension="http://www.aiim.org/pdfa/ns/extension/"
      xmlns:pdfaSchema="http://www.aiim.org/pdfa/ns/schema#">
      <pdfaid:part>2</pdfaid:part>
      <pdfaid:conformance>B</pdfaid:conformance>
      <dc:title>
        <rdf:Alt><rdf:li xml:lang="x-default">${baseName}</rdf:li></rdf:Alt>
      </dc:title>
      <dc:creator>
        <rdf:Seq><rdf:li>PassionTools</rdf:li></rdf:Seq>
      </dc:creator>
      <xmp:CreatorTool>PassionTools PDF/A Converter</xmp:CreatorTool>
      <xmp:CreateDate>${isoDate}</xmp:CreateDate>
      <xmp:ModifyDate>${isoDate}</xmp:ModifyDate>
    </rdf:Description>
  </rdf:RDF>
</x:xmpmeta>
<?xpacket end="w"?>`;

                const xmpBytes = new TextEncoder().encode(xmpXML);
                const xmpStream = newPdf.context.stream(xmpBytes, { Type: 'Metadata', Subtype: 'XML', Length: xmpBytes.length });
                const xmpRef = newPdf.context.register(xmpStream);
                newPdf.catalog.set(PDFLib.PDFName.of('Metadata'), xmpRef);

                /* MarkInfo */
                const markInfoDict = newPdf.context.obj({ Marked: true });
                newPdf.catalog.set(PDFLib.PDFName.of('MarkInfo'), markInfoDict);

                /* sRGB OutputIntent */
                const iccProfilePlaceholder = new Uint8Array(128);
                /* Minimal header so it's parseable */
                iccProfilePlaceholder[0] = 0; iccProfilePlaceholder[1] = 0; iccProfilePlaceholder[2] = 0; iccProfilePlaceholder[3] = 128;
                iccProfilePlaceholder[36] = 0x61; iccProfilePlaceholder[37] = 0x63; iccProfilePlaceholder[38] = 0x73; iccProfilePlaceholder[39] = 0x70; // 'acsp'

                const iccStream = newPdf.context.stream(iccProfilePlaceholder, { N: 3 });
                const iccRef = newPdf.context.register(iccStream);

                const outputIntentDict = newPdf.context.obj({
                    Type: 'OutputIntent',
                    S: 'GTS_PDFA1',
                    OutputConditionIdentifier: 'sRGB IEC61966-2.1',
                    RegistryName: 'http://www.color.org',
                    Info: 'sRGB IEC61966-2.1',
                    DestOutputProfile: iccRef
                });
                const outputIntentRef = newPdf.context.register(outputIntentDict);
                newPdf.catalog.set(PDFLib.PDFName.of('OutputIntents'), newPdf.context.obj([outputIntentRef]));

                setStep(5, 'done');

                /* Step 6 — Export */
                setStep(6, 'active');
                const pdfBytes = await newPdf.save();
                const blob2 = new Blob([pdfBytes], { type: 'application/pdf' });
                const url = URL.createObjectURL(blob2);
                const a = document.createElement('a');
                a.href = url;
                a.download = baseName + '-archive.pdf';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                setTimeout(() => URL.revokeObjectURL(url), 5000);

                setStep(6, 'done');

                showResult(true, 'Conversion complete!', `${totalPages} page${totalPages > 1 ? 's' : ''} converted — ${formatBytes(pdfBytes.length)} output`);
                convertBtn.className = 'btn btn-success';
                convertBtn.innerHTML = '<i class="fa-solid fa-download"></i> Download Again';
                convertBtn.disabled = false;
                convertBtn.onclick = () => {
                    const a2 = document.createElement('a');
                    a2.href = URL.createObjectURL(new Blob([pdfBytes], { type: 'application/pdf' }));
                    a2.download = baseName + '-archive.pdf';
                    document.body.appendChild(a2);
                    a2.click();
                    document.body.removeChild(a2);
                };

            } catch (err) {
                console.error(err);
                for (let i = 1; i <= 6; i++) {
                    const s = document.getElementById('step' + i);
                    if (s.classList.contains('active')) setStep(i, 'error-step');
                }
                showResult(false, 'Conversion failed', err.message || 'An unexpected error occurred.');
                convertBtn.disabled = false;
                convertBtn.className = 'btn btn-primary';
                convertBtn.innerHTML = '<i class="fa-solid fa-arrows-rotate"></i> Retry Conversion';
            }
        }

        function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

        /* ── Reset ── */
        function resetTool() {
            uploadedFile = null;
            uploadedArrayBuffer = null;
            fileInput.value = '';
            processingUI.classList.remove('active');
            uploadZone.style.display = '';
            convertBtn.onclick = startConversion;
            resetPipeline();
        }
    </script>
</body>
</html>

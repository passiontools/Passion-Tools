<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDF to Word - PassionTools</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script src="https://unpkg.com/docx@8.5.0/build/index.umd.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <style>
        :root {
            --red: #ef4444;
            --purple: #a855f7;
            --blue: #3b82f6;
            --blue-dark: #2563eb;
            --green: #22c55e;
            --bg-color: #f9fafb;
            --card-bg: #ffffff;
            --text-primary: #1f2937;
            --text-secondary: #6b7280;
            --border-color: #e5e7eb;
            --hover-gray: #f3f4f6;
            --btn-action-bg: #fef2f2;
            --logo-passion: #000000;
            --header-bg: rgba(255, 255, 255, 0.72);
            --header-border: rgba(229, 231, 235, 0.6);
            --footer-bg: #111827;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04);
            --shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.08), 0 8px 10px -6px rgba(0,0,0,0.04);
        }

        [data-theme="dark"] {
            --bg-color: #020617;
            --card-bg: #111827;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --border-color: #1e293b;
            --hover-gray: #1e293b;
            --btn-action-bg: #450a0a;
            --logo-passion: #ffffff;
            --header-bg: rgba(2, 6, 23, 0.78);
            --header-border: rgba(30, 41, 59, 0.6);
            --footer-bg: #020617;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.3);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.4), 0 2px 4px -2px rgba(0,0,0,0.3);
            --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.45), 0 4px 6px -4px rgba(0,0,0,0.3);
            --shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.5), 0 8px 10px -6px rgba(0,0,0,0.35);
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex; flex-direction: column;
            transition: background-color 0.3s ease, color 0.3s ease;
            line-height: 1.6;
        }

        /* ===== HEADER ===== */
        .header {
            position: sticky; top: 0; z-index: 100;
            background: var(--header-bg);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-bottom: 1px solid var(--header-border);
            transition: all 0.3s ease;
        }
        .header-inner {
            max-width: 1200px; margin: 0 auto; padding: 0 24px;
            height: 64px; display: flex; align-items: center; justify-content: space-between;
        }
        .logo {
            text-decoration: none; font-size: 22px; font-weight: 800;
            letter-spacing: -0.5px; display: flex; align-items: center;
            background: none; border: none; outline: none;
        }
        .logo-passion { color: var(--logo-passion); transition: color 0.3s ease; }
        .logo-tools {
            background: linear-gradient(135deg, var(--red), var(--purple));
            -webkit-background-clip: text; background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .header-actions { display: flex; align-items: center; gap: 20px; }
        .back-link {
            text-decoration: none; color: var(--text-secondary); font-size: 14px;
            font-weight: 500; display: flex; align-items: center; gap: 6px;
            transition: all 0.3s ease;
        }
        .back-link:hover { color: var(--red); }
        .theme-toggle {
            background: none; border: none; cursor: pointer; font-size: 20px;
            width: 40px; height: 40px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.3s ease;
        }
        .theme-toggle:hover { background: var(--hover-gray); }

        /* ===== MAIN ===== */
        .main {
            flex: 1; max-width: 980px; width: 100%;
            margin: 0 auto; padding: 48px 24px 60px;
        }

        .tool-header { text-align: center; margin-bottom: 40px; }
        .tool-title {
            font-size: 32px; font-weight: 800; color: var(--text-primary);
            margin-bottom: 10px; letter-spacing: -0.5px;
        }
        .tool-subtitle {
            font-size: 16px; color: var(--text-secondary);
            max-width: 620px; margin: 0 auto; line-height: 1.7;
        }

        /* ===== MODE SELECTION ===== */
        .mode-selection {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 20px; margin-bottom: 0;
        }

        .mode-card {
            background: var(--card-bg);
            border: 2px solid var(--border-color);
            border-radius: 20px; padding: 32px 24px;
            cursor: pointer; transition: all 0.3s ease;
            text-align: center; position: relative; overflow: hidden;
        }
        .mode-card::before {
            content: ''; position: absolute; inset: 0;
            opacity: 0; transition: opacity 0.3s ease; border-radius: 18px;
        }
        .mode-card.card-text::before { background: linear-gradient(135deg, rgba(59,130,246,0.04), rgba(37,99,235,0.06)); }
        .mode-card.card-image::before { background: linear-gradient(135deg, rgba(168,85,247,0.04), rgba(239,68,68,0.06)); }

        .mode-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-xl); }
        .mode-card:hover::before { opacity: 1; }
        .mode-card.card-text:hover { border-color: var(--blue); }
        .mode-card.card-image:hover { border-color: var(--purple); }

        .mode-card.selected.card-text { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(59,130,246,0.15), var(--shadow-lg); }
        .mode-card.selected.card-image { border-color: var(--purple); box-shadow: 0 0 0 3px rgba(168,85,247,0.15), var(--shadow-lg); }

        .mode-card-icon {
            width: 64px; height: 64px; border-radius: 18px;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 18px; position: relative; z-index: 1;
        }
        .card-text .mode-card-icon { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
        [data-theme="dark"] .card-text .mode-card-icon { background: linear-gradient(135deg, #1e3a5f, #1e40af); }
        .card-image .mode-card-icon { background: linear-gradient(135deg, #f3e8ff, #e9d5ff); }
        [data-theme="dark"] .card-image .mode-card-icon { background: linear-gradient(135deg, #3b1764, #6b21a8); }

        .mode-card-icon i { font-size: 26px; }
        .card-text .mode-card-icon i { color: var(--blue); }
        .card-image .mode-card-icon i { color: var(--purple); }

        .mode-card-title {
            font-size: 18px; font-weight: 700; color: var(--text-primary);
            margin-bottom: 8px; position: relative; z-index: 1;
        }
        .mode-card-desc {
            font-size: 13px; color: var(--text-secondary);
            line-height: 1.6; position: relative; z-index: 1; margin-bottom: 16px;
        }

        .mode-card-badge {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 5px 14px; border-radius: 999px;
            font-size: 11px; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.5px;
            position: relative; z-index: 1;
        }
        .card-text .mode-card-badge { background: #dbeafe; color: #1d4ed8; }
        [data-theme="dark"] .card-text .mode-card-badge { background: #1e3a5f; color: #93c5fd; }
        .card-image .mode-card-badge { background: #f3e8ff; color: #7c3aed; }
        [data-theme="dark"] .card-image .mode-card-badge { background: #3b1764; color: #c4b5fd; }

        .mode-selected-check {
            position: absolute; top: 14px; right: 14px;
            width: 28px; height: 28px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            opacity: 0; transform: scale(0); transition: all 0.3s ease; z-index: 2;
        }
        .card-text .mode-selected-check { background: var(--blue); }
        .card-image .mode-selected-check { background: var(--purple); }
        .mode-card.selected .mode-selected-check { opacity: 1; transform: scale(1); }
        .mode-selected-check i { color: white; font-size: 12px; }

        .mode-card-features {
            list-style: none; text-align: left;
            margin-top: 16px; padding-top: 16px;
            border-top: 1px solid var(--border-color);
            position: relative; z-index: 1;
        }
        .mode-card-features li {
            font-size: 12.5px; color: var(--text-secondary);
            padding: 4px 0; display: flex; align-items: center; gap: 8px;
        }
        .mode-card-features li i { font-size: 10px; width: 14px; text-align: center; }
        .card-text .mode-card-features li i { color: var(--blue); }
        .card-image .mode-card-features li i { color: var(--purple); }

        /* ===== TOOL CARD ===== */
        .tool-card {
            background: var(--card-bg); border: 1px solid var(--border-color);
            border-radius: 20px; padding: 40px; box-shadow: var(--shadow-lg);
            transition: all 0.3s ease; margin-top: 20px; display: none;
        }
        .tool-card.visible { display: block; }

        .selected-mode-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 24px; padding-bottom: 18px;
            border-bottom: 1px solid var(--border-color);
        }
        .selected-mode-info { display: flex; align-items: center; gap: 12px; }
        .selected-mode-icon {
            width: 40px; height: 40px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
        }
        .selected-mode-icon.text-mode { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
        [data-theme="dark"] .selected-mode-icon.text-mode { background: linear-gradient(135deg, #1e3a5f, #1e40af); }
        .selected-mode-icon.image-mode { background: linear-gradient(135deg, #f3e8ff, #e9d5ff); }
        [data-theme="dark"] .selected-mode-icon.image-mode { background: linear-gradient(135deg, #3b1764, #6b21a8); }

        .selected-mode-icon i { font-size: 18px; }
        .selected-mode-icon.text-mode i { color: var(--blue); }
        .selected-mode-icon.image-mode i { color: var(--purple); }

        .selected-mode-label { font-size: 15px; font-weight: 600; color: var(--text-primary); }
        .selected-mode-sublabel { font-size: 12px; color: var(--text-secondary); }

        .change-mode-btn {
            background: transparent; border: 1.5px solid var(--border-color);
            border-radius: 10px; padding: 8px 16px;
            font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 500;
            color: var(--text-secondary); cursor: pointer;
            display: flex; align-items: center; gap: 6px; transition: all 0.3s ease;
        }
        .change-mode-btn:hover {
            background: var(--hover-gray); color: var(--text-primary);
            border-color: var(--text-secondary);
        }

        /* Upload Zone */
        .upload-zone {
            border: 2px dashed var(--border-color);
            border-radius: 16px; padding: 56px 32px;
            text-align: center; cursor: pointer;
            transition: all 0.3s ease; position: relative; overflow: hidden;
        }
        .upload-zone::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(59,130,246,0.03), rgba(168,85,247,0.03));
            opacity: 0; transition: opacity 0.3s ease;
        }
        .upload-zone:hover, .upload-zone.drag-over {
            border-color: var(--blue); background: rgba(59, 130, 246, 0.03);
        }
        .upload-zone:hover::before, .upload-zone.drag-over::before { opacity: 1; }
        .upload-zone.drag-over { transform: scale(1.01); box-shadow: 0 0 0 4px rgba(59,130,246,0.1); }

        .upload-icon {
            width: 56px; height: 56px; margin: 0 auto 20px;
            border-radius: 14px; display: flex;
            align-items: center; justify-content: center;
            transition: transform 0.3s ease;
        }
        .upload-icon.text-icon { background: linear-gradient(135deg, var(--blue), var(--blue-dark)); }
        .upload-icon.image-icon { background: linear-gradient(135deg, var(--purple), var(--red)); }
        .upload-zone:hover .upload-icon { transform: translateY(-2px); }
        .upload-icon i { font-size: 24px; color: white; }

        .upload-primary-text { font-size: 17px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; }
        .upload-secondary-text { font-size: 13px; color: var(--text-secondary); }
        .upload-secondary-text span { color: var(--blue); font-weight: 500; }
        #fileInput { display: none; }

        /* Processing */
        .processing-state { display: none; text-align: center; padding: 40px 20px; }
        .processing-state.active { display: block; }
        .processing-animation { width: 80px; height: 80px; margin: 0 auto 28px; position: relative; }
        .processing-spinner {
            width: 80px; height: 80px;
            border: 3px solid var(--border-color);
            border-top-color: var(--blue); border-right-color: var(--purple);
            border-radius: 50%; animation: spin 1s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .processing-inner-icon {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 24px; color: var(--blue);
            animation: pulse 1.5s ease-in-out infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
            50% { opacity: 0.6; transform: translate(-50%, -50%) scale(0.9); }
        }
        .processing-title { font-size: 18px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
        .processing-subtitle { font-size: 14px; color: var(--text-secondary); margin-bottom: 24px; }
        .progress-bar-container {
            width: 100%; max-width: 400px; height: 6px;
            background: var(--border-color); border-radius: 999px;
            margin: 0 auto; overflow: hidden;
        }
        .progress-bar-fill {
            height: 100%; width: 0%;
            background: linear-gradient(90deg, var(--blue), var(--purple));
            border-radius: 999px; transition: width 0.3s ease;
        }
        .progress-text { font-size: 13px; color: var(--text-secondary); margin-top: 10px; font-weight: 500; }

        /* Success */
        .success-state { display: none; text-align: center; padding: 20px 0 0; }
        .success-state.active { display: block; }
        .success-banner {
            background: linear-gradient(135deg, #f0fdf4, #dcfce7);
            border: 1px solid #bbf7d0; border-radius: 14px;
            padding: 20px 24px; display: flex; align-items: center;
            gap: 14px; margin-bottom: 28px; text-align: left;
        }
        [data-theme="dark"] .success-banner {
            background: linear-gradient(135deg, #052e16, #14532d);
            border-color: #166534;
        }
        .success-icon-circle {
            width: 44px; height: 44px; min-width: 44px;
            background: var(--green); border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            animation: successPop 0.5s ease;
        }
        @keyframes successPop { 0% { transform: scale(0); } 60% { transform: scale(1.2); } 100% { transform: scale(1); } }
        .success-icon-circle i { color: white; font-size: 20px; }
        .success-text-group h3 { font-size: 16px; font-weight: 700; color: var(--text-primary); margin-bottom: 2px; }
        .success-text-group p { font-size: 13px; color: var(--text-secondary); }

        .file-details {
            background: var(--hover-gray); border-radius: 12px;
            padding: 18px 22px; margin-bottom: 28px;
            display: flex; flex-wrap: wrap; gap: 20px;
        }
        .file-detail-item { flex: 1; min-width: 80px; text-align: left; }
        .file-detail-item .label {
            font-size: 11px; font-weight: 500; color: var(--text-secondary);
            text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px;
        }
        .file-detail-item .value {
            font-size: 14px; font-weight: 600; color: var(--text-primary);
            word-break: break-all;
        }

        .action-buttons { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
        .btn {
            display: inline-flex; align-items: center; justify-content: center;
            gap: 8px; padding: 13px 28px; border-radius: 12px;
            font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 600;
            cursor: pointer; transition: all 0.3s ease; border: none; text-decoration: none;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--blue), var(--blue-dark));
            color: white; box-shadow: 0 4px 14px rgba(59,130,246,0.35);
        }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(59,130,246,0.45); }
        .btn-primary:active { transform: translateY(0); }
        .btn-ghost {
            background: transparent; color: var(--text-secondary);
            border: 1.5px solid var(--border-color);
        }
        .btn-ghost:hover { background: var(--hover-gray); color: var(--text-primary); border-color: var(--text-secondary); }

        /* Error */
        .error-state { display: none; text-align: center; padding: 20px 0 0; }
        .error-state.active { display: block; }
        .error-banner {
            background: linear-gradient(135deg, #fef2f2, #fee2e2);
            border: 1px solid #fecaca; border-radius: 14px;
            padding: 24px; margin-bottom: 24px;
        }
        [data-theme="dark"] .error-banner {
            background: linear-gradient(135deg, #450a0a, #7f1d1d);
            border-color: #991b1b;
        }
        .error-icon-circle {
            width: 52px; height: 52px; background: var(--red);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; margin: 0 auto 16px;
        }
        .error-icon-circle i { color: white; font-size: 22px; }
        .error-banner h3 { font-size: 17px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
        .error-banner p { font-size: 14px; color: var(--text-secondary); line-height: 1.6; }

        /* ===== FOOTER ===== */
        .footer { background: var(--footer-bg); padding: 30px 20px; text-align: center; }
        [data-theme="dark"] .footer { background: #020617; }
        .footer p { font-size: 14px; color: #94a3b8; }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 640px) {
            .main { padding: 32px 16px 48px; }
            .tool-card { padding: 24px 20px; border-radius: 16px; }
            .upload-zone { padding: 40px 20px; }
            .tool-title { font-size: 26px; }
            .tool-subtitle { font-size: 14px; }
            .mode-selection { grid-template-columns: 1fr; gap: 14px; }
            .mode-card { padding: 24px 20px; }
            .action-buttons { flex-direction: column; }
            .action-buttons .btn { width: 100%; }
            .file-details { flex-direction: column; gap: 12px; }
            .success-banner { flex-direction: column; text-align: center; gap: 10px; }
            .header-inner { padding: 0 16px; }
            .back-link span.back-text { display: none; }
            .selected-mode-header { flex-direction: column; gap: 12px; align-items: flex-start; }
            .change-mode-btn { align-self: flex-start; }
        }
        @media (max-width: 380px) { .logo { font-size: 19px; } }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
        .fade-in-up { animation: fadeInUp 0.5s ease forwards; }
        @keyframes scaleIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
        .scale-in { animation: scaleIn 0.4s ease forwards; }
    </style>
</head>
<body>
    <!-- HEADER -->
    <header class="header">
        <div class="header-inner">
            <a href="#" onclick="event.preventDefault();" class="logo">
                <span class="logo-passion">Passion</span><span class="logo-tools">Tools</span>
            </a>
            <div class="header-actions">
                <a href="index.html" class="back-link">
                    <i class="fas fa-arrow-left"></i>
                    <span class="back-text">Back to Tools</span>
                </a>
                <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">☀️</button>
            </div>
        </div>
    </header>

    <!-- MAIN -->
    <main class="main">
        <div class="tool-header fade-in-up">
            <h1 class="tool-title">PDF to Word</h1>
            <p class="tool-subtitle">Extract text and images from your PDF files and convert them to editable Word (.docx) documents. 100% private in-browser processing.</p>
        </div>

        <!-- Step 1: Choose Mode -->
        <div id="modeSelectionStep" class="fade-in-up" style="animation-delay: 0.1s;">
            <div class="mode-selection">
                <!-- Text Mode -->
                <div class="mode-card card-text" id="cardText" onclick="selectMode('text')">
                    <div class="mode-selected-check"><i class="fas fa-check"></i></div>
                    <div class="mode-card-icon"><i class="fas fa-font"></i></div>
                    <div class="mode-card-title">Text Mode</div>
                    <div class="mode-card-desc">Extract editable text from your PDF. Best for documents with selectable text content.</div>
                    <span class="mode-card-badge"><i class="fas fa-bolt"></i> Fast & Light</span>
                    <ul class="mode-card-features">
                        <li><i class="fas fa-check-circle"></i> Extracts selectable text</li>
                        <li><i class="fas fa-check-circle"></i> Preserves paragraphs & line breaks</li>
                        <li><i class="fas fa-check-circle"></i> Smallest file size output</li>
                        <li><i class="fas fa-check-circle"></i> Fully editable Word document</li>
                    </ul>
                </div>

                <!-- Image Mode -->
                <div class="mode-card card-image" id="cardImage" onclick="selectMode('image')">
                    <div class="mode-selected-check"><i class="fas fa-check"></i></div>
                    <div class="mode-card-icon"><i class="fas fa-images"></i></div>
                    <div class="mode-card-title">Image Mode</div>
                    <div class="mode-card-desc">Render every page as a high-quality image. Perfect for scanned PDFs & visual layouts.</div>
                    <span class="mode-card-badge"><i class="fas fa-image"></i> Visual Fidelity</span>
                    <ul class="mode-card-features">
                        <li><i class="fas fa-check-circle"></i> Captures full page visuals</li>
                        <li><i class="fas fa-check-circle"></i> Works with scanned PDFs</li>
                        <li><i class="fas fa-check-circle"></i> Preserves charts & diagrams</li>
                        <li><i class="fas fa-check-circle"></i> Retains exact layout & fonts</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Step 2: Upload Card -->
        <div class="tool-card" id="toolCard">
            <div class="selected-mode-header" id="selectedModeHeader">
                <div class="selected-mode-info">
                    <div class="selected-mode-icon" id="selectedModeIcon">
                        <i class="fas fa-font" id="selectedModeIconI"></i>
                    </div>
                    <div>
                        <div class="selected-mode-label" id="selectedModeLabel">Text Mode</div>
                        <div class="selected-mode-sublabel" id="selectedModeSublabel">Extracting editable text</div>
                    </div>
                </div>
                <button class="change-mode-btn" onclick="changeMode()">
                    <i class="fas fa-arrow-left"></i> Change Mode
                </button>
            </div>

            <div id="uploadState">
                <div class="upload-zone" id="uploadZone">
                    <div class="upload-icon text-icon" id="uploadIconDiv">
                        <i class="fas fa-file-pdf"></i>
                    </div>
                    <p class="upload-primary-text">Click or Drag & Drop PDF here</p>
                    <p class="upload-secondary-text">Supports <span>.pdf</span> files up to 100MB</p>
                </div>
                <input type="file" id="fileInput" accept=".pdf,application/pdf">
            </div>

            <div class="processing-state" id="processingState">
                <div class="processing-animation">
                    <div class="processing-spinner"></div>
                    <i class="fas fa-file-word processing-inner-icon"></i>
                </div>
                <p class="processing-title">Processing your PDF...</p>
                <p class="processing-subtitle" id="processingSubtitle">Extracting text and generating Word document...</p>
                <div class="progress-bar-container">
                    <div class="progress-bar-fill" id="progressBar"></div>
                </div>
                <p class="progress-text" id="progressText">Initializing...</p>
            </div>

            <div class="success-state" id="successState">
                <div class="success-banner">
                    <div class="success-icon-circle"><i class="fas fa-check"></i></div>
                    <div class="success-text-group">
                        <h3>Conversion Complete!</h3>
                        <p>Your Word document is ready to download.</p>
                    </div>
                </div>
                <div class="file-details">
                    <div class="file-detail-item">
                        <div class="label">File</div>
                        <div class="value" id="origFileName">—</div>
                    </div>
                    <div class="file-detail-item">
                        <div class="label">Pages</div>
                        <div class="value" id="pageCount">—</div>
                    </div>
                    <div class="file-detail-item" id="imageCountWrapper" style="display:none;">
                        <div class="label">Images</div>
                        <div class="value" id="imageCount">—</div>
                    </div>
                    <div class="file-detail-item">
                        <div class="label">Mode</div>
                        <div class="value" id="modeUsed">—</div>
                    </div>
                    <div class="file-detail-item">
                        <div class="label">Output</div>
                        <div class="value">.docx</div>
                    </div>
                </div>
                <div class="action-buttons">
                    <button class="btn btn-primary" id="downloadBtn">
                        <i class="fas fa-download"></i> Download Word Document
                    </button>
                    <button class="btn btn-ghost" id="convertAnotherBtn">
                        <i class="fas fa-redo"></i> Convert Another File
                    </button>
                </div>
            </div>

            <div class="error-state" id="errorState">
                <div class="error-banner">
                    <div class="error-icon-circle"><i class="fas fa-exclamation-triangle"></i></div>
                    <h3 id="errorTitle">Conversion Failed</h3>
                    <p id="errorMessage">An error occurred during conversion.</p>
                </div>
                <div class="action-buttons">
                    <button class="btn btn-ghost" id="errorRetryBtn">
                        <i class="fas fa-redo"></i> Try Again
                    </button>
                </div>
            </div>
        </div>
    </main>

    <canvas id="renderCanvas" style="display:none;"></canvas>

    <!-- FOOTER -->
    <footer class="footer">
        <p>&copy; 2026 Passion Tools. Secure client-side processing.</p>
    </footer>

    <script>
        // ===== THEME =====
        const themeToggle = document.getElementById('themeToggle');
        const storedTheme = localStorage.getItem('pt-theme');
        if (storedTheme === 'dark' || (!storedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
            themeToggle.textContent = '🌙';
        } else {
            document.documentElement.removeAttribute('data-theme');
            themeToggle.textContent = '☀️';
        }
        themeToggle.addEventListener('click', () => {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            if (isDark) {
                document.documentElement.removeAttribute('data-theme');
                themeToggle.textContent = '☀️';
                localStorage.setItem('pt-theme', 'light');
            } else {
                document.documentElement.setAttribute('data-theme', 'dark');
                themeToggle.textContent = '🌙';
                localStorage.setItem('pt-theme', 'dark');
            }
        });

        // ===== PDF.js =====
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        // ===== STATE =====
        let conversionMode = null;
        let generatedBlob = null;
        let outputFileName = 'converted.docx';

        const modeSelectionStep = document.getElementById('modeSelectionStep');
        const toolCard = document.getElementById('toolCard');
        const uploadState = document.getElementById('uploadState');
        const processingState = document.getElementById('processingState');
        const successState = document.getElementById('successState');
        const errorState = document.getElementById('errorState');
        const uploadZone = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');

        // ===== MODE SELECTION =====
        function selectMode(mode) {
            conversionMode = mode;
            document.getElementById('cardText').classList.remove('selected');
            document.getElementById('cardImage').classList.remove('selected');

            if (mode === 'text') document.getElementById('cardText').classList.add('selected');
            else if (mode === 'image') document.getElementById('cardImage').classList.add('selected');

            setTimeout(() => showUploadCard(mode), 350);
        }

        function showUploadCard(mode) {
            const icon = document.getElementById('selectedModeIcon');
            const iconI = document.getElementById('selectedModeIconI');
            const label = document.getElementById('selectedModeLabel');
            const sublabel = document.getElementById('selectedModeSublabel');
            const uploadIconDiv = document.getElementById('uploadIconDiv');

            if (mode === 'text') {
                icon.className = 'selected-mode-icon text-mode';
                iconI.className = 'fas fa-font';
                label.textContent = 'Text Mode';
                sublabel.textContent = 'Extracting editable text from PDF';
                uploadIconDiv.className = 'upload-icon text-icon';
            } else if (mode === 'image') {
                icon.className = 'selected-mode-icon image-mode';
                iconI.className = 'fas fa-images';
                label.textContent = 'Image Mode';
                sublabel.textContent = 'Rendering pages as high-quality images';
                uploadIconDiv.className = 'upload-icon image-icon';
            }

            modeSelectionStep.style.display = 'none';
            toolCard.classList.add('visible');
            toolCard.classList.add('scale-in');
            showInnerState('upload');
        }

        function changeMode() {
            toolCard.classList.remove('visible', 'scale-in');
            modeSelectionStep.style.display = 'block';
            conversionMode = null;
            document.getElementById('cardText').classList.remove('selected');
            document.getElementById('cardImage').classList.remove('selected');
            generatedBlob = null;
            fileInput.value = '';
        }

        function showInnerState(state) {
            uploadState.style.display = 'none';
            processingState.classList.remove('active');
            successState.classList.remove('active');
            errorState.classList.remove('active');
            document.getElementById('selectedModeHeader').style.display = '';

            if (state === 'upload') uploadState.style.display = 'block';
            else if (state === 'processing') processingState.classList.add('active');
            else if (state === 'success') successState.classList.add('active');
            else if (state === 'error') errorState.classList.add('active');
        }

        // ===== UPLOAD ZONE =====
        uploadZone.addEventListener('click', () => fileInput.click());
        uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
        uploadZone.addEventListener('dragleave', (e) => { e.preventDefault(); uploadZone.classList.remove('drag-over'); });
        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault(); uploadZone.classList.remove('drag-over');
            const file = e.dataTransfer.files[0];
            if (file && file.type === 'application/pdf') processFile(file);
        });
        fileInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) processFile(file);
        });

        // ===== CORE CONVERSION =====
        async function processFile(file) {
            showInnerState('processing');
            const progressBar = document.getElementById('progressBar');
            const progressText = document.getElementById('progressText');
            const processingSubtitle = document.getElementById('processingSubtitle');

            progressBar.style.width = '0%';
            progressText.textContent = 'Loading PDF...';

            const modeMessages = {
                text: 'Extracting text and generating Word document...',
                image: 'Rendering pages as images and generating Word document...'
            };
            processingSubtitle.textContent = modeMessages[conversionMode];

            try {
                const arrayBuffer = await file.arrayBuffer();
                progressBar.style.width = '8%';
                progressText.textContent = 'Parsing PDF structure...';

                let pdf;
                try {
                    pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                } catch (err) {
                    if (err.name === 'PasswordException') {
                        showError('Password-Protected PDF', 'This PDF is password-protected. Please unlock the PDF first, then try again.');
                        return;
                    }
                    throw err;
                }

                const totalPages = pdf.numPages;
                progressBar.style.width = '12%';
                progressText.textContent = `Processing ${totalPages} page(s)...`;

                const { Document, Packer, Paragraph, TextRun, ImageRun, AlignmentType } = window.docx;

                let docChildren = [];
                let totalImagesRendered = 0;
                const RENDER_SCALE = 2.0;
                const renderCanvas = document.getElementById('renderCanvas');
                const renderCtx = renderCanvas.getContext('2d');

                // ========== TEXT MODE ==========
                if (conversionMode === 'text') {
                    let totalTextChars = 0;
                    for (let i = 1; i <= totalPages; i++) {
                        const page = await pdf.getPage(i);
                        const textContent = await page.getTextContent();
                        let pageLines = [];
                        let lastY = null;

                        for (const item of textContent.items) {
                            const y = item.transform[5];
                            if (lastY !== null && Math.abs(y - lastY) > 2) pageLines.push('\n');
                            pageLines.push(item.str);
                            lastY = y;
                        }

                        const pageText = pageLines.join('').trim();
                        totalTextChars += pageText.replace(/\s/g, '').length;

                        if (pageText.length > 0) {
                            const lines = pageText.split('\n');
                            for (const line of lines) {
                                docChildren.push(new Paragraph({
                                    children: [new TextRun({ text: line, font: 'Calibri', size: 24 })],
                                    spacing: { after: 80 },
                                }));
                            }
                        }
                        if (i < totalPages) {
                            docChildren.push(new Paragraph({ children: [], pageBreakBefore: true }));
                        }

                        const pct = 12 + Math.round((i / totalPages) * 76);
                        progressBar.style.width = pct + '%';
                        progressText.textContent = `Extracted page ${i} of ${totalPages}...`;
                        await new Promise(r => setTimeout(r, 20));
                    }

                    if (totalTextChars < 5) {
                        showError('No Text Content Found',
                            'This PDF appears to contain only scanned images without OCR text. Try "Image Mode" instead to capture the visual content.');
                        return;
                    }

                // ========== IMAGE MODE ==========
                } else if (conversionMode === 'image') {
                    for (let i = 1; i <= totalPages; i++) {
                        const page = await pdf.getPage(i);
                        const viewport = page.getViewport({ scale: RENDER_SCALE });
                        renderCanvas.width = viewport.width;
                        renderCanvas.height = viewport.height;
                        renderCtx.fillStyle = '#ffffff';
                        renderCtx.fillRect(0, 0, viewport.width, viewport.height);

                        await page.render({ canvasContext: renderCtx, viewport }).promise;

                        const jpegBlob = await new Promise(resolve => renderCanvas.toBlob(resolve, 'image/jpeg', 0.90));
                        const imgArrayBuffer = await jpegBlob.arrayBuffer();
                        const imgData = new Uint8Array(imgArrayBuffer);

                        const maxW = 595;
                        const ratio = viewport.height / viewport.width;
                        totalImagesRendered++;

                        docChildren.push(new Paragraph({
                            children: [new ImageRun({
                                data: imgData,
                                transformation: { width: maxW, height: Math.round(maxW * ratio) },
                                type: 'jpg',
                            })],
                            alignment: AlignmentType.CENTER,
                            spacing: { after: 0 },
                        }));

                        if (i < totalPages) {
                            docChildren.push(new Paragraph({ children: [], pageBreakBefore: true }));
                        }

                        const pct = 12 + Math.round((i / totalPages) * 76);
                        progressBar.style.width = pct + '%';
                        progressText.textContent = `Rendered page ${i} of ${totalPages}...`;
                        await new Promise(r => setTimeout(r, 20));
                    }
                }

                if (docChildren.length === 0) {
                    showError('No Content Found', 'This PDF appears to be empty.');
                    return;
                }

                progressBar.style.width = '90%';
                progressText.textContent = 'Building Word document...';

                const doc = new Document({
                    sections: [{ properties: {}, children: docChildren }],
                });

                progressBar.style.width = '95%';
                progressText.textContent = 'Generating file...';

                generatedBlob = await Packer.toBlob(doc);
                outputFileName = file.name.replace(/\.pdf$/i, '') + '.docx';

                progressBar.style.width = '100%';
                progressText.textContent = 'Done!';
                await new Promise(r => setTimeout(r, 400));

                // Fill success details
                document.getElementById('origFileName').textContent = file.name;
                document.getElementById('pageCount').textContent = totalPages;

                const modeLabels = { text: 'Text', image: 'Image' };
                document.getElementById('modeUsed').textContent = modeLabels[conversionMode];

                const imgWrap = document.getElementById('imageCountWrapper');
                const imgEl = document.getElementById('imageCount');
                if (conversionMode === 'image') {
                    imgWrap.style.display = '';
                    imgEl.textContent = totalImagesRendered;
                } else {
                    imgWrap.style.display = 'none';
                }

                showInnerState('success');

            } catch (err) {
                console.error('Conversion error:', err);
                showError('Conversion Failed',
                    'An unexpected error occurred while processing your PDF. Please ensure the file is not corrupted and try again. Error: ' + (err.message || 'Unknown error'));
            }
        }

        function showError(title, message) {
            document.getElementById('errorTitle').textContent = title;
            document.getElementById('errorMessage').textContent = message;
            showInnerState('error');
        }

        // ===== BUTTONS =====
        document.getElementById('downloadBtn').addEventListener('click', () => {
            if (generatedBlob) saveAs(generatedBlob, outputFileName);
        });
        document.getElementById('convertAnotherBtn').addEventListener('click', resetToModeSelection);
        document.getElementById('errorRetryBtn').addEventListener('click', resetToModeSelection);

        function resetToModeSelection() {
            generatedBlob = null;
            fileInput.value = '';
            toolCard.classList.remove('visible', 'scale-in');
            modeSelectionStep.style.display = 'block';
            conversionMode = null;
            document.getElementById('cardText').classList.remove('selected');
            document.getElementById('cardImage').classList.remove('selected');
        }
    </script>
</body>
</html>
